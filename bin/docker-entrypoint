#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
    LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
    export LD_PRELOAD
fi

# If running the rails server then create or migrate existing database
if [ "$1" = "bin/rails" ] || [ "$1" = "./bin/rails" ]; then
  if [ "$2" = "server" ]; then
    ./bin/rails db:prepare

    # db:prepare only migrates the primary DB; queue/cache share DATABASE_URL
    # and have no migrations, so load their schemas when tables are missing.
    ./bin/rails runner "
      {
        queue: 'solid_queue_jobs',
        cache: 'solid_cache_entries'
      }.each do |db, table|
        config = ActiveRecord::Base.configurations.configs_for(env_name: Rails.env, name: db.to_s)
        ActiveRecord::Base.establish_connection(config)
        load(Rails.root.join(\"db/\#{db}_schema.rb\")) unless ActiveRecord::Base.connection.table_exists?(table)
      end
    "
  fi
fi

exec "${@}"
