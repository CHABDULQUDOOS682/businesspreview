<!DOCTYPE html>
<html>
  <head>
    <meta content='text/html; charset=UTF-8' http-transform='content-type' />
  </head>
  <body style="font-family: sans-serif; color: #333; line-height: 1.6;">
    <h2 style="color: #213885;">You have a new project inquiry!</h2>
    <hr style="border: 0; border-top: 1px solid #eee;" />
    
    <p><strong>Name:</strong> <%= @first_name %> <%= @last_name %></p>
    <p><strong>Email:</strong> <%= @email %></p>
    <p><strong>Company:</strong> <%= @company.presence || "Not specified" %></p>
    <p><strong>Service Interest:</strong> <%= @service_interest %></p>
    
    <div style="background: #f9f9f9; padding: 15px; border-radius: 8px; border-left: 4px solid #5F3475; margin-top: 20px;">
      <p style="margin-top: 0;"><strong>Project Details:</strong></p>
      <p style="white-space: pre-wrap;"><%= @message %></p>
    </div>
  </body>
</html>
