<h2 style="margin: 0 0 20px 0; font-size: 20px; font-weight: 800; color: #081849; font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">You have a new project inquiry!</h2>

<table border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 24px; border: 1px solid rgba(8, 24, 73, 0.08); border-radius: 16px; background-color: #FAF8F5; overflow: hidden; border-collapse: separate !important;">
  <tr>
    <td style="padding: 14px 20px; border-bottom: 1px solid rgba(8, 24, 73, 0.05); font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 14px; color: rgba(8, 24, 73, 0.6); width: 120px;"><strong>Name</strong></td>
    <td style="padding: 14px 20px; border-bottom: 1px solid rgba(8, 24, 73, 0.05); font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 14px; color: #081849;"><strong><%= @first_name %> <%= @last_name %></strong></td>
  </tr>
  <tr>
    <td style="padding: 14px 20px; border-bottom: 1px solid rgba(8, 24, 73, 0.05); font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 14px; color: rgba(8, 24, 73, 0.6);"><strong>Email</strong></td>
    <td style="padding: 14px 20px; border-bottom: 1px solid rgba(8, 24, 73, 0.05); font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 14px; color: #081849;"><a href="mailto:<%= @email %>" style="color: #213885; text-decoration: none; font-weight: 600;"><%= @email %></a></td>
  </tr>
  <tr>
    <td style="padding: 14px 20px; border-bottom: 1px solid rgba(8, 24, 73, 0.05); font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 14px; color: rgba(8, 24, 73, 0.6);"><strong>Company</strong></td>
    <td style="padding: 14px 20px; border-bottom: 1px solid rgba(8, 24, 73, 0.05); font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 14px; color: #081849;"><%= @company.presence || "Not specified" %></td>
  </tr>
  <tr>
    <td style="padding: 14px 20px; font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 14px; color: rgba(8, 24, 73, 0.6);"><strong>Service</strong></td>
    <td style="padding: 14px 20px; font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 14px; color: #081849;">
      <span style="background-color: rgba(33, 56, 133, 0.08); color: #213885; padding: 4px 10px; border-radius: 8px; font-size: 13px; font-weight: 700; display: inline-block;"><%= @service_interest %></span>
    </td>
  </tr>
</table>

<div style="background-color: #FAF8F5; border-left: 4px solid #5F3475; border-radius: 12px; padding: 20px; border: 1px solid rgba(8, 24, 73, 0.05); border-left-width: 4px;">
  <strong style="display: block; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; color: #5F3475; margin-bottom: 8px; font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">Project Details</strong>
  <div style="font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 15px; color: #081849; line-height: 1.6; white-space: pre-wrap;"><%= @message %></div>
</div>
