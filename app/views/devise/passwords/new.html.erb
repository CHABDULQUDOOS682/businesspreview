<div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-900/5 sm:p-8">
  <div class="mb-6">
    <h1 class="text-2xl font-bold tracking-tight text-slate-900">Reset password</h1>
    <p class="mt-1 text-sm text-slate-600">Enter your email and we will send reset instructions.</p>
  </div>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-4" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :email, class: "block text-sm font-medium text-slate-900" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-1 block w-full rounded-lg border-0 px-3 py-2.5 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-blue-600" %>
    </div>

    <%= f.submit "Send reset instructions", class: "w-full rounded-md bg-blue-600 px-3 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-blue-500" %>
  <% end %>

  <%= render "devise/shared/links" %>
</div>

