<div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-900/5 sm:p-8">
  <div class="mb-6">
    <h1 class="text-2xl font-bold tracking-tight text-slate-900">Sign in</h1>
    <p class="mt-1 text-sm text-slate-600">Welcome back. Continue to your admin workspace.</p>
  </div>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>
    <div>
      <%= f.label :email, class: "block text-sm font-medium text-slate-900" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-1 block w-full rounded-lg border-0 px-3 py-2.5 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-blue-600" %>
    </div>

    <div>
      <%= f.label :password, class: "block text-sm font-medium text-slate-900" %>
      <%= f.password_field :password, autocomplete: "current-password", class: "mt-1 block w-full rounded-lg border-0 px-3 py-2.5 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-blue-600" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="flex items-center gap-2">
        <%= f.check_box :remember_me, class: "rounded border-slate-300 text-blue-600 focus:ring-blue-500" %>
        <%= f.label :remember_me, class: "text-sm text-slate-700" %>
      </div>
    <% end %>

    <%= f.submit "Sign in", class: "w-full rounded-md bg-blue-600 px-3 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-blue-500" %>
  <% end %>

  <%= render "devise/shared/links" %>
</div>

