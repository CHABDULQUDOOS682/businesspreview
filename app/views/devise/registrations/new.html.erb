<div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-900/5 sm:p-8">
  <div class="mb-6">
    <h1 class="text-2xl font-bold tracking-tight text-slate-900">Create account</h1>
    <p class="mt-1 text-sm text-slate-600">Set up your account to access the admin panel.</p>
  </div>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :email, class: "block text-sm font-medium text-slate-900" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-1 block w-full rounded-lg border-0 px-3 py-2.5 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-blue-600" %>
    </div>

    <div>
      <%= f.label :password, class: "block text-sm font-medium text-slate-900" %>
      <div class="relative mt-1" data-controller="password-visibility">
        <%= f.password_field :password, autocomplete: "new-password", class: "block w-full rounded-lg border-0 px-3 py-2.5 pr-16 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-blue-600", data: { password_visibility_target: "input" } %>
        <button type="button" class="absolute inset-y-0 right-0 inline-flex items-center px-3 text-sm font-medium text-slate-500 hover:text-slate-700" data-action="password-visibility#toggle">
          <span data-password-visibility-target="label">Show</span>
        </button>
      </div>
    </div>

    <div>
      <%= f.label :password_confirmation, class: "block text-sm font-medium text-slate-900" %>
      <div class="relative mt-1" data-controller="password-visibility">
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "block w-full rounded-lg border-0 px-3 py-2.5 pr-16 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-blue-600", data: { password_visibility_target: "input" } %>
        <button type="button" class="absolute inset-y-0 right-0 inline-flex items-center px-3 text-sm font-medium text-slate-500 hover:text-slate-700" data-action="password-visibility#toggle">
          <span data-password-visibility-target="label">Show</span>
        </button>
      </div>
    </div>

    <%= f.submit "Create account", class: "w-full rounded-md bg-blue-600 px-3 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-blue-500" %>
  <% end %>

  <%= render "devise/shared/links" %>
</div>
