      </p>

      <div class="mt-8 flex gap-4 flex-wrap justify-center lg:justify-start">
        <button class="bg-yellow-400 text-black px-6 py-3 rounded-lg font-semibold hover:bg-yellow-300 transition">
          Book Now
        </button>
        <button class="bg-gray-800 text-white px-6 py-3 rounded-lg font-semibold hover:bg-gray-700 transition">
          View Services
        </button>
      </div>
    </div>

  </div>
</section>







