

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Barbershop Hero</title>
 <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <script src="https://cdn.tailwindcss.com"></script>

</head>
<body class="font-[Montserrat]">


<section class="bg-blue-500">

  <!-- Header -->
  <header class="bg-[#12110DF2] text-white border border-gray-800 shadow-md">
    <div class="max-w-9xl mx-auto px-6 md:px-12 py-4 flex items-center justify-between ">

      <!-- Logo -->
      <div class="text-xl font-bold">
        MyLogo
      </div>

      <!-- Desktop Menu -->
      <nav class="hidden md:flex items-center gap-14">
        <a href="#" class="hover:text-gray-300">Home</a>
        <a href="#" class="hover:text-gray-300">About</a>
        <a href="#" class="hover:text-gray-300">Services</a>
        <a href="#" class="hover:text-gray-300">Contact</a>
      </nav>

      <!-- Button -->
      <div class="hidden md:block">
        <button class="bg-yellow-400 text-black px-4 py-2 rounded-lg hover:bg-gray-200 transition">
          Book Appointment
        </button>
      </div>

      <!-- Mobile Menu Button -->
      <button id="menuBtn" class="md:hidden text-2xl transition-all duration-300">
        <i id="menuIcon" class="fa-solid fa-bars"></i>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobileMenu" 
         class="max-h-0 overflow-hidden md:hidden px-4 transition-all duration-500 ease-in-out border-t border-gray-800">
      
      <nav class="flex flex-col gap-4 py-4">
        <a href="#" class="hover:text-gray-300">Home</a>
        <a href="#" class="hover:text-gray-300">About</a>
        <a href="#" class="hover:text-gray-300">Services</a>
        <a href="#" class="hover:text-gray-300">Contact</a>

        <button class="bg-white text-black px-4 py-2 rounded-lg hover:bg-gray-200 transition w-full">
          Book Appointment
        </button>
      </nav>
    </div>
  </header>

  <!-- Font Awesome CDN -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

  <script>
    const btn = document.getElementById("menuBtn");
    const menu = document.getElementById("mobileMenu");
    const icon = document.getElementById("menuIcon");

    let isOpen = false;

    btn.addEventListener("click", () => {
      isOpen = !isOpen;

      if (isOpen) {
        menu.style.maxHeight = menu.scrollHeight + "px";

        // Icon change + animation
        icon.classList.remove("fa-bars");
        icon.classList.add("fa-xmark");
        btn.classList.add("rotate-90", "scale-110");

      } else {
        menu.style.maxHeight = "0px";

        icon.classList.remove("fa-xmark");
        icon.classList.add("fa-bars");
        btn.classList.remove("rotate-90", "scale-110");
      }
    });
  </script>

</section>

  <!-- Hero Section -->
  <section class="min-h-screen flex items-center bg-black">
  <div class="max-w-7xl mx-auto px-6 md:px-12 py-12 grid lg:grid-cols-2 gap-10 items-center">

    <!-- Image (comes first on mobile) -->
