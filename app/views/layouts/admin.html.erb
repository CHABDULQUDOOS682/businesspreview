<!DOCTYPE html>
<html class="h-full bg-slate-50">
  <head>
    <title>Cold Outreach | Admin Panel</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <!-- Twilio Voice JS SDK v2 (via jsDelivr) -->
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/@twilio/voice-sdk@2.18.0/dist/twilio.min.js"></script>
  </head>

  <body class="h-full font-sans text-slate-900 antialiased">
    <div class="h-screen flex bg-slate-50 overflow-hidden">
      <!-- Sidebar -->
      <aside class="hidden md:flex md:w-64 md:flex-col border-r border-slate-200 bg-white overflow-y-auto">
        <div class="flex items-center gap-3 px-4 py-4 border-b border-slate-200">
          <%= link_to admin_root_path, class: "flex items-center gap-3 hover:opacity-90 transition-opacity" do %>
            <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <span class="font-bold text-lg tracking-tight text-slate-800">PaaS Engine</span>
          <% end %>
        </div>

        <nav class="flex-1 px-3 py-4 space-y-1 text-sm">
          <%= link_to admin_root_path,
                      class: "group flex items-center gap-2 rounded-md px-2.5 py-2 font-medium #{current_page?(admin_root_path) ? 'bg-slate-900 text-white' : 'text-slate-700 hover:bg-slate-100 hover:text-slate-900'}" do %>
            <span class="inline-flex h-6 w-6 items-center justify-center rounded-md bg-slate-900/5 text-slate-500 group-hover:text-slate-700">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 13h8V3H3v10Zm10 8h8V11h-8v10Z" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
            <span>Dashboard</span>
          <% end %>

          <%= link_to admin_businesses_path,
                      class: "group flex items-center gap-2 rounded-md px-2.5 py-2 font-medium #{current_page?(admin_businesses_path) || params[:controller] == 'admin/businesses' ? 'bg-slate-900 text-white' : 'text-slate-700 hover:bg-slate-100 hover:text-slate-900'}" do %>
            <span class="inline-flex h-6 w-6 items-center justify-center rounded-md bg-slate-900/5 text-slate-500 group-hover:text-slate-700">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 21V8l9-5 9 5v13" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
            <span>Businesses</span>
          <% end %>

          <%= link_to admin_communications_path,
                      class: "group flex items-center justify-between gap-2 rounded-md px-2.5 py-2 font-medium #{current_page?(admin_communications_path) || params[:controller] == 'admin/communications' ? 'bg-slate-900 text-white' : 'text-slate-700 hover:bg-slate-100 hover:text-slate-900'}" do %>
            <span class="flex items-center gap-2">
              <span class="inline-flex h-6 w-6 items-center justify-center rounded-md bg-slate-900/5 text-slate-500 group-hover:text-slate-700">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M4 5h16v10H5.17L4 16.17V5Z" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              <span>Communications</span>
            </span>
            <span id="unread_messages_badge" class="ml-2">
              <%= render partial: "admin/communications/unread_badge", locals: { count: unread_message_count } %>
            </span>
          <% end %>

          <%= link_to admin_tasks_path,
                      class: "group flex items-center gap-2 rounded-md px-2.5 py-2 font-medium #{current_page?(admin_tasks_path) || params[:controller] == 'admin/tasks' ? 'bg-slate-900 text-white' : 'text-slate-700 hover:bg-slate-100 hover:text-slate-900'}" do %>
            <span class="inline-flex h-6 w-6 items-center justify-center rounded-md bg-slate-900/5 text-slate-500 group-hover:text-slate-700">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 11l3 3L22 4M4 7h4m-4 4h4m-4 4h4" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
            <span>Tasks</span>
          <% end %>
        </nav>

        <div class="border-t border-slate-200 px-4 py-4 text-xs text-slate-500">
          <% if user_signed_in? %>
            <div class="mb-2 text-sm font-medium text-slate-700 truncate"><%= current_user.email %></div>
            <%= button_to "Sign out",
                          destroy_user_session_path,
                          method: :delete,
                          class: "w-full rounded-md bg-white px-2.5 py-1.5 text-xs font-semibold text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 hover:bg-slate-50" %>
          <% else %>
            <%= link_to "Sign in",
                        new_user_session_path,
                        class: "w-full inline-flex justify-center rounded-md bg-blue-600 px-3 py-2 text-xs font-semibold text-white shadow-sm hover:bg-blue-500" %>
          <% end %>
        </div>
      </aside>

      <!-- Mobile top bar (simple) -->
      <div class="md:hidden fixed inset-x-0 top-0 z-40 bg-white border-b border-slate-200">
        <div class="flex items-center justify-between px-4 py-3">
          <%= link_to admin_root_path, class: "flex items-center gap-2" do %>
            <div class="w-7 h-7 bg-blue-600 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <span class="font-semibold text-sm text-slate-800">PaaS Engine</span>
          <% end %>
        </div>
      </div>

      <%= turbo_stream_from "unread_messages" %>
      <!-- Main Content Area -->
      <main class="flex-1 flex flex-col overflow-y-auto">
        <div class="pt-[56px] md:pt-8 w-full max-w-7xl mx-auto py-6 px-4 sm:px-6 lg:px-8">
      <!-- Flash Messages -->
      <% if notice %>
        <div class="rounded-md bg-green-50 p-4 mb-6 shadow-sm border border-green-100">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
            </div>
            <div class="ml-3">
              <p class="text-sm font-medium text-green-800"><%= notice %></p>
            </div>
          </div>
        </div>
      <% end %>
      <% if alert %>
        <div class="rounded-md bg-red-50 p-4 mb-6 shadow-sm border border-red-100">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" /></svg>
            </div>
            <div class="ml-3">
              <p class="text-sm font-medium text-red-800"><%= alert %></p>
            </div>
          </div>
        </div>
      <% end %>

      <% if content_for?(:page_header) %>
        <div class="mb-6 rounded-2xl border border-slate-200 bg-white px-4 py-4 shadow-sm sm:px-6">
          <%= yield :page_header %>
        </div>
      <% end %>

      <%= yield %>
        </div>
      </main>
    </div>
  </body>
</html>
