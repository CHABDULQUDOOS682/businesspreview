<!DOCTYPE html>
<html class="h-full bg-background">
  <head>
    <title>Cold Outreach | Admin Panel</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,700&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/@twilio/voice-sdk@2.18.0/dist/twilio.min.js"></script>
  </head>

  <body class="h-full bg-background font-sans text-sand-900 antialiased">
    <%= turbo_stream_from "unread_messages" %>

    <div class="portal-shell" data-controller="mobile-nav" data-action="keydown.escape->mobile-nav#close turbo:before-cache->mobile-nav#close">
      <aside class="sidebar-container sidebar-container--collapsed" data-controller="side-bar">
        <div class="sidebar-logo-container">
          <%= link_to admin_root_path, class: "sidebar-logo-link" do %>
            <span class="sidebar-brand-mark !bg-transparent !border-0">
              <%= image_tag "veloqtech_logo.svg", class: "h-8 w-auto", alt: "BT" %>
            </span>
            <span class="sidebar-item-label text-base font-bold tracking-tight text-[#081849]">Bizzly<span class="text-[#5F3475]">Tech</span></span>
          <% end %>
        </div>

        <div class="sidebar-items-container">
          <%= render admin_sidebar_partial %>

          <div class="sidebar-account-card rounded-[20px] border border-sand-200 bg-sand-50/80 p-3 shadow-[0_8px_18px_rgba(26,25,24,0.03)]">
            <% if user_signed_in? %>
              <div class="sidebar-account-copy min-w-0">
                <p class="truncate text-sm font-semibold text-sand-900"><%= current_user.email %></p>
                <p class="mt-1 text-xs text-sand-500">Signed in as <%= current_role_label %></p>
              </div>

              <div class="sidebar-account-role mt-3">
                <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-semibold ring-1 ring-inset <%= admin_sidebar_role_badge_classes %>">
                  <%= current_role_label %>
                </span>
              </div>

              <div class="sidebar-account-actions mt-3">
                <%= button_to "Sign out",
                              destroy_user_session_path,
                              method: :delete,
                              class: "btn-base btn-sand w-full px-3 py-2 text-sm shadow-sm" %>
              </div>

              <%= button_to destroy_user_session_path,
                            method: :delete,
                            class: "sidebar-account-compact",
                            form_class: "inline-block" do %>
                <span class="sr-only">Sign out</span>
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6A2.25 2.25 0 005.25 5.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m-7.5-3h12m0 0-3-3m3 3-3 3" />
                </svg>
              <% end %>
            <% else %>
              <%= link_to "Sign in",
                          new_user_session_path,
                          class: "btn-base btn-accent-blue w-full px-3 py-2 text-sm shadow-sm" %>
            <% end %>
          </div>
        </div>
      </aside>

      <div class="flex min-h-screen flex-col md:pl-16">
        <header class="portal-topbar">
          <div class="md:hidden">
            <div class="flex items-center justify-between gap-3 px-4 py-3">
              <%= link_to admin_root_path, class: "flex items-center gap-3" do %>
                <span class="sidebar-brand-mark !bg-transparent !border-0 !h-auto !w-auto">
                  <%= image_tag "veloqtech_logo.svg", class: "h-7 w-auto", alt: "BT" %>
                </span>
                <span class="text-base font-bold tracking-tight text-[#081849]">Bizzly<span class="text-[#5F3475]">Tech</span></span>
              <% end %>

              <button
                type="button"
                class="inline-flex items-center justify-center rounded-[12px] border border-sand-200 bg-sand-50 p-2 text-sand-700 hover:bg-sand-100 hover:text-sand-900"
                data-mobile-nav-target="button"
                data-action="mobile-nav#toggle"
                aria-controls="admin-mobile-menu"
                aria-expanded="false">
                <span class="sr-only">Open admin menu</span>
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 7h16M4 12h16M4 17h16" />
                </svg>
              </button>
            </div>

            <div id="admin-mobile-menu" class="hidden border-t border-sand-200 bg-white shadow-xl" data-mobile-nav-target="panel">
              <%= render admin_sidebar_partial, mobile: true %>

              <div class="border-t border-sand-200 px-4 py-4 text-sm text-sand-600">
                <% if user_signed_in? %>
                  <div class="mb-2 truncate font-medium text-sand-900"><%= current_user.email %></div>
                  <div class="mb-3">
                    <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-semibold ring-1 ring-inset <%= admin_sidebar_role_badge_classes %>">
                      <%= current_role_label %>
                    </span>
                  </div>
                  <%= button_to "Sign out",
                                destroy_user_session_path,
                                method: :delete,
                                class: "btn-base btn-sand w-full px-3 py-2 text-sm shadow-sm" %>
                <% else %>
                  <%= link_to "Sign in",
                              new_user_session_path,
                              class: "btn-base btn-accent-blue w-full px-3 py-2 text-sm shadow-sm" %>
                <% end %>
              </div>
            </div>
          </div>

          <div class="<%= content_for?(:page_header) ? 'border-t border-sand-200 md:border-t-0' : '' %> px-4 py-4 md:px-6 md:py-5">
            <% if content_for?(:page_header) %>
              <%= yield :page_header %>
            <% else %>
              <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
                <div>
                  <p class="portal-kicker">Standard Portal</p>
                  <h1 class="portal-page-title mt-2"><%= controller_name.humanize %></h1>
                </div>

                <% if user_signed_in? %>
                  <div class="hidden items-center gap-3 md:flex">
                    <div class="rounded-full border border-sand-200 bg-sand-50 px-3 py-2 text-sm text-sand-700">
                      <span class="font-medium text-sand-900"><%= current_user.email %></span>
                    </div>
                    <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-semibold ring-1 ring-inset <%= admin_sidebar_role_badge_classes %>">
                      <%= current_role_label %>
                    </span>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </header>

        <main class="flex grow flex-col overflow-hidden">
          <div id="content" class="template--layout flex grow flex-col overflow-hidden">
            <%= render "shared/flash" %>

            <div class="portal-scroll-frame">
              <div class="portal-scroll-body template--layout">
                <%= yield %>
              </div>
            </div>
          </div>
        </main>
      </div>
    </div>
  </body>
</html>
