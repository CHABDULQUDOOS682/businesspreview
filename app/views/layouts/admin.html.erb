<!DOCTYPE html>
<html class="h-full bg-slate-50">
  <head>
    <title>Cold Outreach | Admin Panel</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "initial-scale": "1", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <!-- Twilio Voice JS SDK v2 (via jsDelivr) -->
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/@twilio/voice-sdk@2.18.0/dist/twilio.min.js"></script>
  </head>

  <body class="h-full flex flex-col font-sans text-slate-900 antialiased">
    <!-- Top Navigation -->
    <nav class="bg-white border-b border-slate-200 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex">
            <!-- Logo area -->
            <div class="flex-shrink-0 flex items-center">
              <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center mr-3">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
              </div>
              <span class="font-bold text-xl tracking-tight text-slate-800">PaaS Engine</span>
            </div>
            <!-- Navigation Links -->
            <div class="hidden sm:ml-10 sm:flex sm:space-x-8">
              <%= link_to "Dashboard", admin_root_path, class: "border-transparent text-slate-500 hover:border-blue-500 hover:text-slate-800 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium transition-colors #{current_page?(admin_root_path) ? 'border-blue-500 text-slate-900' : ''}" %>
              <%= link_to "Businesses", admin_businesses_path, class: "border-transparent text-slate-500 hover:border-blue-500 hover:text-slate-800 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium transition-colors #{current_page?(admin_businesses_path) || params[:controller] == 'admin/businesses' ? 'border-blue-500 text-slate-900' : ''}" %>
              <%= link_to admin_communications_path, class: "border-transparent text-slate-500 hover:border-blue-500 hover:text-slate-800 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium transition-colors #{current_page?(admin_communications_path) || params[:controller] == 'admin/communications' ? 'border-blue-500 text-slate-900' : ''}" do %>
                Communications
                <span id="unread_messages_badge">
                  <%= render partial: "admin/communications/unread_badge", locals: { count: unread_message_count } %>
                </span>
              <% end %>
            </div>
          </div>
          <!-- Right side user profile placeholder -->
          <div class="hidden sm:ml-6 sm:flex sm:items-center">
            <% if user_signed_in? %>
              <span class="mr-3 text-sm text-slate-600"><%= current_user.email %></span>
              <%= button_to "Sign out",
                            destroy_user_session_path,
                            method: :delete,
                            class: "rounded-md bg-white px-2.5 py-1.5 text-sm font-semibold text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 hover:bg-slate-50" %>
            <% else %>
              <%= link_to "Sign in",
                          new_user_session_path,
                          class: "rounded-md bg-blue-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-500" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <%= turbo_stream_from "unread_messages" %>
    <!-- Main Content Area -->
    <main class="flex-1 w-full max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
      <!-- Flash Messages -->
      <% if notice %>
        <div class="rounded-md bg-green-50 p-4 mb-6 shadow-sm border border-green-100">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
            </div>
            <div class="ml-3">
              <p class="text-sm font-medium text-green-800"><%= notice %></p>
            </div>
          </div>
        </div>
      <% end %>
      <% if alert %>
        <div class="rounded-md bg-red-50 p-4 mb-6 shadow-sm border border-red-100">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" /></svg>
            </div>
            <div class="ml-3">
              <p class="text-sm font-medium text-red-800"><%= alert %></p>
            </div>
          </div>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
