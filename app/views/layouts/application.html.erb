<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Preview App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :tailwind, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-50">
    <nav
      class="bg-white border-b border-slate-200 fixed top-0 w-full z-50"
      data-controller="mobile-nav"
      data-action="keydown.escape->mobile-nav#close turbo:before-cache->mobile-nav#close"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex">
            <div class="flex-shrink-0 flex items-center">
              <%= link_to root_path, class: "text-xl font-bold text-blue-600" do %>
                PreviewApp
              <% end %>
            </div>
            <div class="hidden sm:-my-px sm:ml-10 sm:flex sm:space-x-8">
              <%= link_to "Dashboard", admin_dashboard_index_path, class: "inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium #{controller_name == 'dashboard' ? 'border-blue-500 text-slate-900' : 'border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300'}" %>
              <%= link_to "Businesses", admin_businesses_path, class: "inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium #{controller_name == 'businesses' ? 'border-blue-500 text-slate-900' : 'border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300'}" %>
              <%= link_to "Communications", admin_communications_path, class: "inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium #{controller_name == 'communications' ? 'border-blue-500 text-slate-900' : 'border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300'}" %>
            </div>
          </div>

          <!-- Mobile menu button -->
          <div class="flex items-center sm:hidden">
            <button
              type="button"
              class="inline-flex items-center justify-center rounded-md p-2 text-slate-600 hover:bg-slate-50 hover:text-slate-900 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-blue-600"
              aria-controls="app-mobile-menu"
              aria-expanded="false"
              data-mobile-nav-target="button"
              data-action="mobile-nav#toggle"
            >
              <span class="sr-only">Open main menu</span>
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
          </div>
        </div>

        <!-- Mobile menu panel -->
        <div id="app-mobile-menu" class="hidden sm:hidden border-t border-slate-200 pb-3 pt-2" data-mobile-nav-target="panel">
          <div class="space-y-1 px-2">
            <%= link_to "Dashboard", admin_dashboard_index_path, class: "block rounded-md px-3 py-2 text-base font-medium #{controller_name == 'dashboard' ? 'bg-blue-50 text-blue-700' : 'text-slate-700 hover:bg-slate-50 hover:text-slate-900'}" %>
            <%= link_to "Businesses", admin_businesses_path, class: "block rounded-md px-3 py-2 text-base font-medium #{controller_name == 'businesses' ? 'bg-blue-50 text-blue-700' : 'text-slate-700 hover:bg-slate-50 hover:text-slate-900'}" %>
            <%= link_to "Communications", admin_communications_path, class: "block rounded-md px-3 py-2 text-base font-medium #{controller_name == 'communications' ? 'bg-blue-50 text-blue-700' : 'text-slate-700 hover:bg-slate-50 hover:text-slate-900'}" %>
          </div>
        </div>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto mt-20 px-4 sm:px-6 lg:px-8">
      <%= yield %>
    </main>
  </body>
</html>
