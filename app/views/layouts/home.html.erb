<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || app_name %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= seo_meta_tags %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "app", "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <%= javascript_importmap_tags %>
  </head>

  <body class="home-site min-h-screen antialiased selection:bg-[#5F3475] selection:text-[#ECDFD2]">
    <div class="home-shell flex min-h-screen flex-col">
      <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
        <div class="absolute -left-24 top-16 h-[22rem] w-[22rem] rounded-full bg-[#213885]/12 blur-[110px]"></div>
        <div class="absolute right-[-6rem] top-[-4rem] h-[24rem] w-[24rem] rounded-full bg-[#893172]/10 blur-[130px]"></div>
        <div class="absolute bottom-0 left-1/3 h-[18rem] w-[18rem] rounded-full bg-white/30 blur-[120px]"></div>
        <div class="home-grid-bg absolute inset-0 opacity-[0.16]"></div>
      </div>

      <header class="fixed inset-x-0 top-0 z-50 px-3 py-3 sm:px-4 sm:py-4" data-controller="mobile-nav" data-action="turbo:before-cache->mobile-nav#close">
        <nav class="home-glass mx-auto flex min-h-14 max-w-7xl items-center justify-between gap-3 rounded-2xl px-3 py-2.5 sm:rounded-[26px] sm:px-5 sm:py-3">
          <%= link_to root_path, class: "flex min-w-0 items-center gap-2 group z-20 sm:gap-3" do %>
            <%= image_tag "veloqtech_logo.svg", class: "h-8 w-auto shrink-0 transition group-hover:scale-105 sm:h-9", alt: "" %>
            <span class="brand-wordmark min-w-0 truncate text-base font-extrabold tracking-tight text-[#081849] sm:text-lg">DevDe<span class="brand-wordmark-accent">Bizz</span></span>
          <% end %>

          <button 
            type="button"
            class="relative z-30 inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-[#081849]/15 bg-white/55 text-[#081849] shadow-sm lg:hidden" 
            data-action="click->mobile-nav#toggle"
            data-mobile-nav-target="button"
            aria-controls="marketing-mobile-menu"
            aria-expanded="false"
          >
            <i class="fa-solid fa-bars text-xl"></i>
          </button>

          <div class="hidden min-w-0 items-center gap-1 lg:flex">
            <% marketing_navigation_links.each do |label, path| %>
              <%= link_to label, path, class: marketing_nav_link_classes(path) %>
            <% end %>
            <%= link_to "Contact", contact_path, class: "ml-2 whitespace-nowrap rounded-full bg-[#213885] px-4 py-2.5 text-sm font-bold text-[#ECDFD2] shadow-lg shadow-[#213885]/25 transition hover:-translate-y-0.5 hover:shadow-[#213885]/35 lg:ml-3 lg:px-5" %>
          </div>
        </nav>
        
        <div
          id="marketing-mobile-menu"
          class="home-glass mx-auto mt-2 hidden max-h-[calc(100vh-5.75rem)] max-w-7xl overflow-y-auto rounded-2xl border border-[#081849]/10 p-3 shadow-2xl shadow-[#081849]/10 lg:hidden"
          data-mobile-nav-target="panel"
        >
          <div class="flex flex-col gap-2">
            <% marketing_navigation_links.each do |label, path| %>
              <%= link_to label, path, class: "#{marketing_nav_link_classes(path)} block w-full px-4 py-3 text-base" %>
            <% end %>
            <%= link_to "Contact", contact_path, class: "mt-2 block rounded-full bg-[#213885] px-5 py-3 text-center text-base font-bold text-[#ECDFD2]" %>
          </div>
        </div>
      </header>

      <main class="mx-auto w-full max-w-7xl px-4 pb-20 pt-28 md:px-6 md:pt-32">
        <%= render "shared/flash" %>

        <%= yield %>
      </main>

      <footer class="relative mt-20 border-t border-[#081849]/10 bg-[#CCCACC] pb-8 pt-20">
        <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[#5F3475]/40 to-transparent"></div>
        <div class="mx-auto max-w-7xl px-6">
          <div class="grid gap-12 lg:grid-cols-6">
            <div class="lg:col-span-2">
              <div class="flex items-center gap-3">
                <%= image_tag "veloqtech_logo.svg", class: "h-10 w-auto", alt: "" %>
                <span class="brand-wordmark text-xl font-extrabold tracking-tight text-[#081849]">DevDe<span class="brand-wordmark-accent">Bizz</span></span>
              </div>
              <p class="mt-5 max-w-sm text-sm leading-relaxed text-[#081849]/60">
                DevDeBizz helps service businesses turn their website, follow-up, and client journey into a clear path from interest to booked work.
              </p>
              <div class="mt-6 flex gap-3">
                <a href="#" aria-label="Twitter" class="home-footer-social">
                  <i class="fa-brands fa-x-twitter"></i>
                </a>
                <a href="#" aria-label="LinkedIn" class="home-footer-social">
                  <i class="fa-brands fa-linkedin-in"></i>
                </a>
                <a href="#" aria-label="Instagram" class="home-footer-social">
                  <i class="fa-brands fa-instagram"></i>
                </a>
                <a href="#" aria-label="GitHub" class="home-footer-social">
                  <i class="fa-brands fa-github"></i>
                </a>
              </div>
            </div>

            <% marketing_footer_columns.each do |column| %>
              <div>
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-[#081849]"><%= column[:title] %></p>
                <ul class="mt-5 space-y-3">
                  <% column[:links].each do |label, path| %>
                    <li>
                      <%= link_to label, path, class: "text-sm text-[#081849]/60 transition hover:text-[#5F3475]" %>
                    </li>
                  <% end %>
                </ul>
              </div>
            <% end %>
          </div>

          <div class="mt-14 flex flex-col items-start justify-between gap-4 border-t border-[#081849]/10 pt-8 md:flex-row md:items-center">
            <p class="text-xs text-[#081849]/50">© <%= Time.current.year %> DevDeBizz. All rights reserved.</p>
            <div class="flex flex-wrap gap-5 text-xs text-[#081849]/50">
              <%= link_to "Privacy", privacy_path, class: "hover:text-[#5F3475]" %>
              <%= link_to "Terms", contact_path, class: "hover:text-[#5F3475]" %>
              <%= link_to "Cookies", contact_path, class: "hover:text-[#5F3475]" %>
              <%= link_to "Accessibility", contact_path, class: "hover:text-[#5F3475]" %>
            </div>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
