<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "PreviewApp" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="PreviewApp SaaS agency style public pages">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-slate-100 text-slate-950 selection:bg-sky-200 selection:text-sky-900 [&_p]:hover:text-slate-800 [&_p]:transition-colors [&_h1]:cursor-default [&_h2]:cursor-default [&_h3]:cursor-default">
    <div class="relative overflow-hidden min-h-screen flex flex-col">
      <!-- Premium Grid & Mesh Gradient Background (Darker Base) -->
      <div class="absolute inset-0 -z-10 h-full w-full bg-[linear-gradient(to_right,#80808015_1px,transparent_1px),linear-gradient(to_bottom,#80808015_1px,transparent_1px)] bg-[size:24px_24px]">
        <div class="absolute left-0 right-0 top-0 -z-10 m-auto h-[400px] w-[600px] rounded-full bg-sky-400 opacity-20 blur-[120px]"></div>
        <div class="absolute -left-40 top-20 -z-10 h-[300px] w-[500px] rounded-full bg-indigo-500 opacity-10 blur-[100px]"></div>
        <div class="absolute -right-40 top-40 -z-10 h-[300px] w-[500px] rounded-full bg-blue-500 opacity-10 blur-[100px]"></div>
      </div>
      <header class="mx-auto flex w-full max-w-7xl items-center justify-between px-6 py-6 lg:px-10">
        <%= link_to root_path, class: "flex items-center gap-3" do %>
          <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-slate-950 text-sm font-black tracking-[0.35em] text-white">SA</span>
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-600">LaunchReady</p>
            <p class="text-xs text-slate-500">SaaS agency websites built to convert</p>
          </div>
        <% end %>

        <nav class="hidden items-center gap-2 rounded-full border border-white/60 bg-white/60 p-2 shadow-lg shadow-slate-200/70 backdrop-blur md:flex">
          <%= nav_link_to "Home", root_path %>
          <%= nav_link_to "Services", services_path %>
          <%= nav_link_to "Process", process_path %>
          <%= nav_link_to "Contact", contact_path %>
        </nav>
      </header>

      <% flash.each do |type, message| %>
        <% tone = type.to_s == "notice" ? "border-emerald-200 bg-emerald-50 text-emerald-900" : "border-rose-200 bg-rose-50 text-rose-900" %>
        <div class="mx-auto mb-4 w-full max-w-5xl px-6 lg:px-10">
          <div class="rounded-2xl border px-4 py-3 text-sm font-medium <%= tone %>"><%= message %></div>
        </div>
      <% end %>

      <main class="mx-auto w-full max-w-7xl px-6 pb-16 lg:px-10">
        <%= yield %>
      </main>

      <footer class="border-t border-white/70 bg-white/60 backdrop-blur">
        <div class="mx-auto flex w-full max-w-7xl flex-col gap-6 px-6 py-8 text-sm text-slate-600 lg:flex-row lg:items-center lg:justify-between lg:px-10">
          <div>
            <p class="font-semibold text-slate-900">LaunchReady designs honest, conversion-focused websites for SaaS teams.</p>
            <p class="mt-1 max-w-2xl">We avoid misleading claims, keep calls to action clear, and structure content to support accessibility, transparency, and search-friendly best practices.</p>
          </div>
          <div class="flex flex-wrap items-center gap-4">
            <%= link_to "Privacy", privacy_path, class: "transition hover:text-slate-950" %>
            <a href="mailto:hello@previewapp.example" class="transition hover:text-slate-950">hello@previewapp.example</a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
