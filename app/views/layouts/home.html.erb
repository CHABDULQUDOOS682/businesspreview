<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "BizzlyTech" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="BizzlyTech builds conversion-focused websites and business systems for ambitious local businesses.">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "app", "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <%= javascript_importmap_tags %>
  </head>

  <body class="home-site min-h-screen antialiased selection:bg-[#5F3475] selection:text-[#ECDFD2]">
    <div class="home-shell flex min-h-screen flex-col">
      <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
        <div class="absolute -left-24 top-16 h-[22rem] w-[22rem] rounded-full bg-[#213885]/12 blur-[110px]"></div>
        <div class="absolute right-[-6rem] top-[-4rem] h-[24rem] w-[24rem] rounded-full bg-[#893172]/10 blur-[130px]"></div>
        <div class="absolute bottom-0 left-1/3 h-[18rem] w-[18rem] rounded-full bg-white/30 blur-[120px]"></div>
        <div class="home-grid-bg absolute inset-0 opacity-[0.16]"></div>
      </div>

      <header class="fixed inset-x-0 top-0 z-50 px-4 py-4" data-controller="mobile-nav" data-action="turbo:before-cache->mobile-nav#close">
        <nav class="home-glass mx-auto flex max-w-7xl items-center justify-between rounded-[26px] px-5 py-3">
          <%= link_to root_path, class: "flex items-center gap-3 group z-20" do %>
            <%= image_tag "veloqtech_logo.svg", class: "h-9 w-auto transition group-hover:scale-105", alt: "BizzlyTech" %>
            <span class="text-lg font-extrabold tracking-tight text-[#081849]">Bizzly<span class="bg-gradient-to-r from-[#5F3475] to-[#893172] bg-clip-text text-transparent">Tech</span></span>
          <% end %>

          <button 
            class="rounded-xl border border-[#081849]/10 p-2 text-[#081849] md:hidden" 
            data-action="click->mobile-nav#toggle"
            data-mobile-nav-target="button"
            aria-controls="marketing-mobile-menu"
            aria-expanded="false"
          >
            <i class="fa-solid fa-bars text-xl"></i>
          </button>

          <div class="hidden items-center gap-1 md:flex">
            <% marketing_navigation_links.each do |label, path| %>
              <%= link_to label, path, class: marketing_nav_link_classes(path) %>
            <% end %>
            <%= link_to "Contact", contact_path, class: "ml-3 rounded-full bg-[#213885] px-5 py-2.5 text-sm font-bold text-[#ECDFD2] shadow-lg shadow-[#213885]/25 transition hover:-translate-y-0.5 hover:shadow-[#213885]/35" %>
          </div>
        </nav>
        
        <div
          id="marketing-mobile-menu"
          class="home-glass mx-auto mt-2 hidden max-w-7xl rounded-[26px] border border-[#081849]/10 p-4 md:hidden"
          data-mobile-nav-target="panel"
        >
          <div class="flex flex-col gap-2">
            <% marketing_navigation_links.each do |label, path| %>
              <%= link_to label, path, class: "#{marketing_nav_link_classes(path)} block px-4 py-3" %>
            <% end %>
            <%= link_to "Contact", contact_path, class: "mt-2 rounded-full bg-[#213885] px-5 py-3 text-center text-sm font-bold text-[#ECDFD2]" %>
          </div>
        </div>
      </header>

      <main class="mx-auto w-full max-w-7xl px-4 pb-20 pt-28 md:px-6 md:pt-32">
        <%= render "shared/flash" %>

        <%= yield %>
      </main>

      <footer class="relative mt-20 border-t border-[#081849]/10 bg-[#CCCACC] pb-8 pt-20">
        <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[#5F3475]/40 to-transparent"></div>
        <div class="mx-auto max-w-7xl px-6">
          <div class="grid gap-12 lg:grid-cols-6">
            <div class="lg:col-span-2">
              <div class="flex items-center gap-3">
                <%= image_tag "veloqtech_logo.svg", class: "h-10 w-auto", alt: "BizzlyTech" %>
                <span class="text-xl font-extrabold tracking-tight text-[#081849]">Bizzly<span class="bg-gradient-to-r from-[#5F3475] to-[#893172] bg-clip-text text-transparent">Tech</span></span>
              </div>
              <p class="mt-5 max-w-sm text-sm leading-relaxed text-[#081849]/60">
                BizzlyTech is an independent digital agency crafting websites, brands, and growth systems for ambitious companies worldwide.
              </p>
              <div class="mt-6 flex gap-3">
                <a href="#" aria-label="Twitter" class="home-footer-social">
                  <i class="fa-brands fa-x-twitter"></i>
                </a>
                <a href="#" aria-label="LinkedIn" class="home-footer-social">
                  <i class="fa-brands fa-linkedin-in"></i>
                </a>
                <a href="#" aria-label="Instagram" class="home-footer-social">
                  <i class="fa-brands fa-instagram"></i>
                </a>
                <a href="#" aria-label="GitHub" class="home-footer-social">
                  <i class="fa-brands fa-github"></i>
                </a>
              </div>
            </div>

            <% marketing_footer_columns.each do |column| %>
              <div>
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-[#081849]"><%= column[:title] %></p>
                <ul class="mt-5 space-y-3">
                  <% column[:links].each do |label, path| %>
                    <li>
                      <%= link_to label, path, class: "text-sm text-[#081849]/60 transition hover:text-[#5F3475]" %>
                    </li>
                  <% end %>
                </ul>
              </div>
            <% end %>
          </div>

          <div class="mt-14 flex flex-col items-start justify-between gap-4 border-t border-[#081849]/10 pt-8 md:flex-row md:items-center">
            <p class="text-xs text-[#081849]/50">© <%= Time.current.year %> BizzlyTech, Inc. All rights reserved.</p>
            <div class="flex flex-wrap gap-5 text-xs text-[#081849]/50">
              <%= link_to "Privacy", privacy_path, class: "hover:text-[#5F3475]" %>
              <%= link_to "Terms", contact_path, class: "hover:text-[#5F3475]" %>
              <%= link_to "Cookies", contact_path, class: "hover:text-[#5F3475]" %>
              <%= link_to "Accessibility", contact_path, class: "hover:text-[#5F3475]" %>
            </div>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
