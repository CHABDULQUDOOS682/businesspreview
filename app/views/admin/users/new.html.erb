<div class="mx-auto max-w-2xl">
  <div class="mb-8">
    <div class="flex items-center gap-3">
      <%= link_to admin_users_path, class: "text-slate-400 hover:text-slate-500 transition-colors" do %>
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
      <% end %>
      <h1 class="text-2xl font-bold tracking-tight text-slate-900">Invite User</h1>
    </div>
    <p class="ml-9 mt-2 text-sm text-slate-600">
      <%= current_user.role_super_admin? ? "Invite a new admin or employee and let them set their own password." : "Invite a new employee and let them set their own password." %>
    </p>
  </div>

  <div class="overflow-hidden rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-900/5 sm:p-8">
    <%= render "form" %>
  </div>
</div>
