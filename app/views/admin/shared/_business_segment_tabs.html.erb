<div class="border-b border-slate-200">
  <nav class="-mb-px flex flex-wrap gap-2 sm:gap-6" aria-label="Business segments">
    <% tabs.each do |tab| %>
      <% active = current_segment == tab[:key] %>
      <%= link_to tab[:path],
                  class: [
                    "inline-flex items-center gap-2 border-b-2 px-1 py-3 text-sm font-semibold transition-colors",
                    active ? "border-blue-600 text-blue-600" : "border-transparent text-slate-500 hover:border-slate-300 hover:text-slate-700"
                  ].join(" ") do %>
        <span><%= tab[:label] %></span>
        <span class="<%= active ? 'bg-blue-50 text-blue-700 ring-blue-200' : 'bg-slate-100 text-slate-600 ring-slate-200' %> inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium ring-1 ring-inset">
          <%= tab[:count] %>
        </span>
      <% end %>
    <% end %>
  </nav>
</div>

