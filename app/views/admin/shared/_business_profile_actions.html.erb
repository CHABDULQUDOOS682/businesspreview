<%
  action_button_class = "inline-flex h-9 shrink-0 items-center justify-center gap-1.5 rounded-md px-3 text-sm font-semibold shadow-sm whitespace-nowrap"
%>
<div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
  <h3 class="text-base font-semibold leading-6 text-slate-900">Profile</h3>
  <div class="flex flex-wrap items-center gap-2 sm:justify-end">
    <%= render "admin/shared/business_chat_button",
               business: business,
               button_class: "#{action_button_class} bg-green-600 text-white hover:bg-green-500" %>
    <%= link_to "Edit",
                edit_admin_business_path(business),
                class: "#{action_button_class} bg-blue-600 text-white hover:bg-blue-500" %>
    <button type="button"
            class="<%= action_button_class %> bg-white text-slate-900 ring-1 ring-inset ring-slate-300 hover:bg-slate-50"
            onclick="document.getElementById('review-link-modal-<%= business.id %>').classList.remove('hidden')">
      Request Review
    </button>
  </div>
</div>
<%= render "admin/shared/review_link_modal", business: business %>
