<% if business.phone.present? %>
  <% unread = business.messages.inbound.unread.count %>
  <% variant = local_assigns.fetch(:variant, :button) %>
  <% default_button_class = "relative inline-flex h-9 shrink-0 items-center justify-center gap-1.5 rounded-md bg-green-600 px-3 text-sm font-semibold text-white shadow-sm hover:bg-green-500 whitespace-nowrap" %>
  <% default_link_class = "relative inline-flex items-center gap-1.5 text-green-700 hover:text-green-600" %>
  <% button_class = local_assigns.fetch(:button_class, variant == :link ? default_link_class : default_button_class) %>
  <% unread_target = dom_id(business, :chat_unread) %>

  <%= link_to admin_communication_path(business.phone),
        id: dom_id(business, :chat_button),
        class: button_class,
        data: { unread_count: unread } do %>
    <% if variant != :link %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-4 w-4 shrink-0" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3h9m-9 3h9m-6.75-12.75H18a2.25 2.25 0 0 1 2.25 2.25v9a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 15.75v-9a2.25 2.25 0 0 1 2.25-2.25h1.5m.75-3l3 3m0 0l3-3m-3 3v7.5" />
      </svg>
    <% end %>
    Chat
    <span id="<%= unread_target %>">
      <%= render "admin/shared/business_chat_unread", unread: unread %>
    </span>
  <% end %>
<% end %>
