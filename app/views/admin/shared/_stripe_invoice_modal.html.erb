<div id="stripe-invoice-modal-<%= business.id %>" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
  <div class="flex min-h-full items-center justify-center p-4 text-center sm:p-0">
    <div class="fixed inset-0 bg-slate-500/75 transition-opacity" aria-hidden="true" onclick="document.getElementById('stripe-invoice-modal-<%= business.id %>').classList.add('hidden')"></div>

    <div class="relative transform overflow-hidden rounded-2xl bg-white px-4 pb-4 pt-5 text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-lg sm:p-6">
      <div>
        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-indigo-100">
          <svg class="h-6 w-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75m0 1.5v.75m0 1.5v.75m0 1.5V15h1.5V4.5H3.75zm15 0v.75m0 1.5v.75m0 1.5v.75m0 1.5V15h1.5V4.5h-1.5zm-15 0h16.5c.828 0 1.5.672 1.5 1.5v9.75c0 .828-.672 1.5-1.5 1.5H3.75a1.5 1.5 0 01-1.5-1.5V6c0-.828.672-1.5 1.5-1.5zm10.5 3h.008v.008h-.008V7.5zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z" />
          </svg>
        </div>
        <div class="mt-3 text-center sm:mt-5">
          <h3 class="text-lg font-semibold leading-6 text-slate-900" id="modal-title">Create & Send Stripe Invoice</h3>
          <div class="mt-2">
            <p class="text-sm text-slate-500">Choose the delivery method for the invoice to <strong><%= business.name %></strong>.</p>
            <div class="mt-4 bg-slate-50 rounded-lg p-3 inline-block">
              <span class="text-xs font-medium text-slate-500 uppercase tracking-wider">Amount:</span>
              <span class="ml-2 text-sm font-bold text-slate-900"><%= number_to_currency(payment_invoice.amount) %></span>
              <span class="ml-2 px-2 py-0.5 bg-indigo-100 text-indigo-700 rounded text-[10px] font-bold uppercase"><%= payment_invoice.kind_label %></span>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-3">
        <%= button_to admin_business_payment_invoices_path(business, payment_invoice: { delivery_method: 'email' }), method: :post, class: "flex flex-col items-center justify-center rounded-xl border border-slate-200 p-4 hover:bg-slate-50 transition-colors group" do %>
          <i class="fa-solid fa-envelope text-2xl text-blue-600 mb-2 group-hover:scale-110 transition-transform"></i>
          <span class="text-sm font-bold text-slate-900">Email</span>
          <span class="text-[10px] text-slate-500 mt-1 truncate w-full text-center"><%= business.email.presence || "No email" %></span>
        <% end %>

        <%= button_to admin_business_payment_invoices_path(business, payment_invoice: { delivery_method: 'sms' }), method: :post, class: "flex flex-col items-center justify-center rounded-xl border border-slate-200 p-4 hover:bg-slate-50 transition-colors group" do %>
          <i class="fa-solid fa-comment-sms text-2xl text-green-600 mb-2 group-hover:scale-110 transition-transform"></i>
          <span class="text-sm font-bold text-slate-900">SMS</span>
          <span class="text-[10px] text-slate-500 mt-1 truncate w-full text-center"><%= business.phone.presence || "No phone" %></span>
        <% end %>

        <%= button_to admin_business_payment_invoices_path(business, payment_invoice: { delivery_method: 'email_and_sms' }), method: :post, class: "flex flex-col items-center justify-center rounded-xl border border-slate-200 p-4 hover:bg-slate-50 transition-colors group" do %>
          <div class="flex gap-x-1 mb-2">
            <i class="fa-solid fa-envelope text-lg text-blue-600"></i>
            <i class="fa-solid fa-comment-sms text-lg text-green-600"></i>
          </div>
          <span class="text-sm font-bold text-slate-900">Both</span>
          <span class="text-[10px] text-slate-500 mt-1">Email & SMS</span>
        <% end %>
      </div>

      <div class="mt-8">
        <button type="button" class="inline-flex w-full justify-center rounded-full bg-slate-100 px-3 py-2 text-sm font-semibold text-slate-900 shadow-sm hover:bg-slate-200 transition-colors" onclick="document.getElementById('stripe-invoice-modal-<%= business.id %>').classList.add('hidden')">
          Cancel
        </button>
      </div>
    </div>
  </div>
</div>
