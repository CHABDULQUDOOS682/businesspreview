<div id="global-call-widget"
     data-turbo-permanent
     data-controller="global-call"
     class="pointer-events-none fixed bottom-4 right-4 z-[100] flex flex-col items-end gap-2">

  <%# Minimized pill — visible during active call when collapsed %>
  <div data-global-call-target="minimized"
       class="pointer-events-auto hidden">
    <button type="button"
            data-action="click->global-call#expand"
            class="flex items-center gap-2 rounded-full border border-green-200 bg-white px-3 py-2 shadow-lg ring-1 ring-black/5">
      <span data-global-call-target="pulse" class="relative flex h-2.5 w-2.5">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"></span>
        <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-green-500"></span>
      </span>
      <span class="max-w-[10rem] truncate text-sm font-semibold text-slate-900" data-global-call-target="label">On call</span>
      <span class="text-xs text-slate-500">Expand</span>
    </button>
  </div>

  <%# Expanded call panel %>
  <div data-global-call-target="panel"
       class="pointer-events-auto hidden w-[min(100vw-2rem,22rem)] overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-2xl ring-1 ring-black/5">
    <div class="flex items-start justify-between gap-3 border-b border-slate-100 bg-slate-50 px-4 py-3">
      <div class="min-w-0">
        <p class="truncate text-sm font-semibold text-slate-900" data-global-call-target="label">Phone call</p>
        <p class="truncate text-xs text-slate-500" data-global-call-target="number"></p>
        <p data-global-call-target="status" class="mt-1 text-xs font-medium text-slate-500">Ready</p>
      </div>
      <button type="button"
              data-action="click->global-call#minimize"
              class="rounded-md p-1 text-slate-400 hover:bg-white hover:text-slate-600"
              aria-label="Minimize call bar">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
    </div>

    <div class="flex items-center justify-end gap-2 px-4 py-3">
      <button type="button"
              data-global-call-target="dismissButton"
              data-action="click->global-call#dismiss"
              class="hidden inline-flex items-center rounded-lg bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-200">
        Close
      </button>
      <button type="button"
              data-global-call-target="hangupButton"
              data-action="click->global-call#hangup"
              class="hidden inline-flex items-center gap-2 rounded-lg bg-red-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-500">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
        Hang up
      </button>
    </div>
  </div>
</div>
