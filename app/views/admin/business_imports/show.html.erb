<% content_for :page_header do %>
  <div class="sm:flex sm:items-start sm:justify-between">
    <div class="sm:flex-auto">
      <h1 class="text-2xl font-semibold leading-6 text-slate-900">Import Report</h1>
      <p class="mt-1 text-sm text-slate-600">
        <%= @business_import.filename.presence || "CSV import" %>:
        <%= @business_import.created_count %> created,
        <%= @business_import.duplicate_count %> duplicates,
        <%= @business_import.failed_count %> failed.
      </p>
    </div>
    <div class="mt-3 flex gap-3 sm:mt-0 sm:flex-none">
      <%= link_to "Back to history", admin_business_imports_path, class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 hover:bg-slate-50" %>
      <%= link_to "Download CSV", download_admin_business_import_path(@business_import, format: :csv), class: "rounded-md bg-blue-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-500" %>
    </div>
  </div>
<% end %>

<div class="mt-8 flow-root">
  <div class="-mx-4 -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
    <div class="inline-block min-w-full py-2 align-middle sm:px-6 lg:px-8">
      <div class="overflow-hidden shadow ring-1 ring-black ring-opacity-5 sm:rounded-lg">
        <table class="min-w-full divide-y divide-slate-300">
          <thead class="bg-slate-50">
            <tr>
              <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-slate-900 sm:pl-6">Row #</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Name</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Phone</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Status</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Reason</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200 bg-white">
            <% @rows.each do |row| %>
              <% badge_classes = case row.status
                when "created" then "bg-emerald-50 text-emerald-700 ring-emerald-600/20"
                when "duplicate" then "bg-amber-50 text-amber-700 ring-amber-600/20"
                else "bg-red-50 text-red-700 ring-red-600/20"
              end %>
              <tr class="hover:bg-slate-50">
                <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-slate-900 sm:pl-6"><%= row.row_number %></td>
                <td class="px-3 py-4 text-sm text-slate-500"><%= row.business_name.presence || "-" %></td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-500"><%= row.phone.presence || "-" %></td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-500">
                  <span class="inline-flex items-center rounded-md px-2 py-1 text-xs font-medium ring-1 ring-inset <%= badge_classes %>">
                    <%= row.status.humanize %>
                  </span>
                </td>
                <td class="px-3 py-4 text-sm text-slate-500"><%= row.reason.presence || "-" %></td>
              </tr>
            <% end %>
            <% if @rows.empty? %>
              <tr>
                <td colspan="5" class="px-3 py-8 text-center text-sm text-slate-500">This import has no row details.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <% if @pagy.pages > 1 %>
        <div class="mt-4 flex justify-end">
          <%== pagy_nav(@pagy) %>
        </div>
      <% end %>
    </div>
  </div>
</div>
