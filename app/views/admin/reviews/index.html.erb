<% content_for :page_header do %>
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="portal-kicker">Social proof</p>
      <h1 class="portal-page-title mt-2">Reviews</h1>
      <p class="mt-2 text-sm text-sand-600">
        Manage customer testimonials and reviews shown on the website.
      </p>
    </div>

    <%= link_to "Add review", new_admin_review_path, class: "btn-base btn-accent-blue px-4 py-3 text-sm shadow-sm" %>
  </div>
<% end %>

<div class="overflow-hidden rounded-[24px] border border-sand-200 bg-white shadow-[0_8px_24px_rgba(26,25,24,0.04)]">
  <table class="min-w-full divide-y divide-slate-200">
    <thead class="bg-slate-50">
      <tr>
        <th class="px-4 py-3.5 text-left text-sm font-semibold text-slate-900">Client</th>
        <th class="px-4 py-3.5 text-left text-sm font-semibold text-slate-900">Role</th>
        <th class="px-4 py-3.5 text-left text-sm font-semibold text-slate-900">Rating</th>
        <th class="px-4 py-3.5 text-left text-sm font-semibold text-slate-900">Status</th>
        <th class="px-4 py-3.5 text-right text-sm font-semibold text-slate-900">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-200 bg-white">
      <% @reviews.each do |review| %>
        <tr class="hover:bg-slate-50">
          <td class="px-4 py-4 text-sm text-slate-900">
            <div class="font-medium"><%= review.client_name %></div>
            <div class="mt-1 text-xs text-slate-500 truncate max-w-xs"><%= review.content %></div>
            <% if review.business.present? %>
              <div class="mt-1 text-[10px] font-bold uppercase tracking-wider text-blue-600">
                For: <%= review.business.name %>
              </div>
            <% end %>
          </td>
          <td class="px-4 py-4 text-sm text-slate-600"><%= review.client_role %></td>
          <td class="px-4 py-4 text-sm text-amber-500">
            <%= "★" * review.rating %><%= "☆" * (5 - review.rating) %>
          </td>
          <td class="px-4 py-4 text-sm text-slate-600">
            <% status_badge_classes = review.active? ? "bg-emerald-50 text-emerald-700 ring-emerald-200" : "bg-amber-50 text-amber-700 ring-amber-200" %>
            <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-medium ring-1 ring-inset <%= status_badge_classes %>">
              <%= review.active? ? "Active" : "Hidden" %>
            </span>
          </td>
          <td class="px-4 py-4 text-right text-sm">
            <div class="flex justify-end gap-2">
              <%= button_to toggle_active_admin_review_path(review), method: :patch, class: "rounded-md #{review.active? ? 'bg-amber-50 text-amber-700 ring-amber-200 hover:bg-amber-100' : 'bg-emerald-50 text-emerald-700 ring-emerald-200 hover:bg-emerald-100'} px-3 py-1.5 text-xs font-semibold shadow-sm ring-1 ring-inset" do %>
                <%= review.active? ? "Hide" : "Show" %>
              <% end %>
              <%= link_to "Edit", edit_admin_review_path(review), class: "rounded-md bg-white px-3 py-1.5 text-xs font-semibold text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 hover:bg-slate-50" %>
              <%= button_to "Delete", admin_review_path(review), method: :delete, data: { turbo_confirm: "Delete this review?" }, class: "rounded-md bg-red-50 px-3 py-1.5 text-xs font-semibold text-red-700 shadow-sm ring-1 ring-inset ring-red-200 hover:bg-red-100" %>
            </div>
          </td>
        </tr>
      <% end %>

      <% if @reviews.empty? %>
        <tr>
          <td colspan="5" class="px-4 py-10 text-center text-sm text-slate-500">No reviews found.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
