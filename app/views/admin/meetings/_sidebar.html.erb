<div class="rounded-xl bg-white shadow-sm ring-1 ring-slate-900/5">
  <div class="border-b border-slate-200 px-4 py-4 sm:px-6">
    <h3 class="text-base font-semibold text-slate-900">Schedule for <%= @selected_date.strftime("%A, %b %-d") %></h3>
    <p class="mt-1 text-sm text-slate-600">Pick a business, choose a time, and book in one step.</p>
  </div>
  <div class="px-4 py-4 sm:px-6">
    <%= render "form", meeting: @meeting, businesses: @businesses, compact: false %>
  </div>
</div>

<div class="mt-6 rounded-xl bg-white shadow-sm ring-1 ring-slate-900/5">
  <div class="border-b border-slate-200 px-4 py-4 sm:px-6">
    <h3 class="text-base font-semibold text-slate-900"><%= @day_meetings.any? ? "Meetings on this day" : "No meetings on this day" %></h3>
  </div>
  <div class="divide-y divide-slate-100">
    <% if @day_meetings.any? %>
      <% @day_meetings.each do |meeting| %>
        <div class="px-4 py-4 sm:px-6">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="font-semibold text-slate-900"><%= meeting.title %></p>
              <p class="mt-1 text-sm text-slate-600"><%= meeting_time_range(meeting) %> · <%= meeting.business.name %></p>
              <p class="mt-1 text-sm text-slate-500"><%= meeting.client_name %> · <%= meeting.client_email %></p>
              <div class="mt-2"><%= meeting_status_badge(meeting) %></div>
            </div>
            <div class="flex flex-col gap-2">
              <% if meeting.google_meet_url.present? %>
                <%= link_to "Meet", meeting.google_meet_url, target: "_blank", rel: "noopener", class: "rounded-md bg-green-50 px-3 py-1.5 text-xs font-semibold text-green-700 ring-1 ring-inset ring-green-200 hover:bg-green-100" %>
              <% end %>
              <% if meeting.editable? && (employee_role? ? meeting.user_id == current_user.id : true) %>
                <%= link_to "Edit", edit_admin_meeting_path(meeting), class: "rounded-md bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 ring-1 ring-inset ring-slate-300 hover:bg-slate-50" %>
              <% end %>
              <% if meeting.cancellable? && (employee_role? ? meeting.user_id == current_user.id : true) %>
                <%= button_to "Cancel", cancel_admin_meeting_path(meeting), method: :patch, form: { data: { turbo_confirm: "Cancel this meeting?" } }, class: "rounded-md bg-red-50 px-3 py-1.5 text-xs font-semibold text-red-700 ring-1 ring-inset ring-red-200 hover:bg-red-100" %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="px-4 py-8 text-center text-sm text-slate-500 sm:px-6">
        Click a day on the calendar to schedule here.
      </div>
    <% end %>
  </div>
</div>
