<%= turbo_frame_tag "admin_meeting_slots" do %>
  <p class="mb-3 text-xs font-semibold uppercase tracking-wide text-slate-500">
    Available times for <%= date.strftime("%B %-d, %Y") %>
  </p>
  <% if slots.empty? %>
    <div class="rounded-lg bg-slate-50 px-3 py-6 text-center text-sm text-slate-500 ring-1 ring-inset ring-slate-200">
      No open times on this day. Pick another date or adjust company Availability.
    </div>
  <% else %>
    <div class="grid grid-cols-2 gap-2 sm:grid-cols-3">
      <% slots.each do |slot| %>
        <% selected_slot = selected.present? && Time.zone.parse(selected.to_s).to_i == slot.to_i %>
        <button type="button"
                data-action="slot-picker#choose"
                data-slot-picker-value-param="<%= slot.iso8601 %>"
                data-slot-option
                class="rounded-lg px-3 py-2.5 text-sm font-semibold shadow-sm ring-1 ring-inset transition <%= selected_slot ? 'bg-indigo-600 text-white ring-indigo-600' : 'bg-white text-slate-900 ring-slate-300 hover:bg-indigo-50' %>">
          <%= slot.strftime("%-l:%M %p") %>
        </button>
      <% end %>
    </div>
  <% end %>
<% end %>
