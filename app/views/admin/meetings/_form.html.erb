<% field_class = "mt-1 block w-full rounded-lg border-0 px-3 py-2.5 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6" %>
<% select_class = "mt-1 block w-full rounded-lg border-0 px-3 py-2.5 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6" %>
<% compact = local_assigns.fetch(:compact, false) %>
<% businesses = local_assigns.fetch(:businesses, Business.order(:name)) %>
<% form_url = local_assigns.fetch(:form_url, admin_meetings_path) %>

<div <%= tag.attributes(
  data: {
    controller: "meeting-schedule",
    meeting_schedule_businesses_value: meeting_businesses_hash(businesses)
  }
) %>>
  <%= form_with model: meeting, url: form_url, scope: :meeting, class: "space-y-4" do |f| %>
    <% if meeting.errors.any? %>
      <div class="rounded-lg bg-red-50 p-3 text-sm text-red-700 ring-1 ring-inset ring-red-200">
        <%= meeting.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div>
      <%= f.label :business_id, "Business", class: "block text-sm font-medium text-slate-900" %>
      <%= f.collection_select :business_id, businesses, :id, :name,
            { prompt: "Select a business" },
            class: select_class,
            required: true,
            data: { meeting_schedule_target: "businessSelect", action: "change->meeting-schedule#fillBusiness" } %>
    </div>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div>
        <%= f.label :meeting_date, "Date", class: "block text-sm font-medium text-slate-900" %>
        <%= f.date_field :meeting_date, value: (meeting.starts_at || Time.current).to_date, class: field_class, required: true %>
      </div>
      <div>
        <%= f.label :meeting_time, "Time", class: "block text-sm font-medium text-slate-900" %>
        <%= f.time_field :meeting_time, value: (meeting.starts_at || Time.current).in_time_zone.strftime("%H:%M"), class: field_class, required: true %>
      </div>
    </div>

    <div>
      <%= f.label :duration_minutes, "Duration", class: "block text-sm font-medium text-slate-900" %>
      <div class="mt-2 flex flex-wrap gap-2">
        <% Admin::MeetingsHelper::DURATION_PRESETS.each do |minutes| %>
          <button type="button"
                  data-action="click->meeting-schedule#setDuration"
                  data-duration="<%= minutes %>"
                  class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700 hover:bg-indigo-100 hover:text-indigo-700">
            <%= minutes %> min
          </button>
        <% end %>
      </div>
      <%= f.number_field :duration_minutes, min: 1, step: 1, class: "#{field_class} mt-2", required: true, data: { meeting_schedule_target: "duration" } %>
    </div>

    <div>
      <%= f.label :title, class: "block text-sm font-medium text-slate-900" %>
      <%= f.text_field :title, class: field_class, required: true, data: { meeting_schedule_target: "title" } %>
    </div>

    <% unless compact %>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        <div>
          <%= f.label :client_name, "Client name", class: "block text-sm font-medium text-slate-900" %>
          <%= f.text_field :client_name, class: field_class, required: true, data: { meeting_schedule_target: "clientName" } %>
        </div>
        <div>
          <%= f.label :client_email, "Client email", class: "block text-sm font-medium text-slate-900" %>
          <%= f.email_field :client_email, class: field_class, required: true, data: { meeting_schedule_target: "clientEmail" } %>
        </div>
      </div>
      <div>
        <%= f.label :client_phone, "Client phone", class: "block text-sm font-medium text-slate-900" %>
        <%= f.telephone_field :client_phone, class: field_class, data: { meeting_schedule_target: "clientPhone" } %>
      </div>
      <div>
        <%= f.label :description, class: "block text-sm font-medium text-slate-900" %>
        <%= f.text_area :description, rows: 3, class: field_class %>
      </div>
    <% else %>
      <%= f.hidden_field :client_name, data: { meeting_schedule_target: "clientName" } %>
      <%= f.hidden_field :client_email, data: { meeting_schedule_target: "clientEmail" } %>
      <%= f.hidden_field :client_phone, data: { meeting_schedule_target: "clientPhone" } %>
    <% end %>

    <div class="flex items-center gap-3 pt-1">
      <%= f.submit meeting.persisted? ? "Update Meeting" : "Schedule Meeting", class: "inline-flex w-full items-center justify-center rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
      <% unless compact %>
        <%= link_to "Back", admin_meetings_path, class: "text-sm font-semibold text-slate-600 hover:text-slate-900" %>
      <% end %>
    </div>
  <% end %>
</div>
