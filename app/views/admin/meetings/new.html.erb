<% content_for :page_header do %>
  <div>
    <h1 class="text-2xl font-bold tracking-tight text-slate-900">Schedule Meeting</h1>
    <p class="mt-1 text-sm text-slate-600">Creates a Google Calendar event with Meet link and sends invites from <%= Meeting.company_email %>.</p>
  </div>
<% end %>

<div class="mx-auto max-w-3xl rounded-xl bg-white px-4 py-6 shadow-sm ring-1 ring-slate-900/5 sm:px-6">
  <%= render "form", meeting: @meeting, businesses: Business.order(:name) %>
</div>
