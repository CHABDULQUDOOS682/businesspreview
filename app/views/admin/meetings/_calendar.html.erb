<div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-slate-900/5">
  <div class="flex items-center justify-between border-b border-slate-200 px-4 py-4 sm:px-6">
    <div class="flex items-center gap-3">
      <%= link_to admin_meetings_path(calendar_nav_params(month: @calendar_month - 1.month)), class: "rounded-lg p-2 text-slate-500 hover:bg-slate-100 hover:text-slate-900" do %>
        <span class="sr-only">Previous month</span>
        ←
      <% end %>
      <h2 class="text-lg font-semibold text-slate-900"><%= @calendar_month.strftime("%B %Y") %></h2>
      <%= link_to admin_meetings_path(calendar_nav_params(month: @calendar_month + 1.month)), class: "rounded-lg p-2 text-slate-500 hover:bg-slate-100 hover:text-slate-900" do %>
        <span class="sr-only">Next month</span>
        →
      <% end %>
    </div>
    <%= link_to "Today", admin_meetings_path(calendar_nav_params(month: Date.current, date: Date.current)), class: "text-sm font-semibold text-indigo-600 hover:text-indigo-500" %>
  </div>

  <div class="grid grid-cols-7 border-b border-slate-200 bg-slate-50 text-center text-xs font-semibold uppercase tracking-wide text-slate-500">
    <% %w[Sun Mon Tue Wed Thu Fri Sat].each do |label| %>
      <div class="px-2 py-3"><%= label %></div>
    <% end %>
  </div>

  <div class="grid grid-cols-7 gap-2 p-4">
    <% @calendar.weeks.each do |week| %>
      <% week.each do |day| %>
        <% next if day.nil? %>
        <% day_meetings = @calendar.meetings_on(day) %>
        <%= link_to admin_meetings_path(calendar_nav_params(month: @calendar_month, date: day)), class: meeting_calendar_day_classes(day, @selected_date, @calendar_month) do %>
          <div class="flex items-center justify-between">
            <span class="text-sm font-semibold"><%= day.day %></span>
            <% if day_meetings.any? %>
              <span class="rounded-full bg-indigo-100 px-2 py-0.5 text-[10px] font-bold text-indigo-700"><%= day_meetings.size %></span>
            <% end %>
          </div>
          <div class="mt-2 space-y-1">
            <% day_meetings.first(2).each do |meeting| %>
              <div class="truncate rounded-md bg-indigo-50 px-1.5 py-1 text-[11px] font-medium text-indigo-800">
                <%= meeting.starts_at.in_time_zone.strftime("%-I:%M") %> <%= meeting.client_name %>
              </div>
            <% end %>
            <% if day_meetings.size > 2 %>
              <div class="text-[10px] font-medium text-slate-500">+<%= day_meetings.size - 2 %> more</div>
            <% end %>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>
</div>
