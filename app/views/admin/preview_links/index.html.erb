<%
  field_class = "mt-1 block w-full rounded-lg border-0 px-3 py-2.5 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6"
  select_class = "mt-1 block w-full rounded-lg border-0 px-3 py-2.5 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6"
%>

<% content_for :page_header do %>
  <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <h1 class="text-2xl font-bold tracking-tight text-slate-900">Prototype Links</h1>
      <p class="mt-1 text-sm text-slate-600">Generate trackable landing pages and monitor engagement across all businesses.</p>
    </div>
    <div class="grid grid-cols-1 gap-3 text-sm sm:grid-cols-3">
      <div class="rounded-lg bg-white px-4 py-3 shadow-sm ring-1 ring-slate-900/5">
        <p class="text-slate-500">Total links</p>
        <p class="mt-1 text-lg font-semibold text-slate-900"><%= number_with_delimiter(@total_count) %></p>
      </div>
      <div class="rounded-lg bg-white px-4 py-3 shadow-sm ring-1 ring-slate-900/5">
        <p class="text-slate-500">Total visits</p>
        <p class="mt-1 text-lg font-semibold text-blue-700"><%= number_with_delimiter(@total_visits) %></p>
      </div>
      <div class="rounded-lg bg-white px-4 py-3 shadow-sm ring-1 ring-slate-900/5">
        <p class="text-slate-500">Links with clicks</p>
        <p class="mt-1 text-lg font-semibold text-emerald-700"><%= number_with_delimiter(@clicked_count) %></p>
      </div>
    </div>
  </div>
<% end %>

<div class="mb-6 rounded-xl bg-white shadow-sm ring-1 ring-slate-900/5">
  <div class="border-b border-slate-200 px-4 py-5 sm:px-6">
    <h2 class="text-base font-semibold leading-6 text-slate-900">Generate Prototype Link</h2>
    <p class="mt-1 text-sm text-slate-500">Select a business and template, then generate a new trackable landing page.</p>
  </div>

  <%= form_with url: admin_preview_links_path, method: :post, local: true, class: "space-y-6 px-4 py-5 sm:px-6" do |f| %>
    <div class="max-w-xl">
      <%= f.label :business_id, "Business", class: "block text-sm font-medium leading-6 text-slate-900" %>
      <%= f.select :business_id,
                   options_from_collection_for_select(@businesses, :id, :name, params[:business_id]),
                   { include_blank: "Select a business..." },
                   required: true,
                   class: select_class %>
    </div>

    <fieldset>
      <legend class="block text-sm font-medium leading-6 text-slate-900">Template</legend>
      <div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2 xl:grid-cols-3">
        <% @templates.each do |template| %>
          <label class="relative flex cursor-pointer items-start gap-3 rounded-xl border border-slate-200 bg-white p-4 shadow-sm transition hover:border-blue-300 hover:bg-slate-50 has-[:checked]:border-blue-500 has-[:checked]:ring-2 has-[:checked]:ring-blue-500">
            <%= f.radio_button :template, template, required: template == @templates.first, class: "mt-1 h-4 w-4 border-slate-300 text-blue-600 focus:ring-blue-600" %>
            <span class="min-w-0 flex-1">
              <span class="block text-sm font-semibold text-slate-900"><%= preview_link_template_label(template) %></span>
              <span class="mt-1 block text-xs text-slate-500"><%= template %></span>
            </span>
          </label>
        <% end %>
      </div>
    </fieldset>

    <div>
      <%= f.submit "Generate Link",
                   class: "rounded-md bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600" %>
    </div>
  <% end %>
</div>

<div class="mb-6 rounded-xl bg-white px-4 py-4 shadow-sm ring-1 ring-slate-900/5 sm:px-6">
  <%= form_with url: admin_preview_links_path, method: :get, local: true, class: "grid grid-cols-1 gap-4 lg:grid-cols-4 lg:items-end" do |f| %>
    <div class="lg:col-span-2">
      <%= f.label :q, "Search", class: "block text-sm font-medium leading-6 text-slate-900" %>
      <%= f.text_field :q, value: params[:q], class: field_class, placeholder: "Search by business, email, or link ID" %>
    </div>

    <div>
      <%= f.label :business_id, "Business", class: "block text-sm font-medium leading-6 text-slate-900" %>
      <%= f.select :business_id,
                   options_for_select([ [ "All businesses", "" ] ] + @businesses.map { |b| [ b.name, b.id ] }, params[:business_id]),
                   {},
                   class: select_class %>
    </div>

    <div>
      <%= f.label :template, "Template", class: "block text-sm font-medium leading-6 text-slate-900" %>
      <%= f.select :template,
                   options_for_select([ [ "All templates", "" ] ] + @templates.map { |t| [ preview_link_template_label(t), t ] }, params[:template]),
                   {},
                   class: select_class %>
    </div>

    <div class="flex flex-wrap gap-2 lg:col-span-4">
      <%= f.submit "Apply filters", class: "rounded-md bg-blue-600 px-3 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-blue-500" %>
      <% if params[:q].present? || params[:business_id].present? || params[:template].present? %>
        <%= link_to "Clear", admin_preview_links_path, class: "rounded-md bg-white px-3 py-2.5 text-sm font-semibold text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 hover:bg-slate-50" %>
      <% end %>
    </div>
  <% end %>
</div>

<div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-slate-900/5">
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-slate-300">
      <thead class="bg-slate-50">
        <tr>
          <th class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-slate-900 sm:pl-6">Business</th>
          <th class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Template</th>
          <th class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Engagement</th>
          <th class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Link URL</th>
          <th class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Created</th>
          <th class="relative py-3.5 pl-3 pr-4 sm:pr-6">
            <span class="sr-only">Actions</span>
          </th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200 bg-white">
        <% @preview_links.each do |link| %>
          <% link_url = preview_link_public_url(link) %>
          <tr class="hover:bg-slate-50">
            <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium sm:pl-6">
              <%= link_to link.business.name, admin_business_path(link.business), class: "text-blue-600 hover:text-blue-500 hover:underline" %>
            </td>
            <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-600"><%= preview_link_template_label(link.template) %></td>
            <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-500">
              <div class="flex items-center gap-x-2">
                <span class="<%= link.visit_count.to_i > 0 ? 'inline-flex items-center rounded-md bg-green-50 px-2 py-1 text-xs font-medium text-green-700 ring-1 ring-inset ring-green-600/20' : 'text-slate-500' %>">
                  <%= link.visit_count %> visits
                </span>
                <% if link.clicked_at.present? %>
                  <span class="text-xs text-slate-400" title="<%= link.clicked_at %>">Latest: <%= time_ago_in_words(link.clicked_at) %> ago</span>
                <% end %>
              </div>
            </td>
            <td class="px-3 py-4 text-sm text-slate-500">
              <div class="flex max-w-xs items-center gap-2">
                <%= link_to link_url, link_url, target: "_blank", rel: "noopener", class: "min-w-0 truncate text-blue-600 hover:text-blue-500 hover:underline" %>
                <div data-controller="clipboard" data-clipboard-text-value="<%= link_url %>">
                  <button type="button"
                          data-action="clipboard#copy"
                          data-clipboard-target="label"
                          class="shrink-0 rounded-md bg-slate-100 px-2 py-1 text-xs font-semibold text-slate-700 hover:bg-slate-200">
                    Copy
                  </button>
                </div>
              </div>
            </td>
            <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-500"><%= time_ago_in_words(link.created_at) %> ago</td>
            <td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-6">
              <%= button_to "Delete",
                            admin_preview_link_path(link),
                            method: :delete,
                            data: { turbo_confirm: "Are you sure?" },
                            class: "text-red-600 hover:text-red-900 bg-transparent border-0 p-0 text-sm font-medium cursor-pointer" %>
            </td>
          </tr>
        <% end %>
        <% if @preview_links.empty? %>
          <tr>
            <td colspan="6" class="px-3 py-12 text-center text-sm text-slate-500">No prototype links found. Use the form above to generate one.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<% if @pagy.pages > 1 %>
  <div class="mt-4 flex justify-end">
    <%== pagy_nav(@pagy) %>
  </div>
<% end %>
