<div class="bg-white shadow-sm ring-1 ring-slate-900/5 sm:rounded-xl overflow-hidden">
  <div class="border-b border-slate-200 px-4 py-5 sm:px-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h3 class="text-base font-semibold leading-6 text-slate-900">Prototype Links</h3>
      <p class="mt-1 text-sm text-slate-500">Trackable landing pages generated for this business.</p>
    </div>
    <div class="flex items-center gap-3">
      <span class="inline-flex items-center rounded-md bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-700/10">
        <%= business.preview_links.count %> total
      </span>
      <%= link_to "Generate link",
                  admin_preview_links_path(business_id: business.id),
                  class: "inline-flex h-9 items-center rounded-md bg-blue-600 px-3 text-sm font-semibold text-white shadow-sm hover:bg-blue-500" %>
    </div>
  </div>

  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-slate-300">
      <thead class="bg-slate-50">
        <tr>
          <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-slate-900 sm:pl-6">Template</th>
          <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Engagement</th>
          <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Link URL</th>
          <th scope="col" class="relative py-3.5 pl-3 pr-4 sm:pr-6">
            <span class="sr-only">Actions</span>
          </th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200 bg-white">
        <% business.preview_links.order(created_at: :desc).each do |link| %>
          <% link_url = preview_link_public_url(link) %>
          <tr class="hover:bg-slate-50">
            <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-slate-900 sm:pl-6">
              <%= preview_link_template_label(link.template) %>
            </td>
            <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-500">
              <div class="flex items-center gap-x-2">
                <span class="<%= link.visit_count.to_i > 0 ? 'inline-flex items-center rounded-md bg-green-50 px-2 py-1 text-xs font-medium text-green-700 ring-1 ring-inset ring-green-600/20' : 'text-slate-500' %>">
                  <%= link.visit_count %> visits
                </span>
                <% if link.clicked_at.present? %>
                  <span class="text-xs text-slate-400" title="<%= link.clicked_at %>">Latest: <%= time_ago_in_words(link.clicked_at) %> ago</span>
                <% end %>
              </div>
            </td>
            <td class="px-3 py-4 text-sm text-slate-500">
              <div class="flex min-w-0 max-w-md items-center gap-2">
                <%= link_to link_url, link_url, target: "_blank", rel: "noopener", class: "min-w-0 truncate text-blue-600 hover:text-blue-500 hover:underline" %>
                <div data-controller="clipboard" data-clipboard-text-value="<%= link_url %>">
                  <button type="button"
                          data-action="clipboard#copy"
                          data-clipboard-target="label"
                          class="inline-flex h-8 shrink-0 items-center rounded-md bg-slate-100 px-2.5 text-xs font-semibold text-slate-700 hover:bg-slate-200">
                    Copy
                  </button>
                </div>
              </div>
            </td>
            <td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-6">
              <%= link_to "Open", link_url, target: "_blank", rel: "noopener", class: "text-blue-600 hover:text-blue-500" %>
            </td>
          </tr>
        <% end %>
        <% if business.preview_links.empty? %>
          <tr>
            <td colspan="4" class="px-3 py-8 text-center text-sm text-slate-500">
              No prototype links yet.
              <%= link_to "Generate one", admin_preview_links_path(business_id: business.id), class: "font-medium text-blue-600 hover:text-blue-500" %>.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
