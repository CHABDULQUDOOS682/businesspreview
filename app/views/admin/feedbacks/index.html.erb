<% field_class = "mt-1 block w-full rounded-lg border-0 px-3 py-2.5 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6" %>
<% select_class = "mt-1 block w-full rounded-lg border-0 px-3 py-2.5 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6" %>

<% content_for :page_header do %>
  <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <h1 class="text-2xl font-bold tracking-tight text-slate-900">Feedback & Issues</h1>
      <p class="mt-1 text-sm text-slate-600"><%= employee_role? ? "Submit feedback and track your submissions." : "Review, triage, and manage internal feedback." %></p>
    </div>
    <%= link_to "Submit Feedback", new_admin_feedback_path, class: "inline-flex items-center justify-center rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
  </div>
<% end %>

<div class="mb-6">
  <%= render "stats", stats: @stats %>
</div>

<div class="mb-6 rounded-xl bg-white px-4 py-4 shadow-sm ring-1 ring-slate-900/5 sm:px-6">
  <%= form_with url: admin_feedbacks_path, method: :get, local: true, class: "grid grid-cols-1 gap-4 lg:grid-cols-5 lg:items-end" do |f| %>
    <div class="lg:col-span-2">
      <%= f.label :q, "Search", class: "block text-sm font-medium text-slate-900" %>
      <%= f.text_field :q, value: params[:q], class: field_class, placeholder: "Title, description, or submitter" %>
    </div>

    <div>
      <%= f.label :feedback_type, "Type", class: "block text-sm font-medium text-slate-900" %>
      <%= f.select :feedback_type, options_for_select([ [ "All types", "" ] ] + feedback_type_options, params[:feedback_type]), {}, class: select_class %>
    </div>

    <div>
      <%= f.label :status, "Status", class: "block text-sm font-medium text-slate-900" %>
      <%= f.select :status, options_for_select([ [ "All statuses", "" ] ] + feedback_status_options, params[:status]), {}, class: select_class %>
    </div>

    <div>
      <%= f.label :priority, "Priority", class: "block text-sm font-medium text-slate-900" %>
      <%= f.select :priority, options_for_select([ [ "All priorities", "" ] ] + feedback_priority_options, params[:priority]), {}, class: select_class %>
    </div>

    <% if filterable_user? %>
      <div>
        <%= f.label :user_id, "Submitter", class: "block text-sm font-medium text-slate-900" %>
        <%= f.select :user_id, options_for_select([ [ "All users", "" ] ] + @users.map { |user| [ user.display_name, user.id ] }, params[:user_id]), {}, class: select_class %>
      </div>
    <% end %>

    <div class="flex gap-2 <%= filterable_user? ? "lg:col-span-5" : "lg:col-span-5" %>">
      <%= f.submit "Apply filters", class: "rounded-md bg-indigo-600 px-3 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
      <%= link_to "Clear", admin_feedbacks_path, class: "rounded-md bg-white px-3 py-2.5 text-sm font-semibold text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 hover:bg-slate-50" %>
    </div>
  <% end %>
</div>

<div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-slate-900/5">
  <table class="min-w-full divide-y divide-slate-200">
    <thead class="bg-slate-50">
      <tr>
        <th class="py-3.5 pl-4 pr-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-600 sm:pl-6">Feedback</th>
        <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Type</th>
        <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Priority</th>
        <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Status</th>
        <% if filterable_user? %>
          <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Submitter</th>
        <% end %>
        <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Created</th>
        <th class="relative py-3.5 pl-3 pr-4 sm:pr-6"><span class="sr-only">Actions</span></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100 bg-white">
      <% @feedbacks.each do |feedback| %>
        <tr class="hover:bg-slate-50">
          <td class="py-4 pl-4 pr-3 sm:pl-6">
            <%= link_to feedback.title, admin_feedback_path(feedback), class: "font-semibold text-indigo-700 hover:text-indigo-600" %>
            <p class="mt-1 line-clamp-2 max-w-md text-sm text-slate-500"><%= feedback.description %></p>
          </td>
          <td class="whitespace-nowrap px-3 py-4"><%= feedback_type_badge(feedback) %></td>
          <td class="whitespace-nowrap px-3 py-4">
            <% if feedback.manageable_by?(current_user) %>
              <%= form_with model: feedback, url: admin_feedback_path(feedback), method: :patch, local: true, class: "inline" do |f| %>
                <%= f.select :priority, options_for_select(feedback_priority_options, feedback.priority), {}, class: "rounded-md border-0 py-1.5 text-xs font-semibold shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-indigo-600", onchange: "this.form.requestSubmit()" %>
              <% end %>
            <% else %>
              <%= feedback_priority_badge(feedback) %>
            <% end %>
          </td>
          <td class="whitespace-nowrap px-3 py-4">
            <% if feedback.manageable_by?(current_user) %>
              <%= form_with model: feedback, url: admin_feedback_path(feedback), method: :patch, local: true, class: "inline" do |f| %>
                <%= f.select :status, options_for_select(feedback_status_options, feedback.status), {}, class: "rounded-md border-0 py-1.5 text-xs font-semibold shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-indigo-600", onchange: "this.form.requestSubmit()" %>
              <% end %>
            <% else %>
              <%= feedback_status_badge(feedback) %>
            <% end %>
          </td>
          <% if filterable_user? %>
            <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-600"><%= feedback.user.display_name %></td>
          <% end %>
          <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-500"><%= l(feedback.created_at, format: :short) %></td>
          <td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-6">
            <div class="flex justify-end gap-2">
              <%= link_to "View", admin_feedback_path(feedback), class: "text-indigo-600 hover:text-indigo-900" %>
              <% if feedback.editable_by?(current_user) %>
                <%= link_to "Edit", edit_admin_feedback_path(feedback), class: "text-slate-600 hover:text-slate-900" %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
      <% if @feedbacks.empty? %>
        <tr>
          <td colspan="<%= filterable_user? ? 7 : 6 %>" class="px-3 py-12 text-center text-sm text-slate-500">No feedback found.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if @pagy.pages > 1 %>
  <div class="mt-4 flex justify-end">
    <%== pagy_nav(@pagy) %>
  </div>
<% end %>
