<% content_for :page_header do %>
  <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <div class="flex items-center gap-x-3 text-sm text-slate-500 mb-1">
        <%= link_to "Feedback", admin_feedbacks_path, class: "hover:text-slate-700" %>
        <span>/</span>
        <span>#<%= @feedback.id %></span>
      </div>
      <h1 class="text-2xl font-bold tracking-tight text-slate-900"><%= @feedback.title %></h1>
      <div class="mt-2 flex flex-wrap items-center gap-2">
        <%= feedback_type_badge(@feedback) %>
        <%= feedback_priority_badge(@feedback) %>
        <%= feedback_status_badge(@feedback) %>
      </div>
    </div>
    <div class="flex flex-wrap gap-2">
      <% if @feedback.editable_by?(current_user) %>
        <%= link_to "Edit", edit_admin_feedback_path(@feedback), class: "inline-flex items-center justify-center rounded-lg bg-white px-4 py-2.5 text-sm font-semibold text-slate-900 ring-1 ring-inset ring-slate-300 hover:bg-slate-50" %>
      <% end %>
      <% if super_admin? %>
        <%= button_to "Resolve", resolve_admin_feedback_path(@feedback), method: :patch, class: "inline-flex items-center justify-center rounded-lg bg-green-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-green-500" %>
        <%= button_to "Close", close_admin_feedback_path(@feedback), method: :patch, class: "inline-flex items-center justify-center rounded-lg bg-slate-700 px-4 py-2.5 text-sm font-semibold text-white hover:bg-slate-600" %>
        <%= button_to "Delete", admin_feedback_path(@feedback), method: :delete, data: { turbo_confirm: "Delete this feedback?" }, class: "inline-flex items-center justify-center rounded-lg bg-red-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-red-500" %>
      <% end %>
    </div>
  </div>
<% end %>

<div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
  <div class="lg:col-span-2 space-y-6">
    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-900/5">
      <h2 class="text-base font-semibold text-slate-900">Description</h2>
      <p class="mt-3 whitespace-pre-wrap text-sm text-slate-700"><%= @feedback.description %></p>
    </div>

    <% if @feedback.bug? %>
      <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-900/5 space-y-4">
        <h2 class="text-base font-semibold text-slate-900">Bug details</h2>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Steps to reproduce</p>
          <p class="mt-2 whitespace-pre-wrap text-sm text-slate-700"><%= @feedback.steps_to_reproduce %></p>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Expected result</p>
          <p class="mt-2 whitespace-pre-wrap text-sm text-slate-700"><%= @feedback.expected_result %></p>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Actual result</p>
          <p class="mt-2 whitespace-pre-wrap text-sm text-slate-700"><%= @feedback.actual_result %></p>
        </div>
      </div>
    <% end %>

    <% if @feedback.screenshots.attached? %>
      <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-900/5">
        <h2 class="text-base font-semibold text-slate-900">Screenshots</h2>
        <div class="mt-4 grid grid-cols-2 gap-4 sm:grid-cols-3">
          <% @feedback.screenshots.each do |screenshot| %>
            <%= link_to url_for(screenshot), target: "_blank", rel: "noopener" do %>
              <%= image_tag screenshot, class: "h-32 w-full rounded-lg object-cover ring-1 ring-slate-200" %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="space-y-6">
    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-900/5">
      <h2 class="text-base font-semibold text-slate-900">Details</h2>
      <dl class="mt-4 space-y-3 text-sm">
        <div class="flex justify-between gap-4">
          <dt class="text-slate-500">Submitter</dt>
          <dd class="font-medium text-slate-900"><%= @feedback.user.display_name %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-slate-500">Created</dt>
          <dd class="text-slate-900"><%= l(@feedback.created_at, format: :long) %></dd>
        </div>
        <% if @feedback.resolved_at.present? %>
          <div class="flex justify-between gap-4">
            <dt class="text-slate-500">Resolved</dt>
            <dd class="text-slate-900"><%= l(@feedback.resolved_at, format: :long) %></dd>
          </div>
        <% end %>
        <div class="flex justify-between gap-4">
          <dt class="text-slate-500">Page URL</dt>
          <dd class="text-right text-indigo-600 break-all"><%= @feedback.page_url.present? ? link_to("Open page", @feedback.page_url, target: "_blank", rel: "noopener") : "-" %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-slate-500">Browser</dt>
          <dd class="text-right text-slate-900 break-all"><%= @feedback.browser.presence || "-" %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-slate-500">OS</dt>
          <dd class="text-right text-slate-900"><%= @feedback.operating_system.presence || "-" %></dd>
        </div>
      </dl>
    </div>

    <% if @feedback.admin_notes.present? || @feedback.manageable_by?(current_user) %>
      <div class="rounded-xl bg-indigo-50 p-6 ring-1 ring-inset ring-indigo-100">
        <h2 class="text-base font-semibold text-indigo-900">Admin notes</h2>
        <p class="mt-3 whitespace-pre-wrap text-sm text-indigo-950"><%= @feedback.admin_notes.presence || "No admin notes yet." %></p>
      </div>
    <% end %>
  </div>
</div>
