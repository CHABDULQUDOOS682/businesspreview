<% count = count.to_i %>
<% if count.positive? %>
  <span class="unread-badge-root" data-unread-count="<%= count %>" title="<%= count %> unread message<%= count == 1 ? "" : "s" %>">
    <span class="unread-badge-dot" aria-hidden="true">
      <span class="unread-badge-dot__ping"></span>
      <span class="unread-badge-dot__core"></span>
    </span>
    <span class="unread-badge-count"><%= count > 99 ? "99+" : count %></span>
  </span>
<% else %>
  <span class="unread-badge-root" data-unread-count="0"></span>
<% end %>
