<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 h-[calc(100vh-64px)] flex flex-col" 
     data-controller="twilio-call" 
     data-twilio-call-phone-number-value="<%= @number %>">
  
  <div class="flex items-center justify-between mb-4 flex-shrink-0">
    <div>
      <h2 class="text-2xl font-bold leading-7 text-gray-900">
        <%= @business&.name || @number %>
      </h2>
      <div class="flex items-center gap-x-2">
        <p class="text-sm text-gray-500"><%= @number %></p>
        <span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-gray-100 text-gray-600" data-twilio-call-target="status">Initializing...</span>
      </div>
    </div>
    
    <div class="flex space-x-3">
      <!-- Browser Call Button -->
      <button type="button" 
              data-twilio-call-target="callButton"
              data-action="click->twilio-call#makeCall"
              class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 disabled:opacity-50 disabled:cursor-not-allowed">
        <svg class="-ml-1 mr-2 h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H3.75A2.25 2.25 0 0 0 1.5 4.5v2.25Z" />
        </svg>
        Call Browser
      </button>

      <!-- Hangup Button (Hidden by default) -->
      <button type="button" 
              data-twilio-call-target="hangupButton"
              data-action="click->twilio-call#hangup"
              class="hidden inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
        <svg class="-ml-1 mr-2 h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
        Hang Up
      </button>
    </div>
  </div>

  <div class="flex-1 overflow-y-auto bg-gray-50 p-4 rounded-lg shadow-inner mb-4 space-y-4">
    <% @messages.each do |msg| %>
      <div class="flex <%= msg.direction == "outbound" ? "justify-end" : "justify-start" %>">
        <div class="max-w-[80%] rounded-lg p-3 shadow-sm <%= msg.direction == "outbound" ? "bg-indigo-600 text-white" : "bg-white text-gray-900 border border-gray-200" %>">
          <p class="text-sm"><%= msg.body %></p>
          <p class="text-[10px] mt-1 opacity-70 text-right">
            <%= msg.created_at.strftime("%I:%M %p") %>
          </p>
        </div>
      </div>
    <% end %>
  </div>

  <div class="flex-shrink-0">
    <%= form_with url: admin_communications_path, method: :post, class: "relative" do |f| %>
      <%= f.hidden_field :to_number, value: @number %>
      <%= f.hidden_field :business_id, value: @business&.id %>
      <div class="flex items-center space-x-3">
        <%= f.text_area :body, rows: 2, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm py-3 px-4 resize-none", placeholder: "Type your message..." %>
        <button type="submit" class="inline-flex items-center px-4 py-3 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
          <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
          </svg>
        </button>
      </div>
    <% end %>
  </div>
</div>
