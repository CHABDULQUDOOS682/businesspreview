<%= turbo_stream_from "conversation:#{@conversation_key}" if @conversation_key.present? %>
<div class="flex h-full min-h-[42rem] flex-col"
     data-controller="twilio-call chat-scroll"
     data-action="turbo:load@window->chat-scroll#scrollToBottom turbo:render@window->chat-scroll#scrollToBottom"
     data-twilio-call-phone-number-value="<%= @number %>">

  <div class="mb-4 flex flex-shrink-0 flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <div class="min-w-0">
      <h2 class="text-xl sm:text-2xl font-bold leading-tight text-gray-900 break-words">
        <%= @business&.name || @number %>
      </h2>
      <div class="mt-1 flex flex-wrap items-center gap-2">
        <p class="text-sm text-gray-500 break-all"><%= @number %></p>
        <span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-gray-100 text-gray-600" data-twilio-call-target="status">Initializing...</span>
      </div>
    </div>

    <div class="flex w-full sm:w-auto gap-2 sm:gap-3">
      <!-- Browser Call Button -->
      <button type="button" 
              data-twilio-call-target="callButton"
              data-action="click->twilio-call#makeCall"
              class="flex-1 sm:flex-none justify-center inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 disabled:opacity-50 disabled:cursor-not-allowed">
        <svg class="-ml-1 mr-2 h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H3.75A2.25 2.25 0 0 0 1.5 4.5v2.25Z" />
        </svg>
        <span class="whitespace-nowrap">Call Browser</span>
      </button>

      <!-- Hangup Button -->
      <button type="button" 
              data-twilio-call-target="hangupButton"
              data-action="click->twilio-call#hangup"
              class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
        <svg class="-ml-1 mr-2 h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
        <span class="whitespace-nowrap">Hang Up</span>
      </button>
    </div>
  </div>

  <div class="mt-2 flex min-h-0 flex-1 flex-col lg:flex-row lg:gap-6">
    <!-- Messages column -->
    <div class="flex-1 flex flex-col">
      <div id="messages" class="mb-4 flex-1 min-h-0 overflow-y-auto rounded-[24px] border border-sand-200 bg-sand-50/80 p-4 shadow-inner" data-chat-scroll-target="list">
        <div id="message_list" class="space-y-4">
          <%= render partial: "admin/communications/message",
                     collection: @messages,
                     as: :msg,
                     locals: { conversation_key: @conversation_key, last_inbound_at: @last_inbound_at } %>
        </div>
        <div data-chat-scroll-target="bottom"></div>
      </div>

      <div class="sticky bottom-0 flex-shrink-0 border-t border-sand-200 bg-white/95 pt-3 pb-[calc(0.75rem+env(safe-area-inset-bottom))] 
        <%= form_with url: admin_communications_path, method: :post, class: "relative" do |f| %>
          <%= f.hidden_field :to_number, value: @number %>
          <%= f.hidden_field :business_id, value: @business&.id %>
          <div class="flex items-end gap-2">
            <%= f.text_area :body,
                            rows: 1,
                            class: "block w-full rounded-2xl border border-slate-300 bg-white shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm py-3 px-4 resize-none min-h-11 max-h-36",
                            placeholder: "Type your message..." %>
            <button
              type="submit"
              class="flex-shrink-0 inline-flex h-11 w-11 items-center justify-center rounded-xl border border-transparent text-sm font-medium shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500"
              aria-label="Send message"
            >
              <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
              </svg>
            </button>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Notes column -->
    <% if @business %>
      <div class="mt-4 lg:mt-0 lg:w-80 flex-shrink-0">
        <%= render "admin/notes/notes_panel", business: @business %>
      </div>
    <% end %>
  </div>
</div>
