<div class="bg-white px-4 py-5 shadow-sm ring-1 ring-slate-900/5 sm:rounded-xl sm:px-6">
  <div class="mb-4 flex flex-wrap items-center justify-between gap-2">
    <div>
      <h3 class="text-base font-semibold leading-6 text-slate-900">Payment status</h3>
      <p class="mt-1 text-xs text-slate-500">Stripe / subscription billing only — separate from SitePilot website pause.</p>
    </div>
    <%= business_payment_status_badge(business) %>
  </div>

  <dl class="space-y-4 text-sm leading-6">
    <div class="flex justify-between gap-x-4 border-b border-slate-100 pb-4">
      <dt class="text-slate-500">Subscription billing</dt>
      <dd class="text-slate-900 font-medium">
        <% if business.subscription_active? %>
          Yes<%= business.subscription_fee.present? ? " · #{number_to_currency(business.subscription_fee)}/mo" : "" %>
        <% else %>
          No
        <% end %>
      </dd>
    </div>

    <% if business.sold_price.present? %>
      <div class="flex justify-between gap-x-4 border-b border-slate-100 pb-4">
        <dt class="text-slate-500">Website sale</dt>
        <dd class="text-slate-900 font-medium">
          <%= number_to_currency(business.sold_price) %>
          <% if business.sold_price_paid_at.present? %>
            <span class="text-emerald-700">· Paid <%= l(business.sold_price_paid_at.to_date, format: :long) %></span>
          <% else %>
            <span class="text-amber-700">· Unpaid</span>
          <% end %>
        </dd>
      </div>
    <% end %>

    <% if business.subscription_active? %>
      <div class="flex justify-between gap-x-4 border-b border-slate-100 pb-4">
        <dt class="text-slate-500">Next subscription bill</dt>
        <dd class="text-slate-900 font-medium">
          <%= business.next_subscription_invoice_at.present? ? l(business.next_subscription_invoice_at.to_date, format: :long) : "—" %>
        </dd>
      </div>

      <% if business.subscription_grace_ends_at.present? %>
        <div class="flex justify-between gap-x-4 border-b border-slate-100 pb-4">
          <dt class="text-slate-500">Grace ends</dt>
          <dd class="text-amber-800 font-medium"><%= l(business.subscription_grace_ends_at, format: :long) %></dd>
        </div>
      <% end %>

      <div class="flex justify-between gap-x-4">
        <dt class="text-slate-500">Last invoice paid</dt>
        <dd class="text-slate-900 font-medium">
          <%= business.last_invoice_paid_at.present? ? l(business.last_invoice_paid_at.to_date, format: :long) : "—" %>
        </dd>
      </div>
    <% end %>
  </dl>
</div>
