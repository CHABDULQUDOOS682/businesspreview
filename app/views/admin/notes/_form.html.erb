<%= form_with(model: note, url: note.persisted? ? admin_note_path(note) : admin_notes_path, class: "space-y-3") do |f| %>
  <%= f.hidden_field :business_id, value: note.business_id || business.id %>

  <div>
    <%= f.label :body, "Note", class: "block text-sm font-medium leading-6 text-slate-900" %>
    <%= f.text_area :body,
                    rows: 3,
                    class: "mt-1 block w-full rounded-lg border-0 px-3 py-2.5 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6",
                    placeholder: "Add an internal note about this business..." %>
  </div>

  <div class="flex justify-end">
    <%= f.submit note.persisted? ? "Update note" : "Add note", class: "inline-flex items-center rounded-md bg-blue-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-500" %>
  </div>
<% end %>

