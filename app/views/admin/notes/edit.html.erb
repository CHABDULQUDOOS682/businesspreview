<div class="max-w-2xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
  <div class="mb-6">
    <h1 class="text-2xl font-bold tracking-tight text-slate-900">Edit Note</h1>
    <p class="mt-1 text-sm text-slate-500">
      Updating note for <%= @note.business.name %>.
    </p>
  </div>

  <div class="bg-white shadow-sm ring-1 ring-slate-900/5 sm:rounded-xl p-6">
    <%= render "admin/notes/form", note: @note, business: @note.business %>
  </div>

  <div class="mt-4">
    <%= link_to "Back to business",
                admin_business_path(@note.business),
                class: "text-sm font-medium text-slate-600 hover:text-slate-900" %>
  </div>
</div>

