<div class="bg-white shadow-sm ring-1 ring-slate-900/5 sm:rounded-xl p-5 space-y-4">
  <div class="flex items-center justify-between">
    <h3 class="text-base font-semibold leading-6 text-slate-900">Notes</h3>
    <p class="text-xs text-slate-500">
      Internal notes about <%= business.name %>
    </p>
  </div>

  <% if business.notes.any? %>
    <ul class="space-y-3">
      <% business.notes.order(created_at: :desc).each do |note| %>
        <li class="rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm leading-6 text-slate-800">
          <div class="flex items-start justify-between gap-2">
            <p class="whitespace-pre-wrap break-words flex-1"><%= note.body %></p>
            <div class="flex flex-col items-end gap-1 ml-2">
              <p class="text-[11px] text-slate-500">
                <%= time_ago_in_words(note.created_at) %> ago
              </p>
              <div class="flex items-center gap-1">
                <%= link_to "Edit",
                            edit_admin_note_path(note),
                            class: "text-xs font-medium text-blue-600 hover:text-blue-500" %>
                <span class="text-slate-300 text-xs">·</span>
                <%= button_to "Delete",
                              admin_note_path(note),
                              method: :delete,
                              data: { turbo_confirm: "Delete this note?" },
                              class: "text-xs font-medium text-red-600 hover:text-red-500 bg-transparent border-0 p-0" %>
              </div>
            </div>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-sm text-slate-500">
      No notes yet. Use the form below to add your first note.
    </p>
  <% end %>

  <div class="pt-3 border-t border-slate-200">
    <%= render "admin/notes/form", note: Note.new(business: business), business: business %>
  </div>
</div>

