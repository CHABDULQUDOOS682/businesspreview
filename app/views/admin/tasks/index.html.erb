<%
  field_class = "mt-1 block w-full rounded-lg border-0 px-3 py-2.5 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6"
  select_class = "mt-1 block w-full rounded-lg border-0 px-3 py-2.5 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6"
%>

<% content_for :page_header do %>
  <div>
    <h1 class="text-2xl font-bold tracking-tight text-slate-900">Tasks</h1>
    <p class="mt-1 text-sm text-slate-600">
      Content update requests synced from SitePilot.
    </p>
  </div>
<% end %>

<div class="mb-8 rounded-2xl bg-white px-4 py-4 shadow-sm ring-1 ring-slate-900/5 sm:px-6">
  <%= form_with url: admin_tasks_path, method: :get, local: true, class: "grid grid-cols-1 gap-4 lg:grid-cols-4 lg:items-end" do |f| %>
    <div class="lg:col-span-2">
      <%= f.label :q, "Search", class: "block text-sm font-medium leading-6 text-slate-900" %>
      <%= f.text_field :q, value: @query, class: field_class, placeholder: "Search by title, description, business number, or requester" %>
    </div>

    <div>
      <%= f.label :status, "Status", class: "block text-sm font-medium leading-6 text-slate-900" %>
      <%= f.select :status, options_for_select([ [ "All statuses", "" ] ] + @status_options.map { |status| [ status.humanize, status ] }, @status_filter), {}, class: select_class %>
    </div>

    <div class="flex flex-wrap gap-2">
      <%= f.submit "Apply filters", class: "rounded-md bg-blue-600 px-3 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-blue-500" %>
      <% if @query.present? || @status_filter.present? %>
        <%= link_to "Clear", admin_tasks_path, class: "rounded-md bg-white px-3 py-2.5 text-sm font-semibold text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 hover:bg-slate-50" %>
      <% end %>
    </div>
  <% end %>
</div>

<div class="space-y-4">
  <% if @tasks.any? %>
    <% @tasks.each do |task| %>
      <article class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-900/5">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
          <div class="min-w-0 flex-1">
            <div class="flex flex-wrap items-center gap-2">
              <span class="inline-flex items-center rounded-full bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-700 ring-1 ring-inset ring-slate-200">
                Content update
              </span>
              <%= agency_task_status_badge(task) %>
            </div>

            <h2 class="mt-3 text-lg font-semibold tracking-tight text-slate-900 break-words">
              <%= task.title %>
            </h2>

            <% if task.description.present? %>
              <p class="mt-2 text-sm leading-6 text-slate-600 whitespace-pre-wrap break-words">
                <%= task.description %>
              </p>
            <% end %>

            <div class="mt-4 flex flex-wrap gap-x-5 gap-y-2 text-xs text-slate-500">
              <span>External ID: <%= task.external_id %></span>
              <% if task.business.present? %>
                <span>
                  Business:
                  <%= link_to task.business.name, admin_business_path(task.business), class: "font-medium text-blue-600 hover:text-blue-500" %>
                </span>
              <% end %>
              <% if task.business_number.present? %>
                <span>Number: <%= task.business_number %></span>
              <% end %>
              <% if task.requester_name.present? || task.requester_email.present? %>
                <span>
                  Requested by:
                  <%= [ task.requester_name, task.requester_email ].compact_blank.join(" · ") %>
                </span>
              <% end %>
              <% if task.requested_at.present? %>
                <span>Requested: <%= l(task.requested_at, format: :short) %></span>
              <% end %>
            </div>

            <% if task.external_url.present? %>
              <div class="mt-4">
                <%= link_to "Open in SitePilot", task.external_url, target: "_blank", rel: "noopener", class: "text-sm font-semibold text-blue-600 hover:text-blue-500" %>
              </div>
            <% end %>
          </div>
        </div>
      </article>
    <% end %>
  <% else %>
    <div class="rounded-2xl bg-white px-6 py-12 text-center shadow-sm ring-1 ring-slate-900/5">
      <h2 class="text-base font-semibold text-slate-900">No tasks yet</h2>
      <p class="mt-2 text-sm text-slate-500">
        <% if @query.present? || @status_filter.present? %>
          Try clearing the filters.
        <% else %>
          When a client submits a content update in SitePilot, it will show up here with details and a link.
        <% end %>
      </p>
    </div>
  <% end %>

  <% if @tasks.any? && @pagy.pages > 1 %>
    <div class="mt-4 flex justify-end">
      <%== pagy_nav(@pagy) %>
    </div>
  <% end %>
</div>
