<%
  field_class = "mt-1 block w-full rounded-lg border-0 px-3 py-2.5 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-green-600 sm:text-sm sm:leading-6"
  select_class = "mt-1 block w-full rounded-lg border-0 px-3 py-2.5 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-green-600 sm:text-sm sm:leading-6"
%>

<% content_for :page_header do %>
  <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <h1 class="text-2xl font-bold tracking-tight text-slate-900">All Invoices</h1>
      <p class="mt-1 text-sm text-slate-600">Review every Stripe invoice across all businesses.</p>
    </div>
    <div class="grid grid-cols-1 gap-3 text-sm sm:grid-cols-3">
      <div class="rounded-lg bg-white px-4 py-3 shadow-sm ring-1 ring-slate-900/5">
        <p class="text-slate-500">Total invoices</p>
        <p class="mt-1 text-lg font-semibold text-slate-900"><%= number_with_delimiter(@total_count) %></p>
      </div>
      <div class="rounded-lg bg-white px-4 py-3 shadow-sm ring-1 ring-slate-900/5">
        <p class="text-slate-500">Paid</p>
        <p class="mt-1 text-lg font-semibold text-emerald-700"><%= number_to_currency(@total_paid) %></p>
      </div>
      <div class="rounded-lg bg-white px-4 py-3 shadow-sm ring-1 ring-slate-900/5">
        <p class="text-slate-500">Pending</p>
        <p class="mt-1 text-lg font-semibold text-amber-700"><%= number_to_currency(@total_pending) %></p>
      </div>
    </div>
  </div>
<% end %>

<div class="mb-6 rounded-xl bg-white px-4 py-4 shadow-sm ring-1 ring-slate-900/5 sm:px-6">
  <%= form_with url: admin_payment_invoices_path, method: :get, local: true, class: "grid grid-cols-1 gap-4 lg:grid-cols-4 lg:items-end" do |f| %>
    <div class="lg:col-span-2">
      <%= f.label :q, "Search", class: "block text-sm font-medium leading-6 text-slate-900" %>
      <%= f.text_field :q, value: params[:q], class: field_class, placeholder: "Search by business name or email" %>
    </div>

    <div>
      <%= f.label :status, "Status", class: "block text-sm font-medium leading-6 text-slate-900" %>
      <%= f.select :status, options_for_select([ [ "All statuses", "" ] ] + PaymentInvoice::STATUSES.map { |status| [ status.titleize, status ] }, params[:status]), {}, class: select_class %>
    </div>

    <div>
      <%= f.label :kind, "Type", class: "block text-sm font-medium leading-6 text-slate-900" %>
      <%= f.select :kind, options_for_select([ [ "All types", "" ] ] + PaymentInvoice::KINDS.map { |key, label| [ label, key ] }, params[:kind]), {}, class: select_class %>
    </div>

    <div class="flex flex-wrap gap-2 lg:col-span-4">
      <%= f.submit "Apply filters", class: "rounded-md bg-green-600 px-3 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-green-500" %>
      <% if params[:q].present? || params[:status].present? || params[:kind].present? %>
        <%= link_to "Clear", admin_payment_invoices_path, class: "rounded-md bg-white px-3 py-2.5 text-sm font-semibold text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 hover:bg-slate-50" %>
      <% end %>
    </div>
  <% end %>
</div>

<div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-slate-900/5">
  <div class="overflow-x-auto">
    <table class="min-w-[1500px] divide-y divide-slate-300">
      <thead class="bg-slate-50">
        <tr>
          <th class="py-3.5 pl-4 pr-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-600 sm:pl-6">Record</th>
          <th class="py-3.5 pl-4 pr-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-600 sm:pl-6">Business</th>
          <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Type</th>
          <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Amount</th>
          <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Status</th>
          <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Delivery</th>
          <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Terms</th>
          <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Billing</th>
          <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Sent To</th>
          <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Created</th>
          <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Updated</th>
          <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Sent</th>
          <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Opened</th>
          <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Paid</th>
          <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Follow-up</th>
          <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Stripe IDs</th>
          <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Links</th>
          <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Last Error</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200 bg-white">
        <% @invoices.each do |invoice| %>
          <tr class="hover:bg-slate-50">
            <td class="py-4 pl-4 pr-3 text-sm text-slate-600 sm:pl-6">
              <div class="whitespace-nowrap font-medium text-slate-900">#<%= invoice.id %></div>
              <div class="mt-1 max-w-40 truncate text-xs" title="<%= invoice.payment_token %>"><%= invoice.payment_token %></div>
            </td>
            <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium">
              <%= link_to invoice.business.name, admin_business_path(invoice.business), class: "text-green-700 hover:text-green-600 hover:underline" %>
              <div class="mt-1 text-xs font-normal text-slate-500"><%= invoice.business.email.presence || "-" %></div>
            </td>
            <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-600"><%= invoice.kind_label %></td>
            <td class="whitespace-nowrap px-3 py-4 text-sm font-medium text-slate-900"><%= number_to_currency(invoice.amount, unit: invoice.currency.upcase == "USD" ? "$" : "#{invoice.currency.upcase} ") %></td>
            <td class="whitespace-nowrap px-3 py-4 text-sm">
              <span class="inline-flex items-center rounded-md px-2 py-1 text-xs font-medium ring-1 ring-inset <%= invoice.status == 'paid' ? 'bg-emerald-50 text-emerald-700 ring-emerald-600/20' : invoice.status == 'failed' ? 'bg-red-50 text-red-700 ring-red-600/20' : invoice.status == 'opened' ? 'bg-amber-50 text-amber-700 ring-amber-600/20' : 'bg-blue-50 text-blue-700 ring-blue-600/20' %>">
                <%= invoice.status_label %>
              </span>
            </td>
            <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-600"><%= invoice.delivery_method_label %></td>
            <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-600"><%= pluralize(invoice.days_until_due, "day") %></td>
            <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-600"><%= invoice.billing_interval.to_s.titleize %></td>
            <td class="px-3 py-4 text-sm text-slate-600">
              <div class="max-w-48 space-y-1">
                <div class="truncate" title="<%= invoice.sent_to_email %>"><%= invoice.sent_to_email.presence || "-" %></div>
                <div class="truncate text-xs text-slate-500" title="<%= invoice.sent_to_phone %>"><%= invoice.sent_to_phone.presence || "-" %></div>
              </div>
            </td>
            <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-600"><%= l(invoice.created_at, format: :short) %></td>
            <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-600"><%= l(invoice.updated_at, format: :short) %></td>
            <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-600"><%= invoice.sent_at.present? ? l(invoice.sent_at, format: :short) : "-" %></td>
            <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-600"><%= invoice.opened_at.present? ? l(invoice.opened_at, format: :short) : "-" %></td>
            <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-600"><%= invoice.paid_at.present? ? l(invoice.paid_at, format: :short) : "-" %></td>
            <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-600"><%= invoice.followup_sent_at.present? ? l(invoice.followup_sent_at, format: :short) : "-" %></td>
            <td class="px-3 py-4 text-xs text-slate-600">
              <div class="max-w-56 space-y-1">
                <div class="truncate" title="<%= invoice.stripe_invoice_id %>">Invoice: <%= invoice.stripe_invoice_id.presence || "-" %></div>
                <div class="truncate" title="<%= invoice.stripe_customer_id %>">Customer: <%= invoice.stripe_customer_id.presence || "-" %></div>
                <div class="truncate" title="<%= invoice.stripe_subscription_id %>">Subscription: <%= invoice.stripe_subscription_id.presence || "-" %></div>
                <div class="truncate" title="<%= invoice.stripe_product_id %>">Product: <%= invoice.stripe_product_id.presence || "-" %></div>
                <div class="truncate" title="<%= invoice.stripe_price_id %>">Price: <%= invoice.stripe_price_id.presence || "-" %></div>
              </div>
            </td>
            <td class="px-3 py-4 text-sm">
              <div class="flex flex-col items-start gap-1">
                <% if invoice.hosted_invoice_url.present? %>
                  <%= link_to "Hosted invoice", invoice.paid? ? invoice.hosted_invoice_url : payment_invoice_link_url(invoice.payment_token), target: "_blank", rel: "noopener", class: "font-medium text-green-700 hover:text-green-600" %>
                <% end %>
                <% if invoice.invoice_pdf.present? %>
                  <%= link_to "PDF", invoice.invoice_pdf, target: "_blank", rel: "noopener", class: "font-medium text-green-700 hover:text-green-600" %>
                <% end %>
                <% if invoice.receipt_url.present? %>
                  <%= link_to "Receipt", invoice.receipt_url, target: "_blank", rel: "noopener", class: "font-medium text-green-700 hover:text-green-600" %>
                <% end %>
                <% if invoice.hosted_invoice_url.blank? && invoice.invoice_pdf.blank? && invoice.receipt_url.blank? %>
                  <span class="text-slate-500">-</span>
                <% end %>
              </div>
            </td>
            <td class="px-3 py-4 text-sm text-slate-600">
              <div class="max-w-64 truncate" title="<%= invoice.last_error %>"><%= invoice.last_error.presence || "-" %></div>
            </td>
          </tr>
        <% end %>
        <% if @invoices.empty? %>
          <tr>
            <td colspan="18" class="px-3 py-12 text-center text-sm text-slate-500">No invoices found.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<% if @pagy.pages > 1 %>
  <div class="mt-4 flex justify-end">
    <%== pagy_nav(@pagy) %>
  </div>
<% end %>
