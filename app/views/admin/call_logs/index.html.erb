<%
  field_class = "mt-1 block w-full rounded-lg border-0 px-3 py-2.5 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-orange-600 sm:text-sm sm:leading-6"
  select_class = "mt-1 block w-full rounded-lg border-0 px-3 py-2.5 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-orange-600 sm:text-sm sm:leading-6"
%>

<% content_for :page_header do %>
  <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <h1 class="text-2xl font-bold tracking-tight text-slate-900">Call Logs</h1>
      <p class="mt-1 text-sm text-slate-600">See which employee called which business, with direction, status, and duration.</p>
    </div>
    <div class="grid grid-cols-1 gap-3 text-sm sm:grid-cols-3">
      <div class="rounded-lg bg-white px-4 py-3 shadow-sm ring-1 ring-slate-900/5">
        <p class="text-slate-500">Total calls</p>
        <p class="mt-1 text-lg font-semibold text-slate-900"><%= number_with_delimiter(@total_calls) %></p>
      </div>
      <div class="rounded-lg bg-white px-4 py-3 shadow-sm ring-1 ring-slate-900/5">
        <p class="text-slate-500">Outbound</p>
        <p class="mt-1 text-lg font-semibold text-blue-700"><%= number_with_delimiter(@outbound_count) %></p>
      </div>
      <div class="rounded-lg bg-white px-4 py-3 shadow-sm ring-1 ring-slate-900/5">
        <p class="text-slate-500">Inbound</p>
        <p class="mt-1 text-lg font-semibold text-emerald-700"><%= number_with_delimiter(@inbound_count) %></p>
      </div>
    </div>
  </div>
<% end %>

<div class="mb-6 rounded-xl bg-white px-4 py-4 shadow-sm ring-1 ring-slate-900/5 sm:px-6">
  <%= form_with url: admin_call_logs_path, method: :get, local: true, class: "grid grid-cols-1 gap-4 lg:grid-cols-5 lg:items-end" do |f| %>
    <div class="lg:col-span-2">
      <%= f.label :q, "Search", class: "block text-sm font-medium leading-6 text-slate-900" %>
      <%= f.text_field :q, value: params[:q], class: field_class, placeholder: "Business, employee, phone, or SID" %>
    </div>

    <div>
      <%= f.label :user_id, "Employee", class: "block text-sm font-medium leading-6 text-slate-900" %>
      <%= f.select :user_id,
            options_from_collection_for_select(@employee_options, :id, :display_name, params[:user_id]),
            { include_blank: "All employees" },
            class: select_class %>
    </div>

    <div>
      <%= f.label :direction, "Direction", class: "block text-sm font-medium leading-6 text-slate-900" %>
      <%= f.select :direction, options_for_select([ [ "All directions", "" ], [ "Inbound", "inbound" ], [ "Outbound", "outbound" ] ], params[:direction]), {}, class: select_class %>
    </div>

    <div class="flex flex-wrap gap-2">
      <%= f.submit "Apply filters", class: "rounded-md bg-orange-600 px-3 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-orange-500" %>
      <% if params[:q].present? || params[:direction].present? || params[:user_id].present? %>
        <%= link_to "Clear", admin_call_logs_path, class: "rounded-md bg-white px-3 py-2.5 text-sm font-semibold text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 hover:bg-slate-50" %>
      <% end %>
    </div>
  <% end %>
</div>

<div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-slate-900/5">
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-slate-300">
      <thead class="bg-slate-50">
        <tr>
          <th class="py-3.5 pl-4 pr-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-600 sm:pl-6">Employee</th>
          <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Business</th>
          <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Direction</th>
          <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">From</th>
          <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">To</th>
          <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Status</th>
          <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Duration</th>
          <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Call SID</th>
          <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Logged</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200 bg-white">
        <% @call_logs.each do |call_log| %>
          <tr class="hover:bg-slate-50">
            <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-slate-900 sm:pl-6">
              <%= call_log.employee_name %>
            </td>
            <td class="whitespace-nowrap px-3 py-4 text-sm font-medium">
              <% if call_log.business.present? %>
                <%= link_to call_log.business.name, admin_business_path(call_log.business), class: "text-orange-700 hover:text-orange-600 hover:underline" %>
              <% else %>
                <span class="text-slate-500">Unknown business</span>
              <% end %>
            </td>
            <td class="whitespace-nowrap px-3 py-4 text-sm">
              <span class="inline-flex items-center rounded-md px-2 py-1 text-xs font-medium ring-1 ring-inset <%= call_log.direction == 'inbound' ? 'bg-emerald-50 text-emerald-700 ring-emerald-600/20' : 'bg-blue-50 text-blue-700 ring-blue-600/20' %>">
                <%= call_log.direction_label %>
              </span>
            </td>
            <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-600"><%= call_log.from_number.presence || "-" %></td>
            <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-600"><%= call_log.to_number.presence || "-" %></td>
            <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-600"><%= call_log.status.to_s.titleize.presence || "-" %></td>
            <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-600"><%= call_log.duration_label %></td>
            <td class="px-3 py-4 text-xs text-slate-600">
              <div class="max-w-64 truncate" title="<%= call_log.sid %>"><%= call_log.sid.presence || "-" %></div>
            </td>
            <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-600"><%= call_log.logged_at.present? ? l(call_log.logged_at, format: :short) : "-" %></td>
          </tr>
        <% end %>
        <% if @call_logs.empty? %>
          <tr>
            <td colspan="9" class="px-3 py-12 text-center text-sm text-slate-500">No call logs found.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<% if @pagy.pages > 1 %>
  <div class="mt-4 flex justify-end">
    <%== pagy_nav(@pagy) %>
  </div>
<% end %>
