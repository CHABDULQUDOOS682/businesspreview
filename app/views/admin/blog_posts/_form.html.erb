<% field_class = "block w-full rounded-xl border-0 px-3.5 py-2.5 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6" %>

<%= form_with(model: [:admin, blog_post], class: "space-y-6", html: { multipart: true }) do |f| %>
  <% if blog_post.errors.any? %>
    <div class="rounded-xl bg-red-50 p-4 ring-1 ring-inset ring-red-200">
      <h3 class="text-sm font-medium text-red-800">There were errors with your submission</h3>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-red-700">
        <% blog_post.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-2">
    <%= f.label :title, class: "block text-sm font-semibold text-slate-900" %>
    <%= f.text_field :title, class: field_class, placeholder: "Post title" %>
  </div>

  <div class="grid gap-6 md:grid-cols-2">
    <div class="space-y-2">
      <%= f.label :slug, class: "block text-sm font-semibold text-slate-900" %>
      <%= f.text_field :slug, class: field_class, placeholder: "auto-from-title" %>
      <p class="text-xs text-slate-500">Used for /blog/:slug when the article body is filled in.</p>
    </div>

    <div class="space-y-2">
      <%= f.label :category, class: "block text-sm font-semibold text-slate-900" %>
      <%= f.text_field :category, class: field_class, placeholder: "e.g. Design" %>
    </div>
  </div>

  <div class="space-y-2">
    <%= f.label :excerpt, class: "block text-sm font-semibold text-slate-900" %>
    <%= f.text_area :excerpt, rows: 3, class: field_class, placeholder: "Short summary shown on the blog index" %>
  </div>

  <div class="space-y-2">
    <%= f.label :featured_image, "Feature image", class: "block text-sm font-semibold text-slate-900" %>
    <%= f.file_field :featured_image, accept: "image/png,image/jpeg,image/webp,image/gif", class: "block w-full text-sm text-slate-600 file:mr-4 file:rounded-full file:border-0 file:bg-blue-50 file:px-4 file:py-2 file:text-sm file:font-semibold file:text-blue-700 hover:file:bg-blue-100" %>
    <p class="text-xs text-slate-500">Shown on the blog index and at the top of the article. PNG, JPG, WEBP, or GIF up to 5 MB.</p>

    <% if blog_post.featured_image.attached? %>
      <div class="mt-3 flex items-start gap-4 rounded-xl border border-slate-200 bg-slate-50 p-3">
        <%= image_tag blog_post.featured_image, class: "h-24 w-40 rounded-lg object-cover ring-1 ring-slate-200", alt: "" %>
        <label class="flex items-center gap-2 pt-1 text-sm text-slate-700">
          <%= check_box_tag "blog_post[remove_featured_image]", "1", false %>
          Remove current image
        </label>
      </div>
    <% end %>
  </div>

  <div class="grid gap-6 md:grid-cols-2">
    <div class="space-y-2">
      <%= f.label :read_time_label, class: "block text-sm font-semibold text-slate-900" %>
      <%= f.text_field :read_time_label, class: field_class, placeholder: "5 min read" %>
    </div>

    <div class="space-y-2">
      <%= f.label :published_on, class: "block text-sm font-semibold text-slate-900" %>
      <%= f.date_field :published_on, class: field_class %>
    </div>
  </div>

  <div class="blog-editor space-y-2">
    <%= f.label :body, "Article body (optional)", class: "block text-sm font-semibold text-slate-900" %>
    <p class="text-xs text-slate-500">Leave blank to show a “Coming soon” card. Fill this in to publish a readable article at /blog/:slug. Use the paperclip button in the toolbar to insert images into the article.</p>
    <div class="mt-2">
      <%= f.rich_text_area :body %>
    </div>
  </div>

  <div class="grid gap-6 md:grid-cols-2">
    <div class="space-y-2">
      <%= f.label :meta_title, class: "block text-sm font-semibold text-slate-900" %>
      <%= f.text_field :meta_title, class: field_class, placeholder: "Overrides the browser/search title" %>
    </div>
    <div class="space-y-2">
      <%= f.label :meta_description, class: "block text-sm font-semibold text-slate-900" %>
      <%= f.text_field :meta_description, class: field_class, placeholder: "Shown in search results (150-160 chars)" %>
    </div>
  </div>

  <div class="flex items-center gap-3">
    <%= f.check_box :active, class: "h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-blue-600" %>
    <%= f.label :active, "Show this post on the website", class: "text-sm font-medium text-slate-900" %>
  </div>

  <div class="flex items-center justify-end gap-3 border-t border-slate-100 pt-6">
    <%= link_to "Cancel", admin_blog_posts_path, class: "text-sm font-semibold text-slate-600 hover:text-slate-900" %>
    <%= f.submit class: "rounded-full bg-blue-600 px-6 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-blue-500" %>
  </div>
<% end %>
