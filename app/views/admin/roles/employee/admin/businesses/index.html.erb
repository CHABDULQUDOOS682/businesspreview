<%
  tabs = Business::SEGMENTS.map do |key, label|
    {
      key: key,
      label: label,
      count: @segment_counts.fetch(key, 0),
      path: admin_businesses_path(segment: key)
    }
  end
  filter_input_class = "mt-1 block w-full rounded-lg border-0 px-3 py-2.5 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6"
  filter_select_class = "mt-1 block w-full rounded-lg border-0 px-3 py-2.5 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6"
%>

<% content_for :page_header do %>
  <div class="sm:flex sm:items-start sm:justify-between">
    <div class="sm:flex-auto">
      <h1 class="text-2xl font-semibold leading-6 text-slate-900">Businesses</h1>
      <p class="mt-1 text-sm text-slate-600">
        Manage your pipeline by lifecycle stage, with neutral leads, one-time website sales, and active subscriptions.
      </p>
    </div>
  </div>
<% end %>

<div class="mt-6 bg-white px-4 py-4 shadow-sm ring-1 ring-slate-900/5 sm:rounded-xl sm:px-6">
  <%= render "admin/shared/business_segment_tabs", tabs: tabs, current_segment: @segment %>

  <div class="mt-5">
    <%= form_with url: admin_businesses_path, method: :get, local: true, class: "grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-5 items-end" do |f| %>
      <%= hidden_field_tag :segment, @segment %>

      <div>
        <%= f.label :name, "Name", class: "block text-sm font-medium leading-6 text-slate-900" %>
        <%= f.text_field :name, value: params[:name], class: filter_input_class, placeholder: "Search business name" %>
      </div>

      <div>
        <%= f.label :niche, "Niche", class: "block text-sm font-medium leading-6 text-slate-900" %>
        <%= f.select :niche, options_for_select(@niches, params[:niche]), { include_blank: "All niches" }, class: filter_select_class %>
      </div>

      <div>
        <%= f.label :city, "City", class: "block text-sm font-medium leading-6 text-slate-900" %>
        <%= f.select :city, options_for_select(@cities, params[:city]), { include_blank: "All cities" }, class: filter_select_class %>
      </div>

      <div>
        <%= f.label :country, "Country", class: "block text-sm font-medium leading-6 text-slate-900" %>
        <%= f.select :country, options_for_select(@countries, params[:country]), { include_blank: "All countries" }, class: filter_select_class %>
      </div>

      <div class="flex flex-wrap gap-2">
        <%= f.submit "Apply filters", class: "rounded-md bg-white px-3 py-2.5 text-sm font-semibold text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 hover:bg-slate-50" %>
        <% if params[:name].present? || params[:niche].present? || params[:city].present? || params[:country].present? %>
          <%= link_to "Clear", admin_businesses_path(segment: @segment), class: "rounded-md bg-white px-3 py-2.5 text-sm font-semibold text-red-600 shadow-sm ring-1 ring-inset ring-slate-300 hover:bg-slate-50 hover:text-red-700" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<div class="mt-8 flow-root">
  <div class="-mx-4 -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
    <div class="inline-block min-w-full py-2 align-middle sm:px-6 lg:px-8">
      <div class="overflow-hidden shadow ring-1 ring-black ring-opacity-5 sm:rounded-lg">
        <table class="min-w-full divide-y divide-slate-300">
          <thead class="bg-slate-50">
            <tr>
              <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-slate-900 sm:pl-6">Business Name</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Status</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">City & Country</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Niche</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Total Visits</th>
              <th scope="col" class="relative py-3.5 pl-3 pr-4 sm:pr-6">
                <span class="sr-only">View</span>
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200 bg-white">
            <% @businesses.each do |b| %>
              <tr class="hover:bg-slate-50">
                <td class="py-4 pl-4 pr-3 text-sm font-medium text-slate-900 sm:pl-6">
                  <div class="max-w-xs break-words"><%= b.name %></div>
                </td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-500">
                  <% badge_classes = case b.business_segment
                    when "subscriptions" then "bg-amber-50 text-amber-700 ring-amber-600/20"
                    when "purchased" then "bg-blue-50 text-blue-700 ring-blue-600/20"
                    else "bg-emerald-50 text-emerald-700 ring-emerald-600/20"
                  end %>
                  <span class="inline-flex items-center rounded-md px-2 py-1 text-xs font-medium ring-1 ring-inset <%= badge_classes %>">
                    <%= b.business_segment_label %>
                  </span>
                </td>
                <td class="px-3 py-4 text-sm text-slate-500"><%= [b.city, b.country].compact.join(", ").presence || "Unknown" %></td>
                <td class="px-3 py-4 text-sm text-slate-500"><%= b.niche.presence || "-" %></td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-500">
                  <span class="<%= b.visit_count.to_i > 0 ? 'inline-flex items-center rounded-md bg-green-50 px-2 py-1 text-xs font-medium text-green-700 ring-1 ring-inset ring-green-600/20' : 'text-slate-500' %>">
                    <%= b.visit_count %>
                  </span>
                </td>
                <td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-6">
                  <%= link_to "View<span class='sr-only'>, #{b.name}</span>".html_safe, admin_business_path(b), class: "text-blue-600 hover:text-blue-900" %>
                </td>
              </tr>
            <% end %>
            <% if @businesses.empty? %>
              <tr>
                <td colspan="6" class="px-3 py-8 text-center text-sm text-slate-500">No businesses found in this tab yet. Adjust filters or add a new business.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <% if @pagy.pages > 1 %>
        <div class="mt-4 flex justify-end">
          <%== pagy_nav(@pagy) %>
        </div>
      <% end %>
    </div>
  </div>
</div>
