<% content_for :page_header do %>
  <div class="md:flex md:items-center md:justify-between">
    <div class="min-w-0 flex-1">
      <div class="flex items-center gap-x-3 text-sm text-slate-500 mb-1">
        <%= link_to "Businesses", admin_businesses_path, class: "hover:text-slate-700" %>
        <svg viewBox="0 0 2 2" class="h-0.5 w-0.5 fill-current"><circle cx="1" cy="1" r="1" /></svg>
        <span>Business Details</span>
      </div>
      <h2 class="text-2xl font-bold leading-7 text-slate-900 sm:truncate"><%= @business.name %></h2>
    </div>
  </div>
<% end %>

<div>
  <div class="grid grid-cols-1 items-start gap-x-8 gap-y-8 lg:grid-cols-3">
    <div class="lg:col-span-1 space-y-8">
      <div class="bg-white shadow-sm ring-1 ring-slate-900/5 sm:rounded-xl p-6">
        <dt class="text-sm font-medium leading-6 text-slate-500">Total Pipeline Visits</dt>
        <dd class="mt-2 text-3xl font-bold tracking-tight text-blue-600"><%= @business.visit_count %></dd>
      </div>

      <div class="bg-white px-4 py-5 shadow-sm ring-1 ring-slate-900/5 sm:rounded-xl sm:px-6">
        <%= render "admin/shared/business_profile_actions", business: @business %>
        <dl class="space-y-4 text-sm leading-6">
          <div class="flex justify-between gap-x-4 border-b border-slate-100 pb-4">
            <dt class="text-slate-500">City</dt>
            <dd class="text-slate-900 font-medium"><%= @business.city.presence || "-" %></dd>
          </div>
          <div class="flex justify-between gap-x-4 border-b border-slate-100 pb-4">
            <dt class="text-slate-500">Country</dt>
            <dd class="text-slate-900 font-medium"><%= @business.country.presence || "-" %></dd>
          </div>
          <div class="flex justify-between gap-x-4 border-b border-slate-100 pb-4">
            <dt class="text-slate-500">Business Location</dt>
            <dd class="text-slate-900 font-medium"><%= business_location_link(@business) %></dd>
          </div>
          <div class="flex justify-between gap-x-4 border-b border-slate-100 pb-4">
            <dt class="text-slate-500">Google Rating</dt>
            <dd class="text-slate-900 font-medium"><%= @business.rating.presence || "-" %></dd>
          </div>
          <div class="flex justify-between gap-x-4 border-b border-slate-100 pb-4">
            <dt class="text-slate-500">Business Type</dt>
            <dd class="text-slate-900 font-medium"><%= @business.niche.presence || "-" %></dd>
          </div>
          <div class="flex justify-between gap-x-4 border-b border-slate-100 pb-4">
            <dt class="text-slate-500">Phone</dt>
            <dd class="text-slate-900 font-medium"><%= @business.phone.presence || "-" %></dd>
          </div>
          <div class="flex justify-between gap-x-4 border-b border-slate-100 pb-4">
            <dt class="text-slate-500">Phone Line Type</dt>
            <dd class="text-slate-900 font-medium flex items-center gap-2">
              <%= phone_line_type_badge(@business) %>
              <%= button_to "Verify Number", verify_phone_admin_business_path(@business),
                            method: :post,
                            class: "text-xs text-blue-600 hover:text-blue-900 underline" %>
            </dd>
          </div>
          <div class="flex justify-between gap-x-4 border-b border-slate-100 pb-4">
            <dt class="text-slate-500">Email</dt>
            <dd class="text-slate-900 font-medium">
              <% if @business.try(:email).present? %>
                <%= mail_to @business.email, @business.email, class: "text-blue-600 hover:text-blue-500" %>
              <% else %>
                -
              <% end %>
            </dd>
          </div>
          <div class="flex justify-between gap-x-4 border-b border-slate-100 pb-4">
            <dt class="text-slate-500">Website</dt>
            <dd class="text-slate-900 font-medium">
              <% if @business.try(:website_url).present? %>
                <%= link_to "Visit Site", @business.website_url, target: "_blank", class: "text-blue-600 hover:text-blue-500" %>
              <% else %>
                -
              <% end %>
            </dd>
          </div>
          <div class="flex justify-between gap-x-4 border-b border-slate-100 pb-4">
            <dt class="text-slate-500">Sold Price</dt>
            <dd class="text-slate-900 font-medium">
              <% if @business.try(:sold_price).present? %>
                <%= number_to_currency(@business.sold_price) %>
              <% else %>
                -
              <% end %>
            </dd>
          </div>
          <div class="flex justify-between gap-x-4 border-b border-slate-100 pb-4">
            <dt class="text-slate-500">Sold By</dt>
            <dd class="text-slate-900 font-medium"><%= @business.sold_by&.display_name || "-" %></dd>
          </div>
          <div class="flex justify-between gap-x-4">
            <dt class="text-slate-500">Subscription</dt>
            <dd class="text-slate-900 font-medium">
              <% if @business.try(:subscription).nil? %>
                -
              <% else %>
                <%= @business.subscription ? "Yes" : "No" %>
              <% end %>
            </dd>
          </div>
        </dl>
      </div>

      <%= render "admin/businesses/payment_status_card", business: @business %>
      <%= render "admin/businesses/sitepilot_connection_card", business: @business %>
    </div>

    <div class="lg:col-span-2 space-y-8">
      <%= render "admin/payment_invoices/panel",
                 business: @business,
                 payment_invoice: @payment_invoice,
                 payment_invoices: @payment_invoices %>

      <%= render "admin/preview_links/panel", business: @business %>

      <%= render "admin/meetings/meetings_panel", business: @business %>

      <%= render "admin/notes/notes_panel", business: @business %>
    </div>
  </div>
</div>
