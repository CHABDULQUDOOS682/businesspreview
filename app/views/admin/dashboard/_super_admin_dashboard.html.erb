<section class="portal-panel overflow-hidden bg-gradient-to-br from-white via-sand-50 to-accent-indigo-bg p-6 md:p-8">
  <div class="flex flex-col gap-6 xl:flex-row xl:items-end xl:justify-between">
    <div class="max-w-3xl">
      <p class="portal-kicker"><%= current_role_label %> workspace</p>
      <h1 class="portal-display-title mt-3">Super Admin Dashboard</h1>
      <p class="portal-muted mt-3 max-w-2xl text-sm md:text-base">
        Monitor the full workspace, manage admins and employees, and keep the outreach pipeline moving with a single Standard Portal view.
      </p>
    </div>

    <div class="grid gap-3 sm:grid-cols-2 xl:w-auto">
      <div class="rounded-[22px] border border-sand-200 bg-white/90 px-5 py-4 shadow-sm backdrop-blur">
        <p class="portal-kicker">Team Access</p>
        <p class="mt-3 text-3xl font-semibold text-sand-900"><%= @manageable_user_count %></p>
        <p class="mt-1 text-sm text-sand-600">Admins and employees you can manage</p>
      </div>

      <div class="flex items-end">
        <%= link_to "Add business", new_admin_business_path, class: "btn-base btn-accent-indigo w-full px-4 py-3 text-sm shadow-sm xl:w-auto" %>
      </div>
    </div>
  </div>
</section>

<section class="mt-8">
  <div class="mb-4">
    <p class="portal-kicker">Overview</p>
    <h2 class="portal-page-title mt-2">Workspace metrics</h2>
    <p class="portal-muted mt-2 text-sm">Key activity across outreach, communications, previews, and access management.</p>
  </div>

  <dl class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
    <div class="portal-stat-card">
      <dt class="text-sm font-medium text-sand-500">Total Businesses</dt>
      <dd class="mt-4 text-4xl font-semibold tracking-tight text-sand-900"><%= @business_count %></dd>
    </div>
    <div class="portal-stat-card">
      <dt class="text-sm font-medium text-sand-500">Links generated</dt>
      <dd class="mt-4 text-4xl font-semibold tracking-tight text-accent-indigo"><%= @preview_count %></dd>
    </div>
    <div class="portal-stat-card">
      <dt class="text-sm font-medium text-sand-500">Total Clicks</dt>
      <dd class="mt-4 text-4xl font-semibold tracking-tight text-accent-blue"><%= @total_visits %></dd>
    </div>
    <div class="portal-stat-card">
      <dt class="text-sm font-medium text-sand-500">Unread Messages</dt>
      <dd id="unread_inbound_count" class="mt-4 text-4xl font-semibold tracking-tight text-accent-green">
        <%= render partial: "admin/dashboard/unread_inbound_count", locals: { count: @unread_inbound_count } %>
      </dd>
    </div>
  </dl>
</section>

<section class="mt-4">
  <dl class="grid grid-cols-1 gap-4 md:grid-cols-2">
    <div class="portal-stat-card">
      <dt class="text-sm font-medium text-sand-500">Admins</dt>
      <dd class="mt-4 text-4xl font-semibold tracking-tight text-accent-blue"><%= @admin_count %></dd>
    </div>
    <div class="portal-stat-card">
      <dt class="text-sm font-medium text-sand-500">Employees</dt>
      <dd class="mt-4 text-4xl font-semibold tracking-tight text-accent-green"><%= @employee_count %></dd>
    </div>
  </dl>
</section>

<section class="portal-panel mt-8">
  <div class="border-b border-sand-200 px-5 py-4 md:px-6">
    <h3 class="text-base font-semibold text-sand-900">Available Templates</h3>
  </div>
  <div class="max-h-52 overflow-y-auto px-5 py-5 md:px-6">
    <div class="flex flex-wrap gap-2">
      <% @templates.each do |template| %>
        <%= link_to admin_template_preview_path(template), target: "_blank", class: "inline-flex items-center gap-2 rounded-full border border-sand-200 bg-sand-50 px-3 py-1.5 text-xs font-medium text-sand-700 transition hover:border-accent-indigo hover:text-accent-indigo" do %>
          <span class="h-1.5 w-1.5 rounded-full bg-accent-indigo"></span>
          <%= template.titleize %>
        <% end %>
      <% end %>
    </div>
  </div>
</section>

<section class="mt-8 grid grid-cols-1 gap-6 xl:grid-cols-2">
  <div class="portal-panel overflow-hidden">
    <div class="flex items-center justify-between border-b border-sand-200 px-5 py-4 md:px-6">
      <h3 class="text-base font-semibold text-sand-900">Recent Engagement</h3>
    </div>
    <ul role="list" class="divide-y divide-sand-200">
      <% if @recent_clicks.any? %>
        <% @recent_clicks.each do |link| %>
          <li class="flex items-center justify-between gap-4 px-5 py-5 transition hover:bg-sand-50 md:px-6">
            <div class="min-w-0 flex-1">
              <div class="mb-2 flex flex-wrap items-center gap-2">
                <p class="text-sm font-semibold text-sand-900"><%= link.business.name %></p>
                <span class="inline-flex items-center rounded-full bg-accent-green-bg px-2.5 py-1 text-xs font-medium text-accent-green">Clicked on <%= link.template %></span>
              </div>
              <p class="text-xs text-sand-500"><%= time_ago_in_words(link.clicked_at) %> ago</p>
            </div>
            <%= link_to "View", admin_business_path(link.business), class: "btn-base btn-sand px-3 py-2 text-sm shadow-sm" %>
          </li>
        <% end %>
      <% else %>
        <li class="px-5 py-10 text-center text-sm text-sand-500 md:px-6">No clicks tracked yet. Send out some links to start filling this feed.</li>
      <% end %>
    </ul>
  </div>

  <div class="portal-panel overflow-hidden">
    <div class="flex items-center justify-between border-b border-sand-200 px-5 py-4 md:px-6">
      <h3 class="text-base font-semibold text-sand-900">Recent Businesses</h3>
      <%= link_to "View all", admin_businesses_path, class: "text-sm font-semibold text-accent-indigo hover:text-accent-blue" %>
    </div>
    <ul role="list" class="divide-y divide-sand-200">
      <% if @recent_businesses.any? %>
        <% @recent_businesses.each do |business| %>
          <li class="flex items-center justify-between gap-4 px-5 py-5 transition hover:bg-sand-50 md:px-6">
            <div class="min-w-0 flex-1">
              <p class="text-sm font-semibold text-sand-900">
                <%= link_to business.name, admin_business_path(business) %>
              </p>
              <div class="mt-1 flex flex-wrap items-center gap-2 text-xs text-sand-500">
                <span><%= business.niche.presence || "No niche" %></span>
                <% if business.city.present? %>
                  <span class="h-1 w-1 rounded-full bg-sand-300"></span>
                  <span><%= business.city %></span>
                <% end %>
              </div>
            </div>
          </li>
        <% end %>
      <% else %>
        <li class="px-5 py-10 text-center text-sm text-sand-500 md:px-6">No businesses added yet.</li>
      <% end %>
    </ul>
  </div>
</section>

<section class="portal-panel mt-8 overflow-hidden">
  <div class="flex items-center justify-between border-b border-sand-200 px-5 py-4 md:px-6">
    <h3 class="text-base font-semibold text-sand-900">Recent Team Accounts</h3>
    <%= link_to "Manage users", admin_users_path, class: "text-sm font-semibold text-accent-indigo hover:text-accent-blue" %>
  </div>
  <ul role="list" class="divide-y divide-sand-200">
    <% if @recent_users.any? %>
      <% @recent_users.each do |user| %>
        <li class="flex items-center justify-between gap-4 px-5 py-5 transition hover:bg-sand-50 md:px-6">
          <div class="min-w-0 flex-1">
            <p class="text-sm font-semibold text-sand-900"><%= user.email %></p>
            <p class="mt-1 text-xs text-sand-500">Created <%= time_ago_in_words(user.created_at) %> ago</p>
          </div>
          <% badge_classes = case user.role
            when "super_admin" then "bg-accent-purple-bg text-accent-purple ring-sand-200"
            when "admin" then "bg-accent-blue-bg text-accent-blue ring-sand-200"
            else "bg-accent-green-bg text-accent-green ring-sand-200"
          end %>
          <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-medium ring-1 ring-inset <%= badge_classes %>">
            <%= user.role.humanize %>
          </span>
        </li>
      <% end %>
    <% else %>
      <li class="px-5 py-10 text-center text-sm text-sand-500 md:px-6">No team accounts created yet.</li>
    <% end %>
  </ul>
</section>
