<% content_for :title, "Services | DevDeBizz" %>

<%= render "page_header",
  eyebrow: "Our Services",
  title_html: 'Everything you need <br><span class="home-display-accent">to grow online</span>'.html_safe,
  subtitle: "Six core practices, one accountable team. Engage on a single service or hire us as your full-stack growth partner." %>

<section class="py-20">
  <div class="mx-auto max-w-7xl px-2 md:px-0">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    <% [
      { icon: "fa-code", title: "Web Development", description: "High-performance websites and web apps built with React, Next.js, and Node — engineered for speed, scale, and SEO.", features: ["Custom CMS", "Headless e-commerce", "Web apps & SaaS", "API development"] },
      { icon: "fa-star", title: "Branding & Identity", description: "Distinctive logos, type systems, and brand guidelines that give your company a voice customers remember.", features: ["Logo design", "Visual identity", "Brand guidelines", "Packaging & print"] },
      { icon: "fa-desktop", title: "UI / UX Design", description: "Research-driven product design that turns complex flows into intuitive, conversion-focused experiences.", features: ["User research", "Wireframing", "Design systems", "Prototyping"] },
      { icon: "fa-magnifying-glass", title: "SEO & Content", description: "Technical SEO, keyword strategy, and editorial content that earn rankings, traffic, and qualified leads.", features: ["Technical SEO audit", "Content strategy", "Link building", "Local SEO"] },
      { icon: "fa-chart-line", title: "Performance Marketing", description: "Data-driven Google, Meta, and LinkedIn ad campaigns optimized weekly for ROAS with transparent dashboards.", features: ["Google Ads", "Meta Ads", "LinkedIn Ads", "Analytics & reporting"] },
      { icon: "fa-cloud", title: "Cloud & DevOps", description: "Scalable AWS, GCP, and Vercel infrastructure with CI/CD, monitoring, and zero-downtime deployments.", features: ["Cloud architecture", "CI/CD pipelines", "Monitoring & alerts", "Cost optimization"] }
    ].each_with_index do |service, index| %>
      <div class="home-glass home-card-3d rounded-[28px] p-8 animate-fade-up" style="animation-delay: <%= index * 0.06 %>s;">
        <div class="inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-[#213885]/18 to-[#893172]/10 ring-1 ring-[#213885]/20">
          <i class="fa-solid <%= service[:icon] %> text-xl text-[#5F3475]"></i>
        </div>
        <h2 class="mt-5 text-2xl font-bold text-[#081849]"><%= service[:title] %></h2>
        <p class="mt-3 text-sm leading-relaxed text-[#081849]/66"><%= service[:description] %></p>
        <ul class="mt-5 space-y-2">
          <% service[:features].each do |feature| %>
            <li class="flex items-center gap-2 text-sm text-[#081849]/72">
              <span class="h-1.5 w-1.5 rounded-full bg-[#213885]"></span>
              <%= feature %>
            </li>
          <% end %>
        </ul>
        <%= link_to contact_path, class: "mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-[#5F3475] transition hover:gap-3" do %>
          Get a quote <span>→</span>
        <% end %>
      </div>
    <% end %>
  </div>
</section>

<section class="relative overflow-hidden border-y border-[#081849]/8 bg-[#CCCACC]/45 py-24">
  <div class="home-grid-bg absolute inset-0 opacity-30"></div>
  <div class="relative mx-auto max-w-7xl px-2 md:px-0 text-center">
    <h2 class="text-4xl font-extrabold text-[#081849] md:text-5xl">Built for outcomes, not <span class="text-[#5F3475]">deliverables.</span></h2>
    <p class="mt-6 text-lg text-[#081849]/70">
      Every engagement starts with a clear KPI — traffic, signups, revenue, retention. We don't ship features; we ship results, measured weekly and reported transparently.
    </p>
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      <% [["Weekly", "Reporting"], ["Quarterly", "Strategy reviews"], ["24h", "Response SLA"]].each do |number, label| %>
        <div class="home-glass home-card-3d rounded-[28px] p-8">
          <p class="bg-gradient-to-br from-[#213885] to-[#893172] bg-clip-text text-4xl font-extrabold text-transparent"><%= number %></p>
          <p class="mt-2 text-sm text-[#081849]/68"><%= label %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>
