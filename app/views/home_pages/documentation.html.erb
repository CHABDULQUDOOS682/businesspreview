<% content_for :title, "Documentation | DevDeBizz" %>
<% content_for :meta_description, "DevDeBizz documentation for using your website dashboard, updating content, and managing day-to-day site operations." %>

<%= render "page_header",
  eyebrow: "Guides & Docs",
  title_html: 'Client and developer <span class="home-display-accent">guides</span>'.html_safe,
  subtitle: "Step-by-step instructions for managing your website, integrating tools, and developer resources." %>

<section class="py-20">
  <div class="mx-auto max-w-7xl px-2 md:px-0">
    <div class="grid gap-6 md:grid-cols-3">
      <div class="home-glass home-card-3d rounded-[28px] p-8 flex flex-col justify-between">
        <div>
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[#213885]/8 text-[#5F3475]">
            <i class="fa-solid fa-book-open text-xl"></i>
          </div>
          <h3 class="mt-6 text-2xl font-bold text-[#081849]">User Manuals</h3>
          <p class="mt-3 text-sm leading-relaxed text-[#081849]/66">Learn how to manage your website content, update service lists, customize text descriptions, and upload new image galleries yourself.</p>
        </div>
        <div class="mt-6 pt-4 border-t border-[#081849]/8">
          <%= link_to "#", class: "text-sm font-bold text-[#213885] hover:text-[#5F3475] inline-flex items-center gap-1" do %>
            View Manuals &rarr;
          <% end %>
        </div>
      </div>

      <div class="home-glass home-card-3d rounded-[28px] p-8 flex flex-col justify-between">
        <div>
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[#213885]/8 text-[#5F3475]">
            <i class="fa-solid fa-wallet text-xl"></i>
          </div>
          <h3 class="mt-6 text-2xl font-bold text-[#081849]">Billing Portals</h3>
          <p class="mt-3 text-sm leading-relaxed text-[#081849]/66">Step-by-step guides on reviewing invoice statements, downloading PDF receipts, updating payment details, and editing Stripe subscriptions.</p>
        </div>
        <div class="mt-6 pt-4 border-t border-[#081849]/8">
          <%= link_to "#", class: "text-sm font-bold text-[#213885] hover:text-[#5F3475] inline-flex items-center gap-1" do %>
            View Billing Guides &rarr;
          <% end %>
        </div>
      </div>

      <div class="home-glass home-card-3d rounded-[28px] p-8 flex flex-col justify-between">
        <div>
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[#213885]/8 text-[#5F3475]">
            <i class="fa-solid fa-terminal text-xl"></i>
          </div>
          <h3 class="mt-6 text-2xl font-bold text-[#081849]">Developer APIs</h3>
          <p class="mt-3 text-sm leading-relaxed text-[#081849]/66">Technical specifications for Twilio SMS webhook configuration, Stripe hook sync, and exporting lead details to CRM platforms.</p>
        </div>
        <div class="mt-6 pt-4 border-t border-[#081849]/8">
          <%= link_to "#", class: "text-sm font-bold text-[#213885] hover:text-[#5F3475] inline-flex items-center gap-1" do %>
            View API Docs &rarr;
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
