<% content_for :title, "Brand Kit | DevDeBizz" %>

<%= render "page_header",
  eyebrow: "Brand kit",
  title_html: 'Download official <span class="home-display-accent">assets</span>'.html_safe,
  subtitle: "Visual styles, logo vectors, color codes, and assets for co-marketing partnerships." %>

<section class="py-20">
  <div class="mx-auto max-w-7xl px-2 md:px-0">
    <div class="grid gap-8 lg:grid-cols-3">
      <div class="home-glass home-card-3d rounded-[28px] p-8 lg:col-span-2">
        <h2 class="text-2xl font-bold text-[#081849]">Our Colors</h2>
        <p class="mt-2 text-sm text-[#081849]/66">Use the following color values to maintain visual consistency:</p>
        
        <div class="mt-6 grid gap-4 grid-cols-2 sm:grid-cols-4">
          <% [
            { name: "Deep Navy", hex: "#081849", bg: "bg-[#081849]", text: "text-white" },
            { name: "Brand Blue", hex: "#213885", bg: "bg-[#213885]", text: "text-white" },
            { name: "Dark Purple", hex: "#5F3475", bg: "bg-[#5F3475]", text: "text-white" },
            { name: "Warm Cream", hex: "#ECDFD2", bg: "bg-[#ECDFD2]", text: "text-[#081849]" }
          ].each do |color| %>
            <div class="rounded-2xl border border-[#081849]/8 overflow-hidden bg-white text-center">
              <div class="h-16 <%= color[:bg] %>"></div>
              <div class="p-3">
                <p class="font-bold text-sm text-[#081849]"><%= color[:name] %></p>
                <p class="text-xs font-mono text-[#081849]/50 mt-1"><%= color[:hex] %></p>
              </div>
            </div>
          <% end %>
        </div>

        <h2 class="mt-10 text-2xl font-bold text-[#081849]">Typography</h2>
        <p class="mt-2 text-sm text-[#081849]/66">Our primary typeface is <strong>Plus Jakarta Sans</strong>, a modern sans-serif designed for clean layouts.</p>
        <div class="mt-4 p-6 rounded-2xl bg-[#FAF8F5] border border-[#081849]/8 font-sans">
          <p class="text-xl font-extrabold text-[#081849]">Plus Jakarta Sans (ExtraBold) - Headlines</p>
          <p class="text-base font-semibold text-[#081849]/70 mt-2">Plus Jakarta Sans (SemiBold) - Subtitles</p>
          <p class="text-sm leading-relaxed text-[#081849]/66 mt-2">Plus Jakarta Sans (Regular) - Body text is styled at 15px/16px for high legibility across mobile and desktop screens.</p>
        </div>
      </div>

      <div class="space-y-6">
        <div class="home-glass home-card-3d rounded-[28px] p-8">
          <h3 class="text-2xl font-bold text-[#081849]">Logo Downloads</h3>
          <p class="mt-2 text-sm text-[#081849]/66">Download clean logo files for digital and print media.</p>
          
          <div class="mt-6 p-4 rounded-xl border border-[#081849]/8 bg-white flex items-center justify-center">
            <%= image_tag "veloqtech_logo.svg", class: "h-16 w-auto", alt: "DevDeBizz Logo" %>
          </div>

          <ul class="mt-6 space-y-3">
            <li>
              <%= link_to "#", class: "flex items-center gap-2 text-sm font-semibold text-[#213885] hover:text-[#5F3475]" do %>
                <i class="fa-solid fa-download"></i> SVG Logo Mark
              <% end %>
            </li>
            <li>
              <%= link_to "#", class: "flex items-center gap-2 text-sm font-semibold text-[#213885] hover:text-[#5F3475]" do %>
                <i class="fa-solid fa-download"></i> PNG Logo (Dark Text)
              <% end %>
            </li>
            <li>
              <%= link_to "#", class: "flex items-center gap-2 text-sm font-semibold text-[#213885] hover:text-[#5F3475]" do %>
                <i class="fa-solid fa-download"></i> PNG Logo (White Text)
              <% end %>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
