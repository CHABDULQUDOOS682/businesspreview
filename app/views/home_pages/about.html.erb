<% content_for :title, "About | DevDeBizz" %>

<%= render "page_header",
  eyebrow: "About DevDeBizz",
  title_html: 'A focused studio for <span class="home-display-accent">growth-minded local brands</span>'.html_safe,
  subtitle: "We work with service businesses that are ready to move beyond outdated websites, scattered tools, and confusing customer journeys." %>

<section class="py-20">
  <div class="mx-auto max-w-7xl px-2 md:px-0">
    <div class="grid gap-6 lg:grid-cols-5">
      <div class="home-glass home-card-3d rounded-[32px] p-10 lg:col-span-3">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-[#081849]/58">Our point of view</p>
        <h2 class="mt-4 text-4xl font-extrabold text-[#081849]">Good design should make the business easier to run.</h2>
        <p class="mt-5 text-lg leading-relaxed text-[#081849]/68">
          That means the homepage needs to clarify the offer, service pages need to guide decision-making, and the systems behind the site need to support how your team actually works.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-[#081849]/68">
          We build with the realities of local service businesses in mind: mobile visitors, fast trust decisions, booked-call friction, and the need for handoff clarity after launch.
        </p>
      </div>

      <div class="space-y-6 lg:col-span-2">
        <div class="home-card-3d overflow-hidden rounded-[28px] bg-gradient-to-br from-[#123b56] to-[#11255f] p-8 text-[#ECDFD2]">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-[#ECDFD2]/65">Why clients hire us</p>
          <h3 class="mt-3 text-3xl font-extrabold">Clarity, speed, and systems.</h3>
          <p class="mt-3 text-sm leading-relaxed text-[#ECDFD2]/78">You get a partner who thinks about the offer, the page structure, and the back-end workflow at the same time.</p>
        </div>
        <div class="home-glass home-card-3d rounded-[28px] p-8">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-[#081849]/58">Best fit</p>
          <p class="mt-3 text-lg font-semibold text-[#081849]">Barbers, clinics, studios, local agencies, and service-led teams that want a more intentional digital presence.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="relative overflow-hidden border-y border-[#081849]/8 bg-[#CCCACC]/45 py-24">
  <div class="home-grid-bg absolute inset-0 opacity-30"></div>
  <div class="relative mx-auto max-w-7xl px-2 md:px-0">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-[#081849]/58">Our values</p>
      <h2 class="mt-3 text-4xl font-extrabold text-[#081849] md:text-5xl">The way we work</h2>
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-3">
      <% [
        { icon: "fa-bolt", title: "Fast but thoughtful", text: "We move quickly, but we still design around the business goal and the customer journey." },
        { icon: "fa-eye", title: "Clear communication", text: "We keep the process visible, explain tradeoffs, and avoid burying clients in vague updates." },
        { icon: "fa-location-dot", title: "Local-first thinking", text: "We care about how real local buyers browse, compare, and commit on mobile." }
      ].each do |value| %>
        <div class="home-glass home-card-3d rounded-[28px] p-8">
          <i class="fa-solid <%= value[:icon] %> text-2xl text-[#5F3475]"></i>
          <h3 class="mt-5 text-2xl font-bold text-[#081849]"><%= value[:title] %></h3>
          <p class="mt-3 text-sm leading-relaxed text-[#081849]/66"><%= value[:text] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<section class="pt-24">
  <div class="mx-auto max-w-7xl px-2 md:px-0">
    <div class="grid gap-6 md:grid-cols-4">
      <% [["Strategy", "Offer clarity before pixels"], ["Design", "Interfaces that guide action"], ["Build", "Clean, launch-ready implementation"], ["Support", "A steady hand after launch"]].each do |title, text| %>
        <div class="home-glass home-card-3d rounded-[28px] p-6 text-center">
          <p class="text-2xl font-extrabold text-[#081849]"><%= title %></p>
          <p class="mt-2 text-sm text-[#081849]/66"><%= text %></p>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mt-16 text-center">
    <%= link_to contact_path, class: "home-button-primary" do %>
      Let’s Talk About Your Project
    <% end %>
  </div>
</section>
