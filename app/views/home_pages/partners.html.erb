<% content_for :title, "Partners | DevDeBizz" %>

<%= render "page_header",
  eyebrow: "Partner Program",
  title_html: 'Grow your business <span class="home-display-accent">with our network</span>'.html_safe,
  subtitle: "Collaborate with DevDeBizz to offer advanced website architecture, CRM setups, and follow-up channels to your client roster." %>

<section class="py-20">
  <div class="mx-auto max-w-7xl px-2 md:px-0">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-[#081849]/58">Collaboration Types</p>
      <h2 class="mt-3 text-4xl font-extrabold text-[#081849]">Three ways to partner with us</h2>
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-3">
      <% [
        { icon: "fa-money-bill-trend-up", title: "Referral Program", desc: "Introduce clients who need a new site, billing integrations, or automations. Receive 15% commission on their setup fee upon launch.", action: "Sign up as Partner" },
        { icon: "fa-object-group", title: "White-Label Dev", desc: "Keep your client relationships and visual designs. We do the Rails development, Stripe connection, and Twilio hookups in the background.", action: "Discuss White-label" },
        { icon: "fa-network-wired", title: "Integration Co-op", desc: "Add messaging channels (SMS/calling alerts) or solid database connections to your existing software. We handle API mapping.", action: "Partner with Us" }
      ].each do |tier| %>
        <div class="home-glass home-card-3d flex flex-col justify-between rounded-[28px] p-8">
          <div>
            <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[#213885]/8 text-[#5F3475]">
              <i class="fa-solid <%= tier[:icon] %> text-xl"></i>
            </div>
            <h3 class="mt-6 text-2xl font-bold text-[#081849]"><%= tier[:title] %></h3>
            <p class="mt-3 text-sm leading-relaxed text-[#081849]/66"><%= tier[:desc] %></p>
          </div>
          <div class="mt-6 pt-4 border-t border-[#081849]/8">
            <%= link_to contact_path, class: "text-sm font-bold text-[#213885] hover:text-[#5F3475] inline-flex items-center gap-1" do %>
              <%= tier[:action] %> &rarr;
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>
