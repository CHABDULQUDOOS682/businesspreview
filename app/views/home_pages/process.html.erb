<% content_for :title, "Process | DevDeBizz" %>

<%= render "page_header",
  eyebrow: "How We Work",
  title_html: 'A proven 4-step <span class="home-display-accent">delivery process</span>'.html_safe,
  subtitle: "We keep the path simple: understand the business, shape the offer, build the experience, and launch with the systems needed to support it." %>

<section class="py-20">
  <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
    <% [
      { number: "01", title: "Discover", text: "We audit the business, audience, offer, and current friction points so the build solves the right problem." },
      { number: "02", title: "Design", text: "We define structure, messaging, and visual direction around conversion clarity and ease of use." },
      { number: "03", title: "Build", text: "We implement the site, pages, forms, and tooling with performance and handoff in mind." },
      { number: "04", title: "Launch", text: "We QA the experience, connect the moving parts, and help you go live with confidence." }
    ].each do |step| %>
      <div class="home-card-3d overflow-hidden rounded-[28px] bg-gradient-to-br from-[#123b56] to-[#11255f] p-8 text-[#ECDFD2] shadow-[0_24px_55px_-25px_rgba(8,24,73,0.55)]" data-controller="tilt-card" data-action="mousemove->tilt-card#move mouseleave->tilt-card#leave">
        <p class="text-6xl font-black text-white/10"><%= step[:number] %></p>
        <h2 class="mt-3 text-2xl font-bold"><%= step[:title] %></h2>
        <p class="mt-3 text-sm leading-relaxed text-[#ECDFD2]/76"><%= step[:text] %></p>
      </div>
    <% end %>
  </div>
</section>

<section class="relative overflow-hidden border-y border-[#081849]/8 bg-[#CCCACC]/45 py-24">
  <div class="home-grid-bg absolute inset-0 opacity-30"></div>
  <div class="relative">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-[#081849]/58">What to expect</p>
      <h2 class="mt-3 text-4xl font-extrabold text-[#081849] md:text-5xl">Clear communication at every step</h2>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      <% [
        { icon: "fa-calendar-day", title: "Weekly check-ins", text: "We keep decisions visible and progress easy to follow." },
        { icon: "fa-comments", title: "Tight feedback loops", text: "You review the right things at the right time instead of reviewing everything at once." },
        { icon: "fa-magnifying-glass", title: "SEO considered early", text: "Page structure and metadata are thought through before launch week." },
        { icon: "fa-handshake", title: "Clean handoff", text: "You leave with a site your team can confidently use and update." }
      ].each do |item| %>
        <div class="home-glass home-card-3d rounded-[28px] p-8 text-center" data-controller="tilt-card" data-action="mousemove->tilt-card#move mouseleave->tilt-card#leave">
          <i class="fa-solid <%= item[:icon] %> text-2xl text-[#5F3475]"></i>
          <h3 class="mt-5 text-2xl font-bold text-[#081849]"><%= item[:title] %></h3>
          <p class="mt-3 text-sm leading-relaxed text-[#081849]/66"><%= item[:text] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<section class="pt-24 text-center">
  <h2 class="text-4xl font-extrabold text-[#081849] md:text-5xl">Ready to start your project?</h2>
  <p class="mx-auto mt-4 max-w-2xl text-lg text-[#081849]/70">We’ll help you identify the right scope, the right launch path, and the right next steps before we build anything.</p>
  <div class="mt-8">
    <%= link_to contact_path, class: "home-button-primary" do %>
      Get Started Today
    <% end %>
  </div>
</section>
