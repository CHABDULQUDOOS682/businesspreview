<% content_for :title, "Pricing | DevDeBizz" %>

<%= render "page_header",
  eyebrow: "Pricing",
  title_html: 'Plans that match <br><span class="home-display-accent">your stage.</span>'.html_safe,
  subtitle: "Transparent pricing, no surprise invoices. Upgrade, downgrade, or pause anytime." %>

<section class="py-20" data-controller="pricing-toggle">
  <div class="mx-auto max-w-7xl px-2 md:px-0">
    <div class="mb-10 flex justify-center">
    <div class="inline-flex items-center gap-1 rounded-full border border-[#081849]/10 bg-[#081849]/5 p-1">
      <button 
        data-pricing-toggle-target="projectBtn" 
        data-action="click->pricing-toggle#toggle" 
        data-type="project"
        class="rounded-full bg-[#213885] px-5 py-2 text-sm font-semibold text-[#ECDFD2] shadow-md shadow-[#213885]/25 transition-all duration-300"
      >
        Project
      </button>
      <button 
        data-pricing-toggle-target="retainerBtn" 
        data-action="click->pricing-toggle#toggle" 
        data-type="retainer"
        class="rounded-full px-5 py-2 text-sm font-semibold text-[#081849]/55 transition-all duration-300 hover:text-[#081849]"
      >
        Retainer <span class="ml-1 rounded-full bg-[#5F3475]/10 px-2 py-0.5 text-[10px] text-[#5F3475]">-15%</span>
      </button>
    </div>
  </div>

  <div class="grid gap-6 lg:grid-cols-3">
    <% [
      { name: "Starter", project_price: "$1,900", retainer_price: "$1,600", cadence: "/ project", description: "For founders launching their first professional online presence.", features: ["5-page custom website", "Mobile-first responsive design", "Basic on-page SEO", "Contact form & analytics", "30 days post-launch support"], highlight: false, cta: "Get started" },
      { name: "Growth", project_price: "$4,800", retainer_price: "$4,000", cadence: "/ project", description: "For scaling teams that need a real conversion engine, not just a brochure.", features: ["Up to 15 pages + CMS", "Custom branding & illustration", "Advanced SEO & schema", "Performance marketing setup", "A/B testing framework", "90 days priority support"], highlight: true, cta: "Get started" },
      { name: "Enterprise", project_price: "Custom", retainer_price: "Custom", cadence: "", description: "For established brands needing dedicated capacity and complex integrations.", features: ["Unlimited pages & locales", "Custom web application build", "Dedicated project lead", "DevOps & cloud architecture", "Quarterly growth roadmap", "24/7 SLA support"], highlight: false, cta: "Talk to sales" }
    ].each do |plan| %>
      <div class="<%= plan[:highlight] ? 'home-card-3d relative rounded-[28px] border border-transparent bg-gradient-to-br from-[#213885] via-[#5F3475] to-[#893172] p-8 text-[#ECDFD2]' : 'home-glass home-card-3d relative rounded-[28px] border border-[#081849]/10 p-8' %>">
        <% if plan[:highlight] %>
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-[#213885] px-4 py-1 text-xs font-bold uppercase tracking-[0.18em] text-[#ECDFD2] shadow-lg shadow-[#213885]/35">
            Most Popular
          </div>
        <% end %>
        <h2 class="text-2xl font-bold <%= plan[:highlight] ? 'text-[#ECDFD2]' : 'text-[#081849]' %>"><%= plan[:name] %></h2>
        <p class="mt-2 text-sm <%= plan[:highlight] ? 'text-[#ECDFD2]/78' : 'text-[#081849]/62' %>"><%= plan[:description] %></p>
        <div class="mt-6 flex items-baseline gap-1">
          <span 
            class="text-5xl font-extrabold transition-all duration-300 <%= plan[:highlight] ? 'text-[#ECDFD2]' : 'text-[#081849]' %>"
            data-pricing-toggle-target="price"
            data-project-price="<%= plan[:project_price] %>"
            data-retainer-price="<%= plan[:retainer_price] %>"
          >
            <%= plan[:project_price] %>
          </span>
          <% if plan[:cadence].present? %>
            <span class="text-sm <%= plan[:highlight] ? 'text-[#ECDFD2]/70' : 'text-[#081849]/50' %>"><%= plan[:cadence] %></span>
          <% end %>
        </div>
        <ul class="mt-8 space-y-3 text-sm">
          <% plan[:features].each do |feature| %>
            <li class="flex items-start gap-3 <%= plan[:highlight] ? 'text-[#ECDFD2]/88' : 'text-[#081849]/80' %>">
              <i class="fa-solid fa-check mt-1 text-sm <%= plan[:highlight] ? 'text-[#ECDFD2]' : 'text-[#5F3475]' %>"></i>
              <%= feature %>
            </li>
          <% end %>
        </ul>
        <%= link_to contact_path, class: "mt-10 inline-flex w-full items-center justify-center rounded-full px-6 py-3 text-center text-sm font-semibold transition hover:-translate-y-0.5 #{plan[:highlight] ? 'bg-[#ECDFD2] text-[#213885] shadow-xl shadow-[#081849]/25' : 'border border-[#081849]/15 text-[#081849] hover:border-[#213885] hover:bg-[#213885] hover:text-[#ECDFD2]'}" do %>
          <%= plan[:cta] %>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="mt-24">
    <h2 class="text-center text-3xl font-extrabold text-[#081849] md:text-4xl">Compare <span class="text-[#5F3475]">all features</span></h2>
    <div class="mt-10 overflow-x-auto rounded-[28px] border border-[#081849]/10 bg-white/40 shadow-[0_18px_45px_rgba(8,24,73,0.06)]">
      <table class="min-w-full text-sm">
        <thead>
          <tr class="border-b border-[#081849]/10 text-left">
            <th class="px-6 py-4 font-semibold text-[#081849]">Feature</th>
            <th class="px-6 py-4 text-center font-semibold text-[#081849]">Starter</th>
            <th class="px-6 py-4 text-center font-semibold text-[#5F3475]">Growth</th>
            <th class="px-6 py-4 text-center font-semibold text-[#081849]">Enterprise</th>
          </tr>
        </thead>
        <tbody class="text-[#081849]/80">
          <% [
            ["Custom design", true, true, true],
            ["CMS integration", false, true, true],
            ["E-commerce", false, true, true],
            ["Advanced SEO", false, true, true],
            ["A/B testing", false, true, true],
            ["Multi-language", false, false, true],
            ["Dedicated PM", false, false, true],
            ["24/7 SLA", false, false, true]
          ].each do |feature, starter, growth, enterprise| %>
            <tr class="border-b border-[#081849]/5">
              <td class="px-6 py-4"><%= feature %></td>
              <% [starter, growth, enterprise].each do |value| %>
                <td class="px-6 py-4 text-center">
                  <%= value ? content_tag(:span, "✓", class: "text-[#5F3475]") : content_tag(:span, "—", class: "text-[#081849]/30") %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="mt-24">
    <h2 class="text-center text-3xl font-extrabold text-[#081849] md:text-4xl">Frequently asked <span class="text-[#5F3475]">questions</span></h2>
    <div class="mt-10 space-y-3">
      <% [
        ["How long does a typical project take?", "Starter sites ship in 3-4 weeks. Growth projects average 6-10 weeks. Enterprise builds typically run 12-20 weeks depending on complexity and integrations."],
        ["Do you offer ongoing support after launch?", "Yes — every plan includes post-launch support, and we offer monthly retainer packages for continued maintenance, optimization, and growth marketing."],
        ["Can I upgrade between plans?", "Absolutely. Many clients start with Starter and upgrade to Growth or Enterprise as they scale. We'll credit your prior investment toward the new tier."],
        ["Do you handle hosting and domains?", "We can. We deploy on Vercel, AWS, or your preferred cloud, and we'll manage DNS, SSL, and CDN if you'd like a fully managed setup."],
        ["What if I only need help with marketing or SEO?", "Our services are modular. You can engage us purely for SEO, paid acquisition, or content — no website work required."],
        ["Is there a refund policy?", "We offer a satisfaction guarantee on the discovery phase. If you're not happy with the strategic direction in the first two weeks, we'll refund the full deposit."]
      ].each_with_index do |(question, answer), index| %>
        <details class="overflow-hidden rounded-[22px] border border-[#081849]/10 bg-white/35" <%= "open" if index.zero? %>>
          <summary class="cursor-pointer list-none px-6 py-5 font-semibold text-[#081849] marker:hidden">
            <div class="flex items-center justify-between gap-4">
              <span><%= question %></span>
              <span class="text-xl text-[#5F3475]">+</span>
            </div>
          </summary>
          <div class="px-6 pb-5 text-sm leading-relaxed text-[#081849]/68"><%= answer %></div>
        </details>
      <% end %>
    </div>
  </div>
    </div>
  </div>
</section>
