      website_size: ["Up to 10 pages", "Home", "Services", "Gallery/Portfolio", "About", "Contact", "FAQ", "Appointments", "+3 Extra Pages (as needed)" ],
      included_intro: "Everything in Growth, plus:",
      included: [
        "Dashboard with",
        "Overview",
