<section class="py-20" data-controller="pricing-toggle">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-10 flex justify-center">
      <div class="inline-flex items-center gap-1 rounded-full border border-[#081849]/10 bg-[#081849]/5 p-1">
        <button
          data-pricing-toggle-target="subscriptionBtn"
          data-action="click->pricing-toggle#toggle"
          data-type="subscription"
          class="rounded-full bg-[#213885] px-5 py-2 text-sm font-semibold text-[#ECDFD2] shadow-md shadow-[#213885]/25 transition-all duration-300"
        >
          Subscription <span data-pricing-toggle-target="subscriptionBadge" class="ml-1 rounded-full bg-[#ECDFD2]/18 px-2 py-0.5 text-[10px] uppercase tracking-[0.12em] text-[#ECDFD2]">Hot</span>
        </button>
        <button
          data-pricing-toggle-target="projectBtn"
          data-action="click->pricing-toggle#toggle"
          data-type="project"
          class="rounded-full px-5 py-2 text-sm font-semibold text-[#081849]/55 transition-all duration-300 hover:text-[#081849]"
        >
          Project
        </button>
      </div>
    </div>

    <div data-pricing-toggle-target="panel" data-type="subscription" class="transition-all duration-300">
      <div class="grid gap-6 lg:grid-cols-3">
        <% subscription_plans.each do |plan| %>
          <div class="<%= plan[:highlight] ? 'home-card-3d relative rounded-[28px] border border-transparent bg-gradient-to-br from-[#213885] via-[#5F3475] to-[#893172] p-8 text-[#ECDFD2] shadow-2xl hover:-translate-y-1 transition-all duration-300' : 'home-glass home-card-3d relative rounded-[28px] border border-[#081849]/10 p-8 hover:-translate-y-1 transition-all duration-300 bg-white/40 shadow-[0_15px_30px_-10px_rgba(8,24,73,0.05)]' %>">
            <% if plan[:badge].present? %>
              <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-[#213885] px-4 py-1 text-xs font-bold uppercase tracking-[0.18em] text-[#ECDFD2] shadow-lg shadow-[#213885]/35">
                <i class="fa-solid fa-star mr-1 text-[10px]"></i><%= plan[:badge] %>
              </div>
            <% end %>
            <h2 class="text-2xl font-bold <%= plan[:highlight] ? 'text-[#ECDFD2]' : 'text-[#081849]' %>"><%= plan[:name] %></h2>
            <p class="mt-2 min-h-[44px] text-sm leading-relaxed <%= plan[:highlight] ? 'text-[#ECDFD2]/78' : 'text-[#081849]/62' %>"><%= plan[:description] %></p>
            
            <div class="mt-6 border-t border-b py-5 <%= plan[:highlight] ? 'border-white/10' : 'border-[#081849]/8' %>">
              <div class="flex flex-wrap items-baseline gap-1">
                <span class="text-5xl font-extrabold <%= plan[:highlight] ? 'text-[#ECDFD2]' : 'text-[#081849]' %>"><%= plan[:price] %></span>
                <span class="text-sm font-semibold <%= plan[:highlight] ? 'text-[#ECDFD2]/70' : 'text-[#081849]/50' %>"><%= plan[:cadence] %></span>
              </div>
              <p class="mt-2 text-xs font-semibold uppercase tracking-wider <%= plan[:highlight] ? 'text-[#ECDFD2]/80' : 'text-[#5F3475]' %>"><%= plan[:setup_fee] %></p>
            </div>

            <div class="mt-8 space-y-5 text-sm">
              <div class="rounded-2xl p-5 <%= plan[:highlight] ? 'bg-white/8 border border-white/10' : 'bg-[#081849]/3 border border-[#081849]/5' %>">
                <h3 class="text-xs font-bold uppercase tracking-[0.16em] <%= plan[:highlight] ? 'text-[#ECDFD2]/70' : 'text-[#5F3475]' %>">Website Size</h3>
                <ul class="mt-3 space-y-2">
                  <% plan[:website_size].each do |item| %>
                    <li class="flex items-center gap-2 <%= plan[:highlight] ? 'text-[#ECDFD2]/88' : 'text-[#081849]/80' %>">
                      <i class="fa-regular fa-file-lines text-xs opacity-75 <%= plan[:highlight] ? 'text-[#ECDFD2]/60' : 'text-[#5F3475]/60' %>"></i>
                      <span><%= item %></span>
                    </li>
                  <% end %>
                </ul>
              </div>

              <div class="rounded-2xl p-5 <%= plan[:highlight] ? 'bg-white/8 border border-white/10' : 'bg-[#081849]/3 border border-[#081849]/5' %>">
                <h3 class="text-xs font-bold uppercase tracking-[0.16em] <%= plan[:highlight] ? 'text-[#ECDFD2]/70' : 'text-[#5F3475]' %>">Included Services</h3>
                <% if plan[:included_intro].present? %>
                  <p class="mt-2 text-xs leading-relaxed opacity-90 <%= plan[:highlight] ? 'text-[#ECDFD2]/78' : 'text-[#081849]/62' %>"><%= plan[:included_intro] %></p>
                <% end %>
                <ul class="mt-3 space-y-2.5">
                  <% 
                    in_dashboard = false 
                    plan[:included].each do |feature| 
                      feature_str = feature.to_s.strip
                      if feature_str.start_with?("Dashboard with")
                        in_dashboard = true
                  %>
                        <li class="mt-4 font-bold text-xs uppercase tracking-[0.12em] <%= plan[:highlight] ? 'text-[#ECDFD2]/70' : 'text-[#5F3475]' %>"><%= feature %></li>
                  <% 
                      elsif feature_str.start_with?("-")
                        in_dashboard = false
                  %>
                        <li class="py-1"><hr class="<%= plan[:highlight] ? 'border-white/10' : 'border-[#081849]/10' %>"></li>
                  <% 
                      elsif in_dashboard
                  %>
                        <li class="flex items-center gap-2.5 pl-3.5 <%= plan[:highlight] ? 'text-[#ECDFD2]/88' : 'text-[#081849]/80' %>">
                          <span class="h-1.5 w-1.5 rounded-full <%= plan[:highlight] ? 'bg-[#ECDFD2]/50' : 'bg-[#5F3475]/50' %>"></span>
                          <span><%= feature %></span>
                        </li>
                  <% 
                      else
                  %>
                        <li class="flex items-start gap-3 <%= plan[:highlight] ? 'text-[#ECDFD2]/88' : 'text-[#081849]/80' %>">
                          <i class="fa-solid fa-check mt-1 text-sm <%= plan[:highlight] ? 'text-[#ECDFD2]' : 'text-[#5F3475]' %>"></i>
                          <span><%= feature %></span>
                        </li>
                  <% 
                      end
                    end
                  %>
                </ul>
              </div>

              <% if plan[:not_included].present? %>
                <div class="rounded-2xl p-5 <%= plan[:highlight] ? 'bg-white/8 border border-white/10' : 'bg-[#081849]/3 border border-[#081849]/5' %>">
                  <h3 class="text-xs font-bold uppercase tracking-[0.16em] text-[#5F3475]">Not Included</h3>
                  <ul class="mt-3 space-y-2 text-[#081849]/62">
                    <% plan[:not_included].each do |item| %>
                      <li class="flex items-center gap-2">
                        <i class="fa-solid fa-xmark text-xs text-red-500/70"></i>
                        <span><%= item %></span>
                      </li>
                    <% end %>
                  </ul>
                </div>
              <% end %>

              <% if plan[:perfect_for].present? %>
                <div class="rounded-2xl p-5 <%= plan[:highlight] ? 'bg-white/8 border border-white/10' : 'bg-[#081849]/3 border border-[#081849]/5' %>">
                  <h3 class="text-xs font-bold uppercase tracking-[0.16em] <%= plan[:highlight] ? 'text-[#ECDFD2]/70' : 'text-[#5F3475]' %>">Perfect For</h3>
                  <p class="mt-3 leading-relaxed <%= plan[:highlight] ? 'text-[#ECDFD2]/78' : 'text-[#081849]/62' %>"><%= plan[:perfect_for].join(", ") %></p>
                </div>
              <% end %>
            </div>

            <%= link_to contact_path, class: "mt-8 inline-flex w-full items-center justify-center rounded-full px-6 py-3 text-center text-sm font-bold transition-all duration-200 hover:-translate-y-0.5 #{plan[:highlight] ? 'bg-[#ECDFD2] text-[#213885] shadow-xl shadow-[#081849]/25 hover:bg-[#ECDFD2]/90' : 'border border-[#081849]/15 text-[#081849] hover:border-[#213885] hover:bg-[#213885] hover:text-[#ECDFD2]'}" do %>
              <%= plan[:cta] %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <div data-pricing-toggle-target="panel" data-type="project" class="hidden transition-all duration-300">
      <div class="grid gap-6 lg:grid-cols-3">
        <% project_plans.each do |plan| %>
          <div class="<%= plan[:highlight] ? 'home-card-3d relative rounded-[28px] border border-transparent bg-gradient-to-br from-[#213885] via-[#5F3475] to-[#893172] p-8 text-[#ECDFD2] shadow-2xl hover:-translate-y-1 transition-all duration-300' : 'home-glass home-card-3d relative rounded-[28px] border border-[#081849]/10 p-8 hover:-translate-y-1 transition-all duration-300 bg-white/40 shadow-[0_15px_30px_-10px_rgba(8,24,73,0.05)]' %>">
            <% if plan[:badge].present? %>
              <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-[#213885] px-4 py-1 text-xs font-bold uppercase tracking-[0.18em] text-[#ECDFD2] shadow-lg shadow-[#213885]/35">
                <i class="fa-solid fa-star mr-1 text-[10px]"></i><%= plan[:badge] %>
              </div>
            <% end %>
            <h2 class="text-2xl font-bold <%= plan[:highlight] ? 'text-[#ECDFD2]' : 'text-[#081849]' %>"><%= plan[:name] %></h2>
            <p class="mt-2 min-h-[66px] text-sm leading-relaxed <%= plan[:highlight] ? 'text-[#ECDFD2]/78' : 'text-[#081849]/62' %>"><%= plan[:description] %></p>
            
            <div class="mt-6 border-t border-b py-5 <%= plan[:highlight] ? 'border-white/10' : 'border-[#081849]/8' %>">
              <div class="flex flex-wrap items-baseline gap-1">
                <span class="text-4xl font-extrabold sm:text-5xl <%= plan[:highlight] ? 'text-[#ECDFD2]' : 'text-[#081849]' %>"><%= plan[:price] %></span>
                <% if plan[:cadence].present? %>
                  <span class="text-sm font-semibold <%= plan[:highlight] ? 'text-[#ECDFD2]/70' : 'text-[#081849]/50' %>"><%= plan[:cadence] %></span>
                <% end %>
              </div>
            </div>

            <div class="mt-8 space-y-5 text-sm">
              <div class="rounded-2xl p-5 <%= plan[:highlight] ? 'bg-white/8 border border-white/10' : 'bg-[#081849]/3 border border-[#081849]/5' %>">
                <h3 class="text-xs font-bold uppercase tracking-[0.16em] <%= plan[:highlight] ? 'text-[#ECDFD2]/70' : 'text-[#5F3475]' %>">Pages</h3>
                <ul class="mt-3 space-y-2">
                  <% plan[:pages].each do |item| %>
                    <li class="flex items-center gap-2 <%= plan[:highlight] ? 'text-[#ECDFD2]/88' : 'text-[#081849]/80' %>">
                      <i class="fa-regular fa-file-lines text-xs opacity-75 <%= plan[:highlight] ? 'text-[#ECDFD2]/60' : 'text-[#5F3475]/60' %>"></i>
                      <span><%= item %></span>
                    </li>
                  <% end %>
                </ul>
              </div>

              <div class="rounded-2xl p-5 <%= plan[:highlight] ? 'bg-white/8 border border-white/10' : 'bg-[#081849]/3 border border-[#081849]/5' %>">
                <h3 class="text-xs font-bold uppercase tracking-[0.16em] <%= plan[:highlight] ? 'text-[#ECDFD2]/70' : 'text-[#5F3475]' %>">Included Services</h3>
                <% if plan[:included_intro].present? %>
                  <p class="mt-2 text-xs leading-relaxed opacity-90 <%= plan[:highlight] ? 'text-[#ECDFD2]/78' : 'text-[#081849]/62' %>"><%= plan[:included_intro] %></p>
                <% end %>
                <ul class="mt-3 space-y-2.5">
                  <% plan[:included].each do |feature| %>
                    <li class="flex items-start gap-3 <%= plan[:highlight] ? 'text-[#ECDFD2]/88' : 'text-[#081849]/80' %>">
                      <i class="fa-solid fa-check mt-1 text-sm <%= plan[:highlight] ? 'text-[#ECDFD2]' : 'text-[#5F3475]' %>"></i>
                      <span><%= feature %></span>
                    </li>
                  <% end %>
                </ul>
              </div>

              <% if plan[:additional_features].present? %>
                <div class="rounded-2xl p-5 <%= plan[:highlight] ? 'bg-white/8 border border-white/10' : 'bg-[#081849]/3 border border-[#081849]/5' %>">
                  <h3 class="text-xs font-bold uppercase tracking-[0.16em] <%= plan[:highlight] ? 'text-[#ECDFD2]/70' : 'text-[#5F3475]' %>">Additional Features</h3>
                  <p class="mt-3 leading-relaxed <%= plan[:highlight] ? 'text-[#ECDFD2]/78' : 'text-[#081849]/62' %>"><%= plan[:additional_features].join(", ") %></p>
                </div>
              <% end %>

              <% if plan[:example_projects].present? %>
                <div class="rounded-2xl p-5 <%= plan[:highlight] ? 'bg-white/8 border border-white/10' : 'bg-[#081849]/3 border border-[#081849]/5' %>">
                  <h3 class="text-xs font-bold uppercase tracking-[0.16em] <%= plan[:highlight] ? 'text-[#ECDFD2]/70' : 'text-[#5F3475]' %>">Example Projects</h3>
                  <p class="mt-3 leading-relaxed <%= plan[:highlight] ? 'text-[#ECDFD2]/78' : 'text-[#081849]/62' %>"><%= plan[:example_projects].join(", ") %></p>
                </div>
              <% end %>

              <div class="rounded-2xl p-5 <%= plan[:highlight] ? 'bg-white/8 border border-white/10' : 'bg-[#081849]/3 border border-[#081849]/5' %> flex justify-between items-center">
                <h3 class="text-xs font-bold uppercase tracking-[0.16em] <%= plan[:highlight] ? 'text-[#ECDFD2]/70' : 'text-[#5F3475]' %>">Delivery Time</h3>
                <span class="rounded-full px-3 py-1 text-xs font-bold uppercase tracking-wider <%= plan[:highlight] ? 'bg-white/15 text-[#ECDFD2]' : 'bg-[#213885]/10 text-[#213885]' %>"><%= plan[:delivery] %></span>
              </div>

              <div class="rounded-2xl p-5 <%= plan[:highlight] ? 'bg-white/8 border border-white/10' : 'bg-[#081849]/3 border border-[#081849]/5' %>">
                <h3 class="text-xs font-bold uppercase tracking-[0.16em] <%= plan[:highlight] ? 'text-[#ECDFD2]/70' : 'text-[#5F3475]' %>">Best For</h3>
                <p class="mt-3 leading-relaxed <%= plan[:highlight] ? 'text-[#ECDFD2]/78' : 'text-[#081849]/62' %>"><%= plan[:best_for].join(", ") %></p>
              </div>
            </div>

            <%= link_to contact_path, class: "mt-8 inline-flex w-full items-center justify-center rounded-full px-6 py-3 text-center text-sm font-bold transition-all duration-200 hover:-translate-y-0.5 #{plan[:highlight] ? 'bg-[#ECDFD2] text-[#213885] shadow-xl shadow-[#081849]/25 hover:bg-[#ECDFD2]/90' : 'border border-[#081849]/15 text-[#081849] hover:border-[#213885] hover:bg-[#213885] hover:text-[#ECDFD2]'}" do %>
              <%= plan[:cta] %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="mt-24">
      <h2 class="text-center text-3xl font-extrabold text-[#081849] md:text-4xl">Compare <span class="text-[#5F3475]">all features</span></h2>

      <div data-pricing-toggle-target="comparison" data-type="subscription" class="mt-10 overflow-x-auto rounded-[28px] border border-[#081849]/10 bg-white/40 shadow-[0_18px_45px_rgba(8,24,73,0.06)]">
        <table class="min-w-full text-sm">
          <thead>
            <tr class="border-b border-[#081849]/10 text-left">
              <th class="px-6 py-4 font-semibold text-[#081849]">Feature</th>
              <th class="px-6 py-4 text-center font-semibold text-[#081849]">Essential</th>
              <th class="px-6 py-4 text-center font-semibold text-[#5F3475]">Growth</th>
              <th class="px-6 py-4 text-center font-semibold text-[#081849]">Business Pro</th>
            </tr>
          </thead>
          <tbody class="text-[#081849]/80">
            <% subscription_comparison.each do |feature, essential, growth, pro| %>
              <tr class="border-b border-[#081849]/5">
                <td class="px-6 py-4"><%= feature %></td>
                <% [essential, growth, pro].each do |value| %>
                  <td class="px-6 py-4 text-center"><%= render_value.call(value) %></td>
                <% end %>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <div data-pricing-toggle-target="comparison" data-type="project" class="mt-10 hidden overflow-x-auto rounded-[28px] border border-[#081849]/10 bg-white/40 shadow-[0_18px_45px_rgba(8,24,73,0.06)]">
        <table class="min-w-full text-sm">
          <thead>
            <tr class="border-b border-[#081849]/10 text-left">
              <th class="px-6 py-4 font-semibold text-[#081849]">Feature</th>
              <th class="px-6 py-4 text-center font-semibold text-[#081849]">Starter</th>
              <th class="px-6 py-4 text-center font-semibold text-[#5F3475]">Growth</th>
              <th class="px-6 py-4 text-center font-semibold text-[#081849]">Custom</th>
            </tr>
          </thead>
          <tbody class="text-[#081849]/80">
            <% project_comparison.each do |feature, starter, growth, custom| %>
              <tr class="border-b border-[#081849]/5">
                <td class="px-6 py-4"><%= feature %></td>
                <% [starter, growth, custom].each do |value| %>
                  <td class="px-6 py-4 text-center"><%= render_value.call(value) %></td>
                <% end %>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="mt-24">
      <h2 class="text-center text-3xl font-extrabold text-[#081849] md:text-4xl">Frequently asked <span class="text-[#5F3475]">questions</span></h2>
      <div class="mt-10 space-y-3">
        <% [
          ["Which option should I choose first?", "Choose Subscription if you want hosting, updates, monitoring, SEO support, and ongoing partnership. Choose Project if you need a new website or custom booking system built from the ground up."],
          ["Can I start with a project and move to a subscription?", "Yes. Many clients launch with a project package, then move into a subscription for hosting, updates, SEO, and continuous improvements."],
          ["Do monthly subscriptions include new pages?", "Essential focuses on maintenance and content updates. Growth and Business Pro include monthly development hours that can be used for smaller enhancements or landing page improvements."],
          ["How long does a typical project take?", "Starter websites usually take 2-3 weeks. Business Growth projects take 4-6 weeks. Custom booking systems and portals usually take 6-12+ weeks depending on scope and integrations."],
          ["Do you handle hosting and domains?", "Yes. Subscription plans include managed hosting, SSL, backups, monitoring, and support. Project plans include domain and hosting assistance for launch."],
          ["Can I upgrade between plans?", "Absolutely. You can move from Essential to Growth or Business Pro as your website and business needs grow."]
        ].each_with_index do |(question, answer), index| %>
          <details class="overflow-hidden rounded-[22px] border border-[#081849]/10 bg-white/35" <%= "open" if index.zero? %>>
            <summary class="cursor-pointer list-none px-6 py-5 font-semibold text-[#081849] marker:hidden">
              <div class="flex items-center justify-between gap-4">
                <span><%= question %></span>
                <span class="text-xl text-[#5F3475]">+</span>
              </div>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-[#081849]/68"><%= answer %></div>
          </details>
        <% end %>
      </div>
    </div>
  </div>
</section>
