      ],
      delivery: "6-12+ weeks",
      best_for: ["Multi-location service teams", "Clinics with complex scheduling", "Agencies needing custom ops tools", "Businesses automating bookings and follow-up"],
      highlight: false,
      badge: nil,
      cta: "Talk to Sales"
    }
