        "Reviews Management",
        "Customers Management",
        "Staff Management",
        "Service Management",
        "Gallery Management",
        "Business Hours Management",
        "---------------------------",
        "10 content updates per month",
        "SEO support",
        "Monthly strategy meeting",
        "Priority emergency support",
        "CRM integration support"
      ],
      perfect_for: ["Multi-location service businesses", "Established clinics and studios", "Teams that need booking and reviews"],
      highlight: false,
      badge: nil,
      cta: "Start Business Pro"
    }
  ]

  project_plans = [
    {
      name: "Starter Website",
      price: "$499",
      cadence: "/ project",
      description: "Perfect for local service businesses launching their first professional website with clear services and a simple contact path.",
      pages: ["Up to 5 pages", "Home", "About", "Services", "Portfolio/Gallery", "Contact"],
      included: [
        "Custom UI design",
        "Mobile responsive design",
        "Contact forms",
        "Basic on-page SEO",
        "Google Analytics setup",
        "Social media integration",
        "Speed optimization",
        "SSL configuration",
        "Domain & hosting assistance",
        "30 days post-launch support"
      ],
      delivery: "2-3 weeks",
      best_for: ["Barbershops", "Salons", "Restaurants", "Consultants", "Local service businesses"],
      highlight: false,
      badge: nil,
      cta: "Start Project"
    },
    {
      name: "Business Growth",
      price: "$999",
      cadence: "/ project",
      description: "Built for service businesses that need more than a brochure site and want clearer service pages plus stronger lead capture.",
      pages: ["Up to 12 pages"],
      included_intro: "Everything in Starter, plus:",
      included: [
        "CMS (Content Management System)",
        "Blog setup",
        "Advanced SEO structure",
        "Lead capture forms",
        "Custom service pages",
        "Conversion-focused design",
        "Google Search Console setup",
        "Email marketing integration",
        "Performance optimization",
        "Custom animations",
        "60 days priority support"
      ],
      additional_features: ["Admin dashboard", "Blog management", "Lead collection system", "Analytics dashboard"],
      delivery: "4-6 weeks",
      best_for: ["Growing salons and studios", "Clinics", "Home service companies", "Local agencies", "Multi-service providers"],
      highlight: true,
      badge: "Most Popular",
      cta: "Choose Growth"
    },
    {
      name: "Custom Web Application",
      price: "Starting at $1,999",
      cadence: "",
