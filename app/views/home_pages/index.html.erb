<% content_for :title, "BizzlyTech | Websites and systems that convert" %>

<section class="relative min-h-[90vh]" data-controller="home-scene" data-action="mousemove->home-scene#move mouseleave->home-scene#leave">
  <div class="home-hero-scene pointer-events-none absolute inset-0">
    <div class="home-grid-animated absolute inset-0 opacity-40"></div>

    <div class="animate-glow absolute -right-32 -top-32 h-[36rem] w-[36rem] rounded-full bg-[#213885]/15 blur-[120px] home-hero-parallax-reverse"></div>
    <div class="animate-glow absolute -bottom-28 -left-28 h-[30rem] w-[30rem] rounded-full bg-[#893172]/10 blur-[120px] home-hero-parallax" style="animation-delay: 2s;"></div>

    <div class="absolute left-[8%] top-[15%] animate-float-slow home-hero-parallax">
      <div class="perspective-1000">
        <div class="preserve-3d animate-spin-slower relative h-20 w-20">
          <div class="absolute inset-0 border border-[#213885]/35 bg-[#5F3475]/18 backdrop-blur-[2px]" style="transform: translateZ(40px);"></div>
          <div class="absolute inset-0 border border-[#213885]/28 bg-[#5F3475]/10 backdrop-blur-[2px]" style="transform: rotateY(180deg) translateZ(40px);"></div>
          <div class="absolute inset-0 border border-[#213885]/30 bg-[#5F3475]/14 backdrop-blur-[2px]" style="transform: rotateY(90deg) translateZ(40px);"></div>
          <div class="absolute inset-0 border border-[#213885]/20 bg-[#5F3475]/8 backdrop-blur-[2px]" style="transform: rotateY(-90deg) translateZ(40px);"></div>
          <div class="absolute inset-0 border border-[#213885]/30 bg-[#5F3475]/16 backdrop-blur-[2px]" style="transform: rotateX(90deg) translateZ(40px);"></div>
          <div class="absolute inset-0 border border-[#213885]/15 bg-[#5F3475]/6 backdrop-blur-[2px]" style="transform: rotateX(-90deg) translateZ(40px);"></div>
        </div>
      </div>
    </div>

    <svg class="absolute right-[12%] top-[23%] h-[7.5rem] w-[7.5rem] animate-float-medium home-hero-parallax-reverse home-hero-svg" viewBox="0 0 120 120" fill="none" style="animation-delay: 1s;">
      <defs>
        <radialGradient id="home-torus-gradient" cx="0.3" cy="0.3">
          <stop offset="0%" stop-color="#5F3475" stop-opacity="0.6" />
          <stop offset="100%" stop-color="#5F3475" stop-opacity="0.05" />
        </radialGradient>
      </defs>
      <ellipse cx="60" cy="60" rx="50" ry="20" stroke="url(#home-torus-gradient)" stroke-width="3" />
      <ellipse cx="60" cy="60" rx="50" ry="20" stroke="#5F3475" stroke-width="1" opacity="0.4" transform="rotate(30 60 60)" />
      <ellipse cx="60" cy="60" rx="50" ry="20" stroke="#5F3475" stroke-width="1" opacity="0.3" transform="rotate(60 60 60)" />
      <ellipse cx="60" cy="60" rx="50" ry="20" stroke="#5F3475" stroke-width="1" opacity="0.2" transform="rotate(90 60 60)" />
      <ellipse cx="60" cy="60" rx="50" ry="20" stroke="#5F3475" stroke-width="1" opacity="0.3" transform="rotate(120 60 60)" />
      <ellipse cx="60" cy="60" rx="50" ry="20" stroke="#5F3475" stroke-width="1" opacity="0.4" transform="rotate(150 60 60)" />
    </svg>

    <svg class="absolute left-[13%] bottom-[18%] h-[5.75rem] w-[5.75rem] animate-float-slow home-hero-parallax home-hero-svg" viewBox="0 0 100 100" fill="none" style="animation-delay: 2s;">
      <defs>
        <linearGradient id="home-pyramid-a" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#5F3475" stop-opacity="0.4" />
          <stop offset="100%" stop-color="#5F3475" stop-opacity="0.1" />
        </linearGradient>
        <linearGradient id="home-pyramid-b" x1="0" y1="1" x2="1" y2="0">
          <stop offset="0%" stop-color="#5F3475" stop-opacity="0.25" />
          <stop offset="100%" stop-color="#5F3475" stop-opacity="0.05" />
        </linearGradient>
      </defs>
      <polygon points="50,10 90,80 50,65" fill="url(#home-pyramid-a)" stroke="#5F3475" stroke-width="1.5" opacity="0.7" />
      <polygon points="50,10 10,80 50,65" fill="url(#home-pyramid-b)" stroke="#5F3475" stroke-width="1.5" opacity="0.6" />
      <polygon points="50,65 10,80 90,80" fill="rgba(95,52,117,0.08)" stroke="#5F3475" stroke-width="1" opacity="0.4" />
    </svg>

    <svg class="absolute right-[18%] bottom-[14%] h-[4.5rem] w-[4.5rem] animate-float-medium home-hero-parallax-reverse home-hero-svg" viewBox="0 0 80 80" fill="none" style="animation-delay: 0.5s;">
      <defs>
        <radialGradient id="home-sphere-gradient" cx="0.35" cy="0.35">
          <stop offset="0%" stop-color="#5F3475" stop-opacity="0.9" />
          <stop offset="60%" stop-color="#5F3475" stop-opacity="0.2" />
          <stop offset="100%" stop-color="#081849" stop-opacity="0.6" />
        </radialGradient>
      </defs>
      <circle cx="40" cy="40" r="35" fill="url(#home-sphere-gradient)" stroke="#5F3475" stroke-width="1" opacity="0.5" />
      <ellipse cx="40" cy="40" rx="35" ry="10" stroke="#5F3475" stroke-width="0.5" opacity="0.4" />
      <ellipse cx="40" cy="40" rx="10" ry="35" stroke="#5F3475" stroke-width="0.5" opacity="0.4" />
    </svg>

    <svg class="absolute left-[45%] top-[54%] h-[8.75rem] w-[8.75rem] animate-float-slow home-hero-parallax home-hero-svg" viewBox="0 0 140 140" fill="none" style="animation-delay: 1.5s;">
      <circle cx="70" cy="70" r="60" stroke="#5F3475" stroke-width="1" stroke-dasharray="4 8" opacity="0.35" />
      <circle cx="70" cy="70" r="50" stroke="#5F3475" stroke-width="1" opacity="0.22" />
      <circle cx="70" cy="70" r="40" stroke="#5F3475" stroke-width="0.5" stroke-dasharray="2 6" opacity="0.45" />
    </svg>
  </div>

  <div class="relative mx-auto max-w-7xl px-2 py-10 md:px-0 md:py-16">
    <div class="mx-auto max-w-5xl text-center">
      <span class="home-pill">
        <span class="home-pill-dot"></span>
        Digital Agency · Est. 2019
      </span>

      <h1 class="home-hero-heading text-glow mt-8 text-5xl font-extrabold leading-[1.02] tracking-tight text-[#081849] md:text-8xl">
        Brands that
        <span class="relative inline-block">
          <span class="relative z-10 bg-gradient-to-br from-[#5F3475] to-[#893172] bg-clip-text text-transparent">
            scale.
          </span>
          <svg class="absolute -bottom-2 left-0 w-full" height="14" viewBox="0 0 200 14" preserveAspectRatio="none">
            <path d="M2 8 Q50 2 100 7 T198 6" stroke="#893172" stroke-width="3" fill="none" stroke-linecap="round" />
          </svg>
        </span>
        <br>
        Sites that <span class="bg-gradient-to-br from-[#081849] to-[#081849]/40 bg-clip-text text-transparent">convert.</span>
      </h1>

      <p class="mx-auto mt-8 max-w-2xl text-lg leading-relaxed text-[#081849]/70 md:text-xl">
        BizzlyTech is a full-service digital agency helping ambitious companies launch, grow, and dominate their markets through strategic design, engineering, and growth marketing.
      </p>

      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <%= link_to services_path, class: "home-button-primary" do %>
          Explore Services
        <% end %>
        <%= link_to portfolio_path, class: "home-button-secondary" do %>
          View Our Work →
        <% end %>
      </div>
    </div>

    <div class="perspective-1000 relative mt-24 grid gap-4 md:grid-cols-4">
      <% [
        { number: "250+", label: "Projects delivered" },
        { number: "98%", label: "Client retention" },
        { number: "40+", label: "Team experts" },
        { number: "12", label: "Industry awards" }
      ].each_with_index do |stat, index| %>
        <div class="glass card-3d home-floating-shadow relative rounded-2xl p-6 text-center animate-fade-up" data-controller="tilt-card" data-action="mousemove->tilt-card#move mouseleave->tilt-card#leave" style="animation-delay: <%= 0.1 + (index * 0.08) %>s;">
          <div class="absolute inset-x-6 top-0 h-px bg-gradient-to-r from-transparent via-[#5F3475]/50 to-transparent"></div>
          <p class="bg-gradient-to-br from-[#213885] to-[#893172] bg-clip-text text-4xl font-extrabold text-transparent md:text-5xl"><%= stat[:number] %></p>
          <p class="mt-2 text-xs uppercase tracking-[0.18em] text-[#081849]/58"><%= stat[:label] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<section class="relative border-y border-[#081849]/5 bg-[#CCCACC]/50 py-24">
  <div class="home-grid-bg absolute inset-0 opacity-30"></div>
  <div class="relative mx-auto max-w-7xl px-2 md:px-0">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-[#081849]/58">What we build</p>
      <h2 class="mt-3 text-4xl font-extrabold text-[#081849] md:text-5xl">A complete growth stack for service businesses</h2>
      <p class="mt-4 text-lg text-[#081849]/70">From your first impression to your follow-up systems, we design the touchpoints that turn interest into booked business.</p>
    </div>

    <div class="perspective-1000 mt-16 grid gap-6 md:grid-cols-3">
      <% [
        {
          icon: "fa-layer-group",
          title: "Brand & positioning",
          description: "Messaging, offer clarity, and visual direction that helps local customers trust you fast.",
          points: [ "Offer strategy", "Messaging system", "Visual direction", "Launch roadmap" ]
        },
        {
          icon: "fa-code",
          title: "Websites & funnels",
          description: "High-converting marketing sites, service pages, and landing flows built for speed and mobile.",
          points: [ "Marketing websites", "Landing pages", "Lead forms", "Analytics setup" ]
        },
        {
          icon: "fa-gears",
          title: "Systems & automation",
          description: "Booking flows, follow-up touchpoints, and internal tooling that remove manual bottlenecks.",
          points: [ "Booking logic", "CRM workflows", "Reminders", "Ops dashboards" ]
        }
      ].each_with_index do |service, index| %>
        <div class="glass card-3d group relative overflow-hidden rounded-2xl p-8 animate-fade-up" data-controller="tilt-card" data-action="mousemove->tilt-card#move mouseleave->tilt-card#leave" style="animation-delay: <%= index * 0.08 %>s;">
          <div class="absolute -right-12 -top-12 h-32 w-32 rounded-full bg-[#213885]/0 blur-2xl transition group-hover:bg-[#213885]/30"></div>
          <div class="relative">
            <div class="inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-[#213885]/20 to-[#213885]/5 ring-1 ring-[#213885]/30">
            <i class="fa-solid <%= service[:icon] %> text-xl text-[#5F3475]"></i>
            </div>
            <h3 class="mt-5 text-2xl font-bold text-[#081849]"><%= service[:title] %></h3>
            <p class="mt-3 text-sm leading-relaxed text-[#081849]/65"><%= service[:description] %></p>
            <ul class="mt-5 space-y-2">
              <% service[:points].each do |point| %>
                <li class="flex items-center gap-2 text-sm text-[#081849]/72">
                  <span class="h-1.5 w-1.5 rounded-full bg-[#213885]"></span>
                  <%= point %>
                </li>
              <% end %>
            </ul>
          </div>
        </div>
      <% end %>
    </div>

    <div class="mt-12 text-center">
      <%= link_to services_path, class: "text-sm font-semibold text-[#5F3475] transition hover:text-[#213885]" do %>
        See all services →
      <% end %>
    </div>
  </div>
</section>

<section class="relative py-24">
  <div class="mx-auto max-w-7xl px-2 md:px-0">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-[#081849]/58">How we work</p>
      <h2 class="mt-3 text-4xl font-extrabold text-[#081849] md:text-5xl">A proven 4-step process</h2>
    </div>

    <div class="perspective-1000 mt-16 grid gap-6 md:grid-cols-4">
      <% [
        { number: "01", title: "Discover", text: "We deep-dive into your business, audience, and competitive landscape." },
        { number: "02", title: "Design", text: "Strategic positioning meets striking visual identity and UX." },
        { number: "03", title: "Build", text: "Engineering teams ship clean, fast, scalable production code." },
        { number: "04", title: "Grow", text: "Continuous optimization, SEO, and paid acquisition from day one." }
      ].each_with_index do |step, index| %>
        <div class="card-3d glass relative overflow-hidden rounded-2xl border border-[#081849]/10 p-6 animate-fade-up" data-controller="tilt-card" data-action="mousemove->tilt-card#move mouseleave->tilt-card#leave" style="animation-delay: <%= index * 0.08 %>s;">
          <div class="absolute -right-0 -top-0 text-7xl font-black text-[#5F3475]/15 select-none"><%= step[:number] %></div>
          <div class="relative">
            <div class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-[#213885] to-[#5F3475] text-sm font-bold text-[#ECDFD2] shadow-lg shadow-[#5F3475]/30"><%= step[:number] %></div>
            <h3 class="mt-4 text-lg font-bold text-[#081849]"><%= step[:title] %></h3>
            <p class="mt-2 text-sm text-[#081849]/70"><%= step[:text] %></p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<section class="relative border-y border-[#081849]/5 bg-[#CCCACC]/50 py-24">
  <div class="mx-auto max-w-7xl px-2 md:px-0">
    <div class="mx-auto max-w-3xl text-center">
      <span class="text-xs font-bold uppercase tracking-[0.2em] text-[#081849]/60">Happy clients</span>
      <h2 class="mt-3 text-4xl font-extrabold text-[#081849] md:text-5xl">What our partners say</h2>
    </div>

    <div class="relative mt-16 px-4 md:px-0" data-controller="carousel">
      <div class="swiper" data-carousel-target="container">
        <div class="swiper-wrapper py-12">
          <% [
            { quote: "BizzlyTech rebuilt our site and booking flow so the business finally feels easy to browse and trust on mobile.", name: "Sarah Chen", role: "Owner, Studio North" },
            { quote: "The new pages gave our offers structure, improved lead quality, and made our team look far more established online.", name: "Marcus Hale", role: "Founder, Atlas Fitness" },
            { quote: "From strategy to launch, the polish and follow-through felt like having an in-house growth team for the project.", name: "Priya Nair", role: "Director, Clarity Dental" },
            { quote: "We saw a 40% increase in lead conversion within the first month of launching our new funnel systems.", name: "David Miller", role: "CEO, Miller Tech" },
            { quote: "The attention to detail in the design phase was unlike anything we've experienced with other agencies.", name: "Elena Rossi", role: "Marketing Lead, Luxe Stay" }
          ].each_with_index do |testimonial, index| %>
            <div class="swiper-slide h-auto max-w-lg">
              <div class="card-3d glass h-full rounded-2xl p-7 shadow-xl" data-controller="tilt-card" data-action="mousemove->tilt-card#move mouseleave->tilt-card#leave">
                <div class="absolute inset-0 -z-10 rounded-2xl bg-gradient-to-br from-[#5F3475]/5 to-transparent"></div>
                <svg width="32" height="32" viewBox="0 0 24 24" fill="#5F3475" opacity="0.4">
                  <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
                </svg>
                <p class="mt-4 text-sm leading-relaxed text-[#081849]/85 md:text-base"><%= testimonial[:quote] %></p>
                <div class="mt-6 border-t border-[#081849]/10 pt-4">
                  <div class="font-bold text-[#081849]"><%= testimonial[:name] %></div>
                  <div class="text-xs font-medium text-[#081849]/55"><%= testimonial[:role] %></div>
                </div>
              </div>
            </div>
          <% end %>
        </div>

        <div class="swiper-pagination !-bottom-2"></div>
        
        <div class="swiper-button-prev !hidden md:!flex !left-0 !h-12 !w-12 !rounded-full !bg-white/50 !text-[#5F3475] !backdrop-blur-sm after:!text-sm hover:!bg-white/80 transition-all"></div>
        <div class="swiper-button-next !hidden md:!flex !right-0 !h-12 !w-12 !rounded-full !bg-white/50 !text-[#5F3475] !backdrop-blur-sm after:!text-sm hover:!bg-white/80 transition-all"></div>
      </div>
    </div>
  </div>
</section>

<section class="pt-24">
  <div class="mx-auto max-w-5xl px-2 md:px-0">
    <div class="home-card-3d relative overflow-hidden rounded-[32px] bg-gradient-to-br from-[#213885] via-[#5F3475] to-[#893172] p-12 text-center text-[#ECDFD2] shadow-[0_30px_80px_-20px_rgba(95,52,117,0.5)] md:p-16">
      <div class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-white/15 blur-3xl"></div>
      <div class="absolute -left-20 -bottom-20 h-64 w-64 rounded-full bg-[#893172]/40 blur-3xl"></div>
      <div class="relative">
        <h2 class="text-4xl font-extrabold md:text-5xl">
          Ready to build something <span class="underline decoration-white/40 underline-offset-8">remarkable?</span>
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-[#ECDFD2]/85">
          Tell us about your business and we’ll come back with a practical plan for the site, pages, and systems you actually need.
        </p>
        <%= link_to contact_path, class: "home-button-light mt-8" do %>
          Start a Project →
        <% end %>
      </div>
    </div>
  </div>
</section>
