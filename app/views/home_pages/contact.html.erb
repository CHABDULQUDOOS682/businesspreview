<% content_for :title, "Contact | DevDeBizz" %>

<%= render "page_header",
  eyebrow: "Get in Touch",
  title_html: 'Let&apos;s build something <br><span class="home-display-accent">remarkable.</span>'.html_safe,
  subtitle: "Tell us about your project and we'll get back to you within one business day with a tailored plan and ballpark timeline." %>

<section class="py-16">
  <div class="mx-auto max-w-7xl px-2 md:px-0">
    <div class="grid gap-8 lg:grid-cols-5">
    <div class="space-y-6 lg:col-span-2">
      <div class="home-glass home-card-3d space-y-6 rounded-[28px] p-8">
        <% [
          { icon: "fa-envelope", label: "Email", value: "hello@devdebizz.com", href: "mailto:hello@devdebizz.com" },
          { icon: "fa-phone", label: "Phone", value: "+1 (415) 555-0142", href: "tel:+14155550142" },
          { icon: "fa-location-dot", label: "Office", value: "221 Market Street, San Francisco, CA", href: "#" },
          { icon: "fa-clock", label: "Hours", value: "Mon–Fri · 9am–6pm PT", href: "#" }
        ].each do |contact| %>
          <a href="<%= contact[:href] %>" class="group flex items-start gap-4">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-[#213885]/20 to-[#213885]/5 ring-1 ring-[#213885]/30 transition group-hover:scale-110">
              <i class="fa-solid <%= contact[:icon] %> text-lg text-[#5F3475]"></i>
            </div>
            <div>
              <p class="text-xs uppercase tracking-[0.18em] text-[#081849]/52"><%= contact[:label] %></p>
              <p class="mt-1 font-semibold text-[#081849] transition group-hover:text-[#5F3475]"><%= contact[:value] %></p>
            </div>
          </a>
        <% end %>
      </div>

      <div class="home-glass home-card-3d rounded-[28px] p-8">
        <h3 class="font-bold text-[#081849]">Response time</h3>
        <p class="mt-2 text-sm text-[#081849]/65">We respond to all inquiries within one business day. Urgent? Mention it in your message and we’ll prioritize.</p>
        <div class="mt-5 flex items-center gap-3">
          <span class="relative flex h-3 w-3">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[#213885] opacity-75"></span>
            <span class="relative inline-flex h-3 w-3 rounded-full bg-[#213885]"></span>
          </span>
          <span class="text-sm font-semibold text-[#081849]">Currently accepting new clients</span>
        </div>
      </div>
    </div>

    <div class="lg:col-span-3">
      <form class="home-card-3d relative overflow-hidden rounded-[32px] border border-[#081849]/10 bg-white/70 p-8 shadow-[0_18px_45px_rgba(8,24,73,0.06)] md:p-10">
        <div class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-[#5F3475]/10"></div>
        <div class="absolute -left-20 -bottom-20 h-64 w-64 rounded-full bg-[#213885]/10"></div>

        <div class="relative grid gap-5">
          <div class="grid gap-5 md:grid-cols-2">
            <label class="block">
              <span class="mb-2 block text-xs font-bold uppercase tracking-[0.18em] text-[#213885]">First name</span>
              <input type="text" class="home-input" placeholder="Jane">
            </label>
            <label class="block">
              <span class="mb-2 block text-xs font-bold uppercase tracking-[0.18em] text-[#213885]">Last name</span>
              <input type="text" class="home-input" placeholder="Doe">
            </label>
          </div>

          <div class="grid gap-5 md:grid-cols-2">
            <label class="block">
              <span class="mb-2 block text-xs font-bold uppercase tracking-[0.18em] text-[#213885]">Work email</span>
              <input type="email" class="home-input" placeholder="you@company.com">
            </label>
            <label class="block">
              <span class="mb-2 block text-xs font-bold uppercase tracking-[0.18em] text-[#213885]">Company</span>
              <input type="text" class="home-input" placeholder="Acme Inc.">
            </label>
          </div>

          <label class="block">
            <span class="mb-2 block text-xs font-bold uppercase tracking-[0.18em] text-[#213885]">Service interest</span>
            <select class="home-input">
              <option>Web Development</option>
              <option>Branding & Identity</option>
              <option>UI / UX Design</option>
              <option>SEO & Content</option>
              <option>Performance Marketing</option>
              <option>Cloud & DevOps</option>
            </select>
          </label>

          <label class="block">
            <span class="mb-2 block text-xs font-bold uppercase tracking-[0.18em] text-[#213885]">Project details</span>
            <textarea class="home-input" placeholder="Tell us about your goals, timeline, and anything else we should know…"></textarea>
          </label>

          <button type="button" class="group relative w-full overflow-hidden rounded-full bg-[#213885] px-8 py-4 text-sm font-bold text-[#ECDFD2] shadow-2xl shadow-[#213885]/30 transition hover:scale-[1.02]">
            <span class="relative z-10">Send Message →</span>
            <span class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-[#081849]/45 to-transparent transition-transform duration-700 group-hover:translate-x-full"></span>
          </button>
        </div>
      </form>
    </div>
    </div>
  </div>
</section>
