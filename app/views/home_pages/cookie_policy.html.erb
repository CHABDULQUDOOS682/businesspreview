<% content_for :title, "Cookie Policy | DevDeBizz" %>
<% content_for :meta_description, "Learn how DevDeBizz uses cookies and similar technologies on our website and related services." %>

<%= render "page_header",
  eyebrow: "Cookies",
  title_html: 'Cookie and tracking <span class="home-display-accent">policy</span>'.html_safe,
  subtitle: "Details about how we use cookies to secure sessions and analyze website interactions." %>

<section class="py-20">
  <div class="mx-auto max-w-4xl px-2 md:px-0">
    <div class="home-glass home-card-3d rounded-[32px] p-8 md:p-12 space-y-8 text-[#081849]/80 leading-relaxed">
      <div>
        <h2 class="text-2xl font-bold text-[#081849] mb-3">What are cookies?</h2>
        <p>Cookies are small text files stored on your device by your browser. They help websites remember preferences, manage sessions, and protect secure interactions.</p>
      </div>

      <div>
        <h2 class="text-2xl font-bold text-[#081849] mb-3">How we use cookies</h2>
        <p>DevDeBizz collects very minimal data. We use cookies primarily for:</p>
        <ul class="mt-3 list-disc pl-6 space-y-2">
          <li><strong>Security & Sessions:</strong> Essential cookies that store login status and secure admin sessions.</li>
          <li><strong>Payment Processing:</strong> First-party cookies set by Stripe to handle credit card payments, checkouts, and prevent fraud.</li>
          <li><strong>Analytics:</strong> Performance cookies that gather aggregate site traffic and interaction counts to improve layout responsiveness.</li>
        </ul>
      </div>

      <div>
        <h2 class="text-2xl font-bold text-[#081849] mb-3">Your choices</h2>
        <p>You can choose to disable non-essential cookies via your browser settings. However, disabling essential session or payment cookies may prevent checkout flows from executing correctly.</p>
      </div>
    </div>
  </div>
</section>
