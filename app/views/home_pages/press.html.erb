<% content_for :title, "Press | DevDeBizz" %>
<% content_for :meta_description, "Press and media information about DevDeBizz, the studio helping service businesses grow with clearer websites and systems." %>

<%= render "page_header",
  eyebrow: "Press & Media",
  title_html: 'News and <span class="home-display-accent">media assets</span>'.html_safe,
  subtitle: "Official guidelines, company assets, and news resources for DevDeBizz." %>

<section class="py-20">
  <div class="mx-auto max-w-7xl px-2 md:px-0">
    <div class="grid gap-8 lg:grid-cols-3">
      <div class="home-glass home-card-3d rounded-[28px] p-8 lg:col-span-2">
        <h2 class="text-3xl font-extrabold text-[#081849]">About DevDeBizz</h2>
        <p class="mt-4 text-base leading-relaxed text-[#081849]/70">
          DevDeBizz is a focused studio that turns service websites and client journeys into clear, automated flows. We design local-first web presences, booking systems, and automated email/SMS follow-up campaigns that help service-led businesses succeed online.
        </p>
        
        <h3 class="mt-8 text-2xl font-bold text-[#081849]">Quick Facts</h3>
        <table class="mt-4 w-full text-sm border-collapse text-left text-[#081849]/80">
          <tr class="border-b border-[#081849]/8">
            <td class="py-3 font-semibold w-1/3">Founded</td>
            <td class="py-3"><%= Time.current.year %></td>
          </tr>
          <tr class="border-b border-[#081849]/8">
            <td class="py-3 font-semibold">Specialization</td>
            <td class="py-3">Web Development, Automations, Messaging, and Client Nurture Systems</td>
          </tr>
          <tr class="border-b border-[#081849]/8">
            <td class="py-3 font-semibold">HQ</td>
            <td class="py-3">Remote-First Studio</td>
          </tr>
          <tr>
            <td class="py-3 font-semibold">Contact Email</td>
            <td class="py-3"><%= contact_email %></td>
          </tr>
        </table>
      </div>

      <div class="space-y-6">
        <div class="home-card-3d overflow-hidden rounded-[28px] bg-gradient-to-br from-[#213885] to-[#5F3475] p-8 text-[#ECDFD2]">
          <h3 class="text-2xl font-bold">Media Contact</h3>
          <p class="mt-3 text-sm leading-relaxed text-[#ECDFD2]/80">For press inquiries, interview requests, or quote permissions, reach out directly at:</p>
          <p class="mt-4 text-lg font-bold"><%= link_to contact_email, "mailto:#{contact_email}", class: "underline text-[#ECDFD2]" %></p>
        </div>

        <div class="home-glass home-card-3d rounded-[28px] p-8">
          <h3 class="text-2xl font-bold text-[#081849]">Press Assets</h3>
          <p class="mt-2 text-sm text-[#081849]/66">Download logos, photos, and studio product captures.</p>
          <ul class="mt-4 space-y-3">
            <li>
              <%= link_to "#", class: "flex items-center gap-2 text-sm font-semibold text-[#213885] hover:text-[#5F3475]" do %>
                <i class="fa-solid fa-download"></i> Logo Kit (Vector SVG/PNG)
              <% end %>
            </li>
            <li>
              <%= link_to "#", class: "flex items-center gap-2 text-sm font-semibold text-[#213885] hover:text-[#5F3475]" do %>
                <i class="fa-solid fa-download"></i> Studio Screenshots
              <% end %>
            </li>
            <li>
              <%= link_to "#", class: "flex items-center gap-2 text-sm font-semibold text-[#213885] hover:text-[#5F3475]" do %>
                <i class="fa-solid fa-download"></i> Executive Headshots
              <% end %>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
