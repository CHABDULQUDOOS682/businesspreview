<div class="min-h-screen bg-stone-100 font-serif text-stone-900 border-8 border-white box-border">
  <!-- Minimalist Hero -->
  <div class="max-w-5xl mx-auto px-6 pt-32 pb-24 text-center">
    <p class="text-stone-500 uppercase tracking-[0.3em] text-sm font-semibold mb-6">
      <%= @business.niche.presence || "Bespoke Services" %>
    </p>
    <h1 class="text-6xl md:text-8xl text-stone-800 tracking-tight font-light mb-8 italic">
      <%= @business.name %>
    </h1>
    <div class="w-24 h-px bg-stone-300 mx-auto mb-8"></div>
    <p class="text-xl md:text-2xl text-stone-600 font-light max-w-2xl mx-auto leading-relaxed">
      Quiet luxury and refined excellence, exclusively in <%= @business.city %>.
    </p>
  </div>

  <!-- Quiet Details -->
  <div class="max-w-4xl mx-auto px-6 py-20 border-t border-stone-200">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
      <div>
        <h2 class="text-2xl font-light text-stone-800 mb-6">The Standard</h2>
        <p class="text-stone-600 leading-relaxed font-sans font-light">
          We bring unparalleled attention to detail to every client we serve. Our reputation speaks for itself, boasting a <%= @business.rating.presence || "4.9" %> rating across <%= @business.city %>. We don't just provide a service; we offer an experience.
        </p>
      </div>
      <div>
        <h2 class="text-2xl font-light text-stone-800 mb-6">Connect</h2>
        <ul class="space-y-4 font-sans font-light text-stone-600">
          <li class="flex items-center gap-4">
            <span class="w-8 text-center text-stone-400">T.</span>
            <span class="text-stone-800"><%= @business.phone.presence || "Upon Request" %></span>
          </li>
          <li class="flex items-center gap-4">
            <span class="w-8 text-center text-stone-400">L.</span>
            <span class="text-stone-800"><%= [@business.city, @business.country].compact.join(", ") %></span>
          </li>
          <% if @business.website.present? %>
            <li class="flex items-center gap-4">
              <span class="w-8 text-center text-stone-400">W.</span>
              <a href="<%= @business.website %>" class="text-stone-800 hover:text-stone-500 underline decoration-stone-300 underline-offset-4">Visit Journal</a>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>

  <!-- Soft Call to Action -->
  <div class="max-w-4xl mx-auto px-6 py-24 text-center">
    <a href="mailto:concierge@<%= @business.name.downcase.gsub(/[^a-z]/, '') %>.com" class="inline-block px-12 py-4 bg-stone-800 text-stone-100 font-sans tracking-widest text-sm uppercase hover:bg-stone-700 transition-colors duration-300">
      Request a Consultation
    </a>
    <p class="mt-8 text-stone-400 font-sans text-xs uppercase tracking-widest">
      A digital prototype crafted carefully for <%= @business.name %>
    </p>
  </div>
</div>
