<div class="min-h-screen bg-rose-50 font-sans">
  <!-- Gradient Hero Section -->
  <div class="bg-gradient-to-br from-rose-500 via-orange-500 to-yellow-500 rounded-b-[4rem] sm:rounded-b-[6rem] shadow-2xl relative overflow-hidden">
    <!-- Abstract shapes -->
    <div class="absolute top-0 left-0 w-64 h-64 bg-white opacity-10 rounded-full mix-blend-overlay filter  transform -translate-x-1/2 -translate-y-1/2"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-white opacity-10 rounded-full mix-blend-overlay filter  transform translate-x-1/3 translate-y-1/3"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32 text-center relative z-10">
      <span class="inline-block py-1 px-3 rounded-full bg-white/20 text-white backdrop- text-sm font-bold uppercase tracking-widest mb-6 border border-white/30">
        <%= @business.niche.presence || "Creative Solutions" %>
      </span>
      <h1 class="text-5xl md:text-7xl font-black tracking-tight text-white mb-6 drop-shadow-md">
        <%= @business.name %>
      </h1>
      <p class="mt-4 text-xl md:text-2xl text-rose-50 max-w-3xl mx-auto font-medium">
        Making waves in <%= @business.city %>. Experience creativity unleashed.
      </p>
    </div>
  </div>

  <!-- Content Boxes -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 -mt-16 sm:-mt-24 relative z-20 pb-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Box 1 -->
      <div class="bg-white rounded-3xl p-8 shadow-xl shadow-rose-900/5 transform transition duration-300 hover:-translate-y-2">
        <div class="w-14 h-14 bg-orange-100 rounded-2xl flex items-center justify-center text-3xl mb-6">🏆</div>
        <h3 class="text-xl font-bold text-slate-900 mb-2">Excellence</h3>
        <p class="text-slate-600"><%= @business.rating ? "Rated #{@business.rating} stars" : "Top rated" %> by clients across the region for outstanding service delivery.</p>
      </div>
      
      <!-- Box 2 -->
      <div class="bg-white rounded-3xl p-8 shadow-xl shadow-rose-900/5 transform transition duration-300 hover:-translate-y-2">
        <div class="w-14 h-14 bg-rose-100 rounded-2xl flex items-center justify-center text-3xl mb-6">📍</div>
        <h3 class="text-xl font-bold text-slate-900 mb-2">Local Roots</h3>
        <p class="text-slate-600">Deeply embedded in the <%= @business.city %> community, understanding local needs better than anyone.</p>
      </div>

      <!-- Box 3 -->
      <div class="bg-white rounded-3xl p-8 shadow-xl shadow-rose-900/5 transform transition duration-300 hover:-translate-y-2">
        <div class="w-14 h-14 bg-yellow-100 rounded-2xl flex items-center justify-center text-3xl mb-6">💬</div>
        <h3 class="text-xl font-bold text-slate-900 mb-2">Say Hello</h3>
        <p class="text-slate-600 font-medium text-lg text-slate-800"><%= @business.phone %></p>
        <% if @business.website.present? %>
          <a href="<%= @business.website %>" target="_blank" class="text-orange-500 font-bold hover:underline mt-2 inline-block">Visit website &rarr;</a>
        <% end %>
      </div>
    </div>
    
    <!-- CTA -->
    <div class="mt-16 bg-slate-900 rounded-3xl p-10 md:p-16 text-center text-white relative overflow-hidden shadow-2xl">
      <!-- pattern -->
      <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 24px 24px;"></div>
      
      <div class="relative z-10">
        <h2 class="text-3xl md:text-5xl font-black mb-6 tracking-tight">Own This Vibrant Experience</h2>
        <p class="text-xl text-slate-300 mb-10 max-w-2xl mx-auto">Stand out from the crowd with a tailored, high-energy digital presence built exclusively for <%= @business.name %>.</p>
        <button class="bg-gradient-to-r from-orange-400 to-rose-500 text-white font-bold py-4 px-10 rounded-full text-lg shadow-lg shadow-rose-500/30 hover:scale-105 transform transition-all">
          Secure Your Design
        </button>
      </div>
    </div>
  </div>
</div>