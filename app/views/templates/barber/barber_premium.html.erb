<nav
  class="fixed w-full z-50 bg-white/90 backdrop-blur-md border-b border-stone-200 relative"
  data-controller="mobile-nav"
  data-action="keydown.escape->mobile-nav#close turbo:before-cache->mobile-nav#close"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-20 items-center">
      <div class="text-2xl font-bold tracking-tighter uppercase serif"><%= @business.name %></div>
      <div class="hidden md:flex space-x-8 items-center uppercase text-sm tracking-widest font-semibold">
        <a href="#about" class="hover:text-amber-700 transition">About</a>
        <a href="#services" class="hover:text-amber-700 transition">Services</a>
        <a href="#packages" class="hover:text-amber-700 transition">Packages</a>
        <a href="#map" class="hover:text-amber-700 transition">Location</a>
        <a href="#gallery" class="hover:text-amber-700 transition">Gallery</a>
        <a href="#team" class="hover:text-amber-700 transition">Team</a>
        <a href="#contact" class="hover:text-amber-700 transition">Contact</a>
        <a href="<%= @business.website_url.presence || '#' %>" class="bg-stone-900 text-white px-6 py-2 hover:bg-amber-800 transition">Book Now</a>
      </div>
      <button
        type="button"
        class="md:hidden inline-flex items-center justify-center rounded-md p-2 text-stone-700 hover:bg-stone-50 hover:text-stone-900 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-amber-700"
        aria-controls="barber-premium-mobile-menu"
        aria-expanded="false"
        data-mobile-nav-target="button"
        data-action="mobile-nav#toggle"
      >
        <span class="sr-only">Open menu</span>
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <div
    id="barber-premium-mobile-menu"
    class="hidden md:hidden absolute top-full inset-x-0 bg-white/95 backdrop-blur-md border-b border-stone-200"
    data-mobile-nav-target="panel"
  >
    <div class="max-w-7xl mx-auto px-4 py-4 grid grid-cols-2 gap-2 text-sm font-semibold uppercase tracking-widest">
      <a href="#about" class="rounded-md px-3 py-2 text-stone-700 hover:bg-stone-50 hover:text-stone-900 transition">About</a>
      <a href="#services" class="rounded-md px-3 py-2 text-stone-700 hover:bg-stone-50 hover:text-stone-900 transition">Services</a>
      <a href="#packages" class="rounded-md px-3 py-2 text-stone-700 hover:bg-stone-50 hover:text-stone-900 transition">Packages</a>
      <a href="#map" class="rounded-md px-3 py-2 text-stone-700 hover:bg-stone-50 hover:text-stone-900 transition">Location</a>
      <a href="#gallery" class="rounded-md px-3 py-2 text-stone-700 hover:bg-stone-50 hover:text-stone-900 transition">Gallery</a>
      <a href="#team" class="rounded-md px-3 py-2 text-stone-700 hover:bg-stone-50 hover:text-stone-900 transition">Team</a>
      <a href="#contact" class="rounded-md px-3 py-2 text-stone-700 hover:bg-stone-50 hover:text-stone-900 transition">Contact</a>
      <a href="<%= @business.website_url.presence || '#' %>" class="col-span-2 rounded-md bg-stone-900 px-3 py-2 text-center text-white hover:bg-amber-800 transition">Book Now</a>
    </div>
  </div>
</nav>

<header class="relative min-h-[70vh] flex items-center justify-center bg-gradient-to-br from-stone-900 via-stone-800 to-stone-700">
  <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 2px 2px, #fff 1px, transparent 0); background-size: 24px 24px;"></div>
  <div class="relative z-10 max-w-4xl mx-auto text-center px-6">
    <div class="inline-block rounded-full px-4 py-2 text-sm leading-6 text-amber-400 ring-1 ring-amber-400/30 mb-6">
      <%= @business.niche.presence || "Barber" %> • <%= [@business.city, @business.country].compact.join(", ") %>
    </div>
    <h1 class="text-5xl md:text-6xl font-black tracking-tight text-white mb-4 serif"><%= @business.name %></h1>
    <p class="text-stone-300 text-lg max-w-2xl mx-auto">Crafted in <%= [@business.city, @business.country].compact.join(", ") %> • Rated <span class="text-amber-400 font-bold"><%= @business.rating.presence || "5.0" %></span></p>
    <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
      <a href="<%= @business.phone.present? ? "tel:#{@business.phone}" : "#" %>" class="rounded-md bg-amber-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-amber-700">Call <%= @business.phone.presence || "" %></a>
      <a href="<%= @business.website_url.presence || '#' %>" class="rounded-md bg-white px-6 py-3 text-sm font-semibold text-stone-900 shadow-sm ring-1 ring-inset ring-stone-300 hover:bg-stone-50">Book Online</a>
    </div>
  </div>
</header>

<section id="about" class="py-16 bg-white px-4">
  <div class="max-w-5xl mx-auto text-center">
    <h2 class="text-4xl serif italic mb-4">A Tradition Of Excellence</h2>
    <p class="text-stone-600 leading-relaxed text-lg">From first cuts to refined shaves, we deliver consistent quality and an elevated experience for every guest.</p>
    <div class="mt-10 grid sm:grid-cols-3 gap-6 text-left">
      <div class="rounded-2xl ring-1 ring-stone-200 p-6">
        <div class="text-3xl mb-3">🪒</div>
        <div class="font-semibold text-stone-900 mb-1">Precision Shaves</div>
        <div class="text-stone-600 text-sm">Hot towel prep, traditional techniques, ultra-smooth finish.</div>
      </div>
      <div class="rounded-2xl ring-1 ring-stone-200 p-6">
        <div class="text-3xl mb-3">✂️</div>
        <div class="font-semibold text-stone-900 mb-1">Signature Cuts</div>
        <div class="text-stone-600 text-sm">Tailored styles, clean lines, and balanced blending.</div>
      </div>
      <div class="rounded-2xl ring-1 ring-stone-200 p-6">
        <div class="text-3xl mb-3">🧴</div>
        <div class="font-semibold text-stone-900 mb-1">Beard Sculpting</div>
        <div class="text-stone-600 text-sm">Defined shapes and conditioning for long-lasting results.</div>
      </div>
    </div>
  </div>
</section>

<section id="map" class="py-20 bg-white px-4">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-8">
      <h2 class="text-4xl serif italic">Location</h2>
      <p class="text-stone-500 mt-2"><%= [@business.website_name.presence || @business.name, @business.city, @business.country].compact.join(", ") %></p>
    </div>
    <div class="rounded-2xl overflow-hidden ring-1 ring-stone-200">
      <iframe
        src="https://www.google.com/maps?q=<%= ERB::Util.url_encode([@business.website_name.presence || @business.name, @business.city, @business.country].compact.join(', ')) %>&output=embed"
        width="100%"
        height="420"
        style="border:0;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade">
      </iframe>
    </div>
    <div class="text-center mt-4">
      <a href="https://www.google.com/maps/search/<%= ERB::Util.url_encode([@business.website_name.presence || @business.name, @business.city, @business.country].compact.join(', ')) %>" target="_blank" class="inline-block rounded-md bg-stone-900 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-stone-800">Open in Google Maps</a>
    </div>
  </div>
</section>

<section id="services" class="py-20 bg-stone-50 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-4xl serif italic">Services</h2>
      <p class="text-stone-500 mt-2">Clear, fair pricing and premium care.</p>
    </div>
    <div class="grid lg:grid-cols-3 gap-8">
      <div class="rounded-2xl bg-white ring-1 ring-stone-200 p-8">
        <div class="flex items-baseline justify-between">
          <div class="text-xl font-semibold serif">Traditional Haircut</div>
          <div class="text-2xl font-bold">$30</div>
        </div>
        <p class="text-stone-600 mt-2">Includes neckline straight razor by request and style finish.</p>
      </div>
      <div class="rounded-2xl bg-white ring-1 ring-stone-200 p-8">
        <div class="flex items-baseline justify-between">
          <div class="text-xl font-semibold serif">Beard Trim & Shape</div>
          <div class="text-2xl font-bold">$15</div>
        </div>
        <p class="text-stone-600 mt-2">Careful shaping with line detail and conditioning.</p>
      </div>
      <div class="rounded-2xl bg-white ring-1 ring-stone-200 p-8">
        <div class="flex items-baseline justify-between">
          <div class="text-xl font-semibold serif">Straight Razor Shave</div>
          <div class="text-2xl font-bold">$25</div>
        </div>
        <p class="text-stone-600 mt-2">Hot towel prep and a classic close shave.</p>
      </div>
    </div>
  </div>
</section>

<section id="packages" class="py-20 bg-white px-4">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-4xl serif italic">Membership</h2>
      <p class="text-stone-500 mt-2">Exclusive plans for regulars.</p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
      <div class="rounded-2xl ring-1 ring-stone-200 p-8">
        <div class="text-xl font-semibold">Classic</div>
        <div class="text-stone-500 text-sm mb-4">2 cuts/month</div>
        <div class="text-3xl font-black mb-4">$49</div>
        <ul class="text-stone-600 space-y-2 text-sm">
          <li>Priority scheduling</li>
          <li>Member discount on products</li>
          <li>Complimentary hot towel</li>
        </ul>
        <div class="mt-6">
          <a href="<%= @business.website_url.presence || '#' %>" class="rounded-md bg-stone-900 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-stone-800">Join</a>
        </div>
      </div>
      <div class="rounded-2xl ring-2 ring-amber-400 p-8 bg-amber-50">
        <div class="text-xl font-semibold">Premium</div>
        <div class="text-stone-600 text-sm mb-4">Unlimited trims</div>
        <div class="text-3xl font-black mb-4">$79</div>
        <ul class="text-stone-700 space-y-2 text-sm">
          <li>Unlimited beard trims</li>
          <li>Priority + flexible rescheduling</li>
          <li>Annual gift kit</li>
        </ul>
        <div class="mt-6">
          <a href="<%= @business.website_url.presence || '#' %>" class="rounded-md bg-amber-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-amber-700">Join</a>
        </div>
      </div>
      <div class="rounded-2xl ring-1 ring-stone-200 p-8">
        <div class="text-xl font-semibold">Family</div>
        <div class="text-stone-500 text-sm mb-4">Up to 4 members</div>
        <div class="text-3xl font-black mb-4">$99</div>
        <ul class="text-stone-600 space-y-2 text-sm">
          <li>Shared plan for household</li>
          <li>Kids’ first haircut certificate</li>
          <li>Product bundle discount</li>
        </ul>
        <div class="mt-6">
          <a href="<%= @business.website_url.presence || '#' %>" class="rounded-md bg-stone-900 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-stone-800">Join</a>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="gallery" class="py-20 bg-stone-100 px-4">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-4xl serif italic">Gallery</h2>
      <p class="text-stone-500 mt-2">Inside the shop and the craft.</p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <%= image_tag "barber/gallery1.svg", class: "rounded-xl object-cover w-full h-56", alt: "Gallery 1" %>
      <%= image_tag "barber/gallery2.svg", class: "rounded-xl object-cover w-full h-56", alt: "Gallery 2" %>
      <%= image_tag "barber/gallery3.svg", class: "rounded-xl object-cover w-full h-56", alt: "Gallery 3" %>
      <%= image_tag "barber/gallery4.svg", class: "rounded-xl object-cover w-full h-56", alt: "Gallery 4" %>
      <%= image_tag "barber/gallery5.svg", class: "rounded-xl object-cover w-full h-56", alt: "Gallery 5" %>
      <%= image_tag "barber/gallery6.svg", class: "rounded-xl object-cover w-full h-56", alt: "Gallery 6" %>
    </div>
  </div>
</section>

<section id="team" class="py-20 bg-white px-4">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-4xl serif italic">Team</h2>
      <p class="text-stone-500 mt-2">Crafted by passionate barbers.</p>
    </div>
    <div class="grid sm:grid-cols-2 gap-8">
      <div class="rounded-2xl bg-stone-50 ring-1 ring-stone-200 p-6 flex items-center gap-4">
        <div class="w-16 h-16 rounded-full bg-stone-200"></div>
        <div>
          <div class="text-stone-900 font-semibold">Alex</div>
          <div class="text-stone-500 text-sm">Master Barber • 10+ years</div>
          <p class="text-stone-600 mt-2 text-sm">Classic fades, razor shaves, and tailored styles.</p>
        </div>
      </div>
      <div class="rounded-2xl bg-stone-50 ring-1 ring-stone-200 p-6 flex items-center gap-4">
        <div class="w-16 h-16 rounded-full bg-stone-200"></div>
        <div>
          <div class="text-stone-900 font-semibold">Mia</div>
          <div class="text-stone-500 text-sm">Senior Barber • 8+ years</div>
          <p class="text-stone-600 mt-2 text-sm">Clean line work, beard sculpting, and detail care.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="contact" class="py-20 bg-stone-100 px-4">
  <div class="max-w-5xl mx-auto text-center">
    <h2 class="text-4xl serif italic mb-4">Contact</h2>
    <p class="text-stone-600 mb-6">Find us in <%= [@business.city, @business.country].compact.join(", ") %>. We’re happy to help.</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="<%= @business.phone.present? ? "tel:#{@business.phone}" : "#" %>" class="rounded-md bg-stone-900 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-stone-800">Call <%= @business.phone.presence || "" %></a>
      <a href="<%= @business.email.present? ? "mailto:#{@business.email}" : "#" %>" class="rounded-md bg-amber-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-amber-700">Email <%= @business.email.presence || "" %></a>
      <a href="<%= @business.website_url.presence || '#' %>" class="rounded-md bg-white px-6 py-3 text-sm font-semibold text-stone-900 shadow-sm ring-1 ring-inset ring-stone-300 hover:bg-stone-50">Visit Website</a>
    </div>
  </div>
</section>

<footer class="bg-stone-900 text-white py-16 px-4">
  <div class="max-w-7xl mx-auto grid md:grid-cols-3 gap-12 text-center md:text-left">
    <div>
      <div class="serif italic text-2xl mb-4">Hours</div>
      <div class="text-stone-400">Tue–Fri: <span class="text-stone-200">8:30 AM – 5:30 PM</span></div>
      <div class="text-stone-400">Sat: <span class="text-stone-200">8:00 AM – 2:00 PM</span></div>
    </div>
    <div>
      <div class="serif italic text-2xl mb-4">Visit</div>
      <div class="text-stone-200"><%= @business.website_name.presence || @business.name %></div>
      <div class="text-stone-200"><%= [@business.city, @business.country].compact.join(", ") %></div>
      <div class="text-amber-500 mt-4 font-bold"><%= @business.phone.presence || "(555) 123-4567" %></div>
    </div>
    <div>
      <div class="serif italic text-2xl mb-4">Connect</div>
      <div class="text-stone-400"><%= @business.email.presence || "info@example.com" %></div>
      <div class="mt-6 flex justify-center md:justify-start space-x-6 text-sm uppercase tracking-widest font-bold">
        <a href="#" class="hover:text-amber-500 transition">Instagram</a>
        <a href="#" class="hover:text-amber-500 transition">Facebook</a>
      </div>
    </div>
  </div>
  <div class="text-center mt-12 pt-8 border-t border-stone-800 text-stone-600 text-sm">
    © <%= Time.current.year %> <%= @business.name %>. All rights reserved.
  </div>
</footer>
