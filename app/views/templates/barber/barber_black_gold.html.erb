<nav
  class="fixed top-0 w-full z-50 bg-black/80 backdrop-blur-md border-b border-white/10 relative"
  data-controller="mobile-nav"
  data-action="keydown.escape->mobile-nav#close turbo:before-cache->mobile-nav#close"
>
  <div class="max-w-7xl mx-auto px-5 h-16 flex items-center justify-between">
    <div class="flex items-center gap-6">
      <a href="#hero" class="text-xl font-bold tracking-wide text-white"><%= @business.name %></a>
      <div class="hidden md:flex items-center gap-5 text-sm">
        <a href="#services" class="text-white/70 hover:text-amber-400 transition">Services</a>
        <a href="#about" class="text-white/70 hover:text-amber-400 transition">About</a>
        <a href="#testimonials" class="text-white/70 hover:text-amber-400 transition">Reviews</a>
        <a href="#location" class="text-white/70 hover:text-amber-400 transition">Location</a>
      </div>
    </div>
    <div class="flex items-center gap-3">
      <a href="<%= @business.phone.present? ? "tel:#{@business.phone}" : "#" %>" class="hidden sm:inline-flex rounded-md border border-amber-500/50 px-3 py-2 text-xs font-semibold text-amber-400 hover:bg-amber-500 hover:text-black transition">Call Now</a>
      <a href="<%= @business.website_url.presence || '#booking' %>" class="inline-flex rounded-md bg-amber-600 px-4 py-2 text-xs font-semibold text-black hover:bg-amber-500 transition">Book Now</a>
      <button
        type="button"
        class="md:hidden inline-flex items-center justify-center rounded-md p-2 text-white/80 hover:text-white hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-amber-500"
        aria-controls="bbg-mobile-menu"
        aria-expanded="false"
        data-mobile-nav-target="button"
        data-action="mobile-nav#toggle"
      >
        <span class="sr-only">Open menu</span>
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <div
    id="bbg-mobile-menu"
    class="hidden md:hidden absolute top-full inset-x-0 bg-black/90 backdrop-blur-md border-b border-white/10"
    data-mobile-nav-target="panel"
  >
    <div class="max-w-7xl mx-auto px-5 py-4 grid grid-cols-2 gap-3 text-sm">
      <a href="#services" class="rounded-md px-3 py-2 text-white/80 hover:text-white hover:bg-white/10 transition">Services</a>
      <a href="#about" class="rounded-md px-3 py-2 text-white/80 hover:text-white hover:bg-white/10 transition">About</a>
      <a href="#testimonials" class="rounded-md px-3 py-2 text-white/80 hover:text-white hover:bg-white/10 transition">Reviews</a>
      <a href="#location" class="rounded-md px-3 py-2 text-white/80 hover:text-white hover:bg-white/10 transition">Location</a>
    </div>
  </div>
</nav>

<section id="hero" class="relative pt-16">
  <div class="relative h-[85vh] md:h-screen">
    <div class="absolute inset-0">
      <div class="w-full h-full bg-cover bg-center" style="background-image: url('<%= asset_path('barber/hero.svg') %>');"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-black/40 to-black"></div>
    </div>
    <div class="relative z-10 max-w-5xl mx-auto px-5 h-full flex flex-col justify-center items-center text-center">
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-white">Precision Cuts. Premium Experience.</h1>
      <p class="mt-4 text-white/80 text-lg md:text-xl max-w-2xl">Quality grooming with modern style. Confidence built into every detail.</p>
      <div class="mt-6 flex items-center gap-3 text-amber-400">
        <span class="text-lg">★★★★★</span>
        <span class="text-xs md:text-sm text-white/70"><%= (@business.visit_count || 128) %>+ reviews</span>
        <span class="text-white/40">•</span>
        <span class="text-xs md:text-sm text-white/70"><%= [@business.city, @business.country].compact.join(", ") %></span>
      </div>
      <div class="mt-8 flex flex-col sm:flex-row gap-3">
        <a href="<%= @business.website_url.presence || '#booking' %>" class="rounded-md bg-amber-600 px-6 py-3 text-sm font-semibold text-black hover:bg-amber-500">Book Appointment</a>
        <a href="<%= @business.phone.present? ? "tel:#{@business.phone}" : "#" %>" class="rounded-md border border-amber-500/50 px-6 py-3 text-sm font-semibold text-amber-400 hover:bg-amber-500 hover:text-black">Call Now</a>
      </div>
      <div class="mt-10 h-16 w-px bg-gradient-to-b from-transparent via-white/40 to-transparent"></div>
    </div>
  </div>
</section>

<section id="services" class="py-16 bg-black">
  <div class="max-w-7xl mx-auto px-5">
    <div class="text-center mb-10">
      <h2 class="text-3xl md:text-4xl font-bold text-white">Services</h2>
      <p class="text-white/60 mt-2">Premium care with transparent pricing</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="rounded-2xl bg-white/5 ring-1 ring-white/10 p-6 hover:bg-white/10 transition">
        <div class="text-3xl mb-2">✂️</div>
        <div class="font-semibold text-white">Haircut</div>
        <p class="text-white/60 text-sm mt-1">Clean lines and styled finish</p>
        <div class="mt-3 text-amber-400 font-bold">$30</div>
      </div>
      <div class="rounded-2xl bg-white/5 ring-1 ring-white/10 p-6 hover:bg-white/10 transition">
        <div class="text-3xl mb-2">🧔</div>
        <div class="font-semibold text-white">Beard Trim</div>
        <p class="text-white/60 text-sm mt-1">Shape and define with care</p>
        <div class="mt-3 text-amber-400 font-bold">$15</div>
      </div>
      <div class="rounded-2xl bg-white/5 ring-1 ring-white/10 p-6 hover:bg-white/10 transition">
        <div class="text-3xl mb-2">🪒</div>
        <div class="font-semibold text-white">Hair + Beard Combo</div>
        <p class="text-white/60 text-sm mt-1">Complete look, one session</p>
        <div class="mt-3 text-amber-400 font-bold">$40</div>
      </div>
      <div class="rounded-2xl bg-white/5 ring-1 ring-white/10 p-6 hover:bg-white/10 transition">
        <div class="text-3xl mb-2">👦</div>
        <div class="font-semibold text-white">Kids Cut</div>
        <p class="text-white/60 text-sm mt-1">Comfortable, friendly experience</p>
        <div class="mt-3 text-amber-400 font-bold">$25</div>
      </div>
    </div>
  </div>
</section>

<section id="about" class="py-16 bg-[#0a0a0a]">
  <div class="max-w-7xl mx-auto px-5 grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
    <div class="rounded-2xl overflow-hidden ring-1 ring-white/10">
      <%= image_tag "barber/gallery2.svg", class: "w-full h-full object-cover", alt: "Barber shop" %>
    </div>
    <div>
      <h3 class="text-2xl md:text-3xl font-bold text-white">Crafted By Professionals</h3>
      <p class="mt-3 text-white/70">Years of experience, sharp attention to detail, and a passion for confidence. Every session is tailored to your style.</p>
      <div class="mt-6 flex items-center gap-4">
        <div class="rounded-xl bg-white/5 ring-1 ring-white/10 px-4 py-3 text-center">
          <div class="text-amber-400 font-black text-xl">10+</div>
          <div class="text-white/60 text-xs">Years</div>
        </div>
        <div class="rounded-xl bg-white/5 ring-1 ring-white/10 px-4 py-3 text-center">
          <div class="text-amber-400 font-black text-xl">1K+</div>
          <div class="text-white/60 text-xs">Happy Clients</div>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="testimonials" class="py-16 bg-black">
  <div class="max-w-7xl mx-auto px-5">
    <div class="text-center mb-10">
      <h3 class="text-3xl font-bold text-white">What Clients Say</h3>
      <p class="text-white/60 mt-2">Trusted by <%= [@business.city, @business.country].compact.join(", ") %></p>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="rounded-2xl bg-white/5 ring-1 ring-white/10 p-6">
        <div class="text-amber-400">★★★★★</div>
        <p class="mt-3 text-white/80">Best fade I've had. Attention to detail is unreal and the vibe is premium.</p>
        <div class="mt-3 text-white/60 text-sm">— James P.</div>
      </div>
      <div class="rounded-2xl bg-white/5 ring-1 ring-white/10 p-6">
        <div class="text-amber-400">★★★★★</div>
        <p class="mt-3 text-white/80">Clean, professional, and fast. Booking was effortless and results were sharp.</p>
        <div class="mt-3 text-white/60 text-sm">— Aaron V.</div>
      </div>
      <div class="rounded-2xl bg-white/5 ring-1 ring-white/10 p-6">
        <div class="text-amber-400">★★★★★</div>
        <p class="mt-3 text-white/80">Friendly team and premium experience. My go-to spot before big events.</p>
        <div class="mt-3 text-white/60 text-sm">— Malik R.</div>
      </div>
    </div>
  </div>
</section>

<section id="booking" class="py-16 bg-[#0a0a0a]">
  <div class="max-w-6xl mx-auto px-5 text-center">
    <div class="inline-flex items-center gap-2 rounded-full bg-amber-600/10 ring-1 ring-amber-600/30 px-4 py-1 text-xs text-amber-400">Limited slots today</div>
    <h3 class="mt-4 text-3xl md:text-4xl font-bold text-white">Ready for Your Fresh Cut?</h3>
    <p class="mt-2 text-white/70">Book now to secure your preferred time. Walk-ins welcome.</p>
    <div class="mt-6 flex flex-col sm:flex-row gap-3 justify-center">
      <a href="<%= @business.website_url.presence || '#booking' %>" class="rounded-md bg-amber-600 px-6 py-3 text-sm font-semibold text-black hover:bg-amber-500">Book Appointment</a>
      <a href="<%= @business.phone.present? ? "tel:#{@business.phone}" : "#" %>" class="rounded-md border border-amber-500/50 px-6 py-3 text-sm font-semibold text-amber-400 hover:bg-amber-500 hover:text-black">Call <%= @business.phone.presence || "" %></a>
    </div>
  </div>
</section>

<section id="location" class="py-16 bg-black">
  <div class="max-w-7xl mx-auto px-5 grid grid-cols-1 lg:grid-cols-2 gap-8">
    <div>
      <h4 class="text-2xl font-bold text-white">Visit Us</h4>
      <p class="mt-2 text-white/70"><%= [@business.website_name.presence || @business.name, @business.city, @business.country].compact.join(", ") %></p>
      <div class="mt-6 rounded-2xl overflow-hidden ring-1 ring-white/10">
        <iframe
          src="https://www.google.com/maps?q=<%= ERB::Util.url_encode([@business.website_name.presence || @business.name, @business.city, @business.country].compact.join(', ')) %>&output=embed"
          width="100%"
          height="360"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>
    </div>
    <div class="rounded-2xl bg-white/5 ring-1 ring-white/10 p-6">
      <h4 class="text-xl font-semibold text-white">Hours</h4>
      <div class="mt-4 space-y-3 text-sm">
        <div class="flex justify-between text-white/70"><span>Mon–Fri</span><span>8:30 AM – 5:30 PM</span></div>
        <div class="flex justify-between text-white/70"><span>Sat</span><span>8:00 AM – 2:00 PM</span></div>
        <div class="flex justify-between text-white/70"><span>Sun</span><span>Closed</span></div>
      </div>
      <div class="mt-6 flex items-center gap-4">
        <a href="#" class="text-white/60 hover:text-white transition text-sm">Instagram</a>
        <a href="#" class="text.white/60 hover:text-white transition text-sm">Facebook</a>
      </div>
    </div>
  </div>
</section>
