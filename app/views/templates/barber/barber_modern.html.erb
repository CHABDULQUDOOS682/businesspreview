<nav
  class="fixed w-full z-50 bg-white/90 backdrop-blur-md border-b border-stone-200 relative"
  data-controller="mobile-nav"
  data-action="keydown.escape->mobile-nav#close turbo:before-cache->mobile-nav#close"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16 items-center">
      <div class="text-xl font-bold tracking-tight"><%= @business.name %></div>
      <div class="hidden md:flex space-x-8 items-center text-sm font-semibold">
        <a href="#overview" class="hover:text-amber-700 transition">Overview</a>
        <a href="#services" class="hover:text-amber-700 transition">Services</a>
        <a href="#highlights" class="hover:text-amber-700 transition">Highlights</a>
        <a href="#location" class="hover:text-amber-700 transition">Location</a>
        <a href="#book" class="hover:text-amber-700 transition">Book</a>
        <a href="#contact" class="hover:text-amber-700 transition">Contact</a>
        <a href="<%= @business.website_url.presence || '#' %>" class="bg-stone-900 text-white px-4 py-2 rounded-md hover:bg-amber-800 transition">Book Now</a>
      </div>
      <button
        type="button"
        class="md:hidden inline-flex items-center justify-center rounded-md p-2 text-stone-700 hover:bg-stone-50 hover:text-stone-900 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-amber-700"
        aria-controls="barber-modern-mobile-menu"
        aria-expanded="false"
        data-mobile-nav-target="button"
        data-action="mobile-nav#toggle"
      >
        <span class="sr-only">Open menu</span>
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <div
    id="barber-modern-mobile-menu"
    class="hidden md:hidden absolute top-full inset-x-0 bg-white/95 backdrop-blur-md border-b border-stone-200"
    data-mobile-nav-target="panel"
  >
    <div class="max-w-7xl mx-auto px-4 py-4 grid grid-cols-2 gap-2 text-sm font-semibold">
      <a href="#overview" class="rounded-md px-3 py-2 text-stone-700 hover:bg-stone-50 hover:text-stone-900 transition">Overview</a>
      <a href="#services" class="rounded-md px-3 py-2 text-stone-700 hover:bg-stone-50 hover:text-stone-900 transition">Services</a>
      <a href="#highlights" class="rounded-md px-3 py-2 text-stone-700 hover:bg-stone-50 hover:text-stone-900 transition">Highlights</a>
      <a href="#location" class="rounded-md px-3 py-2 text-stone-700 hover:bg-stone-50 hover:text-stone-900 transition">Location</a>
      <a href="#book" class="rounded-md px-3 py-2 text-stone-700 hover:bg-stone-50 hover:text-stone-900 transition">Book</a>
      <a href="#contact" class="rounded-md px-3 py-2 text-stone-700 hover:bg-stone-50 hover:text-stone-900 transition">Contact</a>
      <a href="<%= @business.website_url.presence || '#' %>" class="col-span-2 rounded-md bg-stone-900 px-3 py-2 text-center text-white hover:bg-amber-800 transition">Book Now</a>
    </div>
  </div>
</nav>

<header id="overview" class="pt-20 bg-gradient-to-br from-stone-900 via-stone-800 to-stone-700 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 grid lg:grid-cols-2 gap-12 items-center">
    <div>
      <h1 class="text-4xl md:text-5xl font-black tracking-tight mb-4"><%= @business.name %></h1>
      <p class="text-stone-300 text-lg mb-6">Modern grooming rooted in tradition — serving <%= [@business.city, @business.country].compact.join(", ") %>.</p>
      <div class="flex flex-wrap gap-3">
        <span class="inline-flex items-center rounded-md bg-amber-50 px-3 py-1 text-xs font-medium text-amber-700 ring-1 ring-inset ring-amber-600/20">
          Rating: <%= @business.rating.presence || "5.0" %>
        </span>
        <span class="inline-flex items-center rounded-md bg-green-50 px-3 py-1 text-xs font-medium text-green-700 ring-1 ring-inset ring-green-600/20">
          Niche: <%= @business.niche.presence || "Barber" %>
        </span>
      </div>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="<%= @business.phone.present? ? "tel:#{@business.phone}" : "#" %>" class="rounded-md bg-amber-600 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-amber-700">Call <%= @business.phone.presence || "" %></a>
        <a href="<%= @business.website_url.presence || '#' %>" class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-stone-900 shadow-sm ring-1 ring-inset ring-stone-300 hover:bg-stone-50">Book Online</a>
      </div>
    </div>
    <div class="rounded-2xl bg-stone-800/40 ring-1 ring-stone-700 p-6">
      <div class="grid grid-cols-2 gap-4 text-center">
        <div class="rounded-xl bg-stone-900/40 p-4">
          <div class="text-2xl font-black">10+</div>
          <div class="text-stone-300 text-xs">Years Experience</div>
        </div>
        <div class="rounded-xl bg-stone-900/40 p-4">
          <div class="text-2xl font-black">1K+</div>
          <div class="text-stone-300 text-xs">Happy Clients</div>
        </div>
        <div class="rounded-xl bg-stone-900/40 p-4">
          <div class="text-2xl font-black">24</div>
          <div class="text-stone-300 text-xs">Slots / Day</div>
        </div>
        <div class="rounded-xl bg-stone-900/40 p-4">
          <div class="text-2xl font-black">4.9</div>
          <div class="text-stone-300 text-xs">Avg. Review</div>
        </div>
      </div>
    </div>
  </div>
</header>

<section id="services" class="py-16 bg-white px-4">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-10">
      <h2 class="text-3xl serif italic">Services & Pricing</h2>
      <p class="text-stone-600 mt-2">Transparent rates and premium care.</p>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="rounded-2xl ring-1 ring-stone-200 p-6">
        <div class="flex items-center justify-between mb-2">
          <div class="font-semibold">Traditional Haircut</div>
          <div class="text-xl font-black">$30</div>
        </div>
        <p class="text-stone-600 text-sm">Neckline straight razor by request, styled finish.</p>
      </div>
      <div class="rounded-2xl ring-1 ring-stone-200 p-6">
        <div class="flex items-center justify-between mb-2">
          <div class="font-semibold">Beard Trim & Shape</div>
          <div class="text-xl font-black">$15</div>
        </div>
        <p class="text-stone-600 text-sm">Line detailing and conditioning for clean definition.</p>
      </div>
      <div class="rounded-2xl ring-1 ring-stone-200 p-6">
        <div class="flex items-center justify-between mb-2">
          <div class="font-semibold">Straight Razor Shave</div>
          <div class="text-xl font-black">$25</div>
        </div>
        <p class="text-stone-600 text-sm">Hot towel prep and a classic close shave.</p>
      </div>
    </div>
  </div>
</section>

<section id="highlights" class="py-16 bg-stone-50 px-4">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-10">
      <h2 class="text-3xl serif italic">Why Choose Us</h2>
      <p class="text-stone-600 mt-2">Elevated experience, every visit.</p>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="rounded-2xl bg-white ring-1 ring-stone-200 p-6">
        <div class="text-3xl mb-2">🪒</div>
        <div class="font-semibold">Classic Craft</div>
        <p class="text-stone-600 text-sm mt-1">Traditional techniques refined for modern results.</p>
      </div>
      <div class="rounded-2xl bg-white ring-1 ring-stone-200 p-6">
        <div class="text-3xl mb-2">🧴</div>
        <div class="font-semibold">Premium Products</div>
        <p class="text-stone-600 text-sm mt-1">Conditioning and care for lasting finish.</p>
      </div>
      <div class="rounded-2xl bg-white ring-1 ring-stone-200 p-6">
        <div class="text-3xl mb-2">⏱️</div>
        <div class="font-semibold">Effortless Booking</div>
        <p class="text-stone-600 text-sm mt-1">Online scheduling and flexible rescheduling.</p>
      </div>
    </div>
  </div>
</section>

<section id="location" class="py-16 bg-white px-4">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-8">
      <h2 class="text-3xl serif italic">Find Us</h2>
      <p class="text-stone-600"><%= [@business.website_name.presence || @business.name, @business.city, @business.country].compact.join(", ") %></p>
    </div>
    <div class="rounded-2xl overflow-hidden ring-1 ring-stone-200">
      <iframe
        src="https://www.google.com/maps?q=<%= ERB::Util.url_encode([@business.website_name.presence || @business.name, @business.city, @business.country].compact.join(', ')) %>&output=embed"
        width="100%"
        height="420"
        style="border:0;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade">
      </iframe>
    </div>
    <div class="text-center mt-4">
      <a href="https://www.google.com/maps/search/<%= ERB::Util.url_encode([@business.website_name.presence || @business.name, @business.city, @business.country].compact.join(', ')) %>" target="_blank" class="inline-block rounded-md bg-stone-900 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-stone-800">Open in Google Maps</a>
    </div>
  </div>
</section>

<section id="book" class="py-16 bg-stone-50 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-10">
      <h2 class="text-3xl serif italic">How To Book</h2>
      <p class="text-stone-600">Three easy steps to your next cut.</p>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="rounded-2xl bg-white ring-1 ring-stone-200 p-6">
        <div class="font-semibold mb-1">1. Choose Service</div>
        <p class="text-stone-600 text-sm">Pick your preferred service and time slot.</p>
      </div>
      <div class="rounded-2xl bg-white ring-1 ring-stone-200 p-6">
        <div class="font-semibold mb-1">2. Confirm Details</div>
        <p class="text-stone-600 text-sm">Add any notes or requests — we’ll tailor your experience.</p>
      </div>
      <div class="rounded-2xl bg-white ring-1 ring-stone-200 p-6">
        <div class="font-semibold mb-1">3. Show Up</div>
        <p class="text-stone-600 text-sm">Enjoy your session — payment by cash or card.</p>
      </div>
    </div>
    <div class="text-center mt-8">
      <a href="<%= @business.website_url.presence || '#' %>" class="rounded-md bg-amber-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-amber-700">Book Online</a>
    </div>
  </div>
</section>

<section id="contact" class="py-16 bg-white px-4">
  <div class="max-w-6xl mx-auto text-center">
    <h2 class="text-3xl serif italic mb-4">Contact</h2>
    <p class="text-stone-600 mb-6">Reach us in <%= [@business.city, @business.country].compact.join(", ") %>.</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="<%= @business.phone.present? ? "tel:#{@business.phone}" : "#" %>" class="rounded-md bg-stone-900 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-stone-800">Call <%= @business.phone.presence || "" %></a>
      <a href="<%= @business.email.present? ? "mailto:#{@business.email}" : "#" %>" class="rounded-md bg-amber-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-amber-700">Email <%= @business.email.presence || "" %></a>
      <a href="<%= @business.website_url.presence || '#' %>" class="rounded-md bg-white px-6 py-3 text-sm font-semibold text-stone-900 shadow-sm ring-1 ring-inset ring-stone-300 hover:bg-stone-50">Visit Website</a>
    </div>
  </div>
</section>

<footer class="bg-stone-900 text-white py-12 px-4">
  <div class="max-w-7xl mx-auto grid md:grid-cols-3 gap-12 text-center md:text-left">
    <div>
      <div class="serif italic text-xl mb-3">Hours</div>
      <div class="text-stone-400">Tue–Fri: <span class="text-stone-200">8:30 AM – 5:30 PM</span></div>
      <div class="text-stone-400">Sat: <span class="text-stone-200">8:00 AM – 2:00 PM</span></div>
    </div>
    <div>
      <div class="serif italic text-xl mb-3">Visit</div>
      <div class="text-stone-200"><%= @business.website_name.presence || @business.name %></div>
      <div class="text-stone-200"><%= [@business.city, @business.country].compact.join(", ") %></div>
      <div class="text-amber-500 mt-4 font-bold"><%= @business.phone.presence || "(555) 123-4567" %></div>
    </div>
    <div>
      <div class="serif italic text-xl mb-3">Connect</div>
      <div class="text-stone-400"><%= @business.email.presence || "info@example.com" %></div>
      <div class="mt-6 flex justify-center md:justify-start space-x-6 text-sm uppercase tracking-widest font-bold">
        <a href="#" class="hover:text-amber-500 transition">Instagram</a>
        <a href="#" class="hover:text-amber-500 transition">Facebook</a>
      </div>
    </div>
  </div>
  <div class="text-center mt-10 pt-6 border-t border-stone-800 text-stone-600 text-sm">
    © <%= Time.current.year %> <%= @business.name %>. All rights reserved.
  </div>
</footer>
